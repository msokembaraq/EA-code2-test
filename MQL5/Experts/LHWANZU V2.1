//  MARKET STRUCTURE
//+------------------------------------------------------------------+
void UpdateMarketStructure()
  {
   double   sh1 = 0,  sh2 = 0;
   datetime sht1 = 0, sht2 = 0;
   double   sl1 = 0,  sl2 = 0;
   datetime slt1 = 0, slt2 = 0;

   for(int k = 0; k < g_nLv; k++)
     {
      if(g_lv[k].broken) continue;
      if(g_lv[k].isHigh)
        {
         if(g_lv[k].t1 > sht1)
           { sht2 = sht1; sh2 = sh1; sht1 = g_lv[k].t1; sh1 = g_lv[k].price; }
         else if(g_lv[k].t1 > sht2)
           { sht2 = g_lv[k].t1; sh2 = g_lv[k].price; }
        }
      else
        {
         if(g_lv[k].t1 > slt1)
           { slt2 = slt1; sl2 = sl1; slt1 = g_lv[k].t1; sl1 = g_lv[k].price; }
         else if(g_lv[k].t1 > slt2)
           { slt2 = g_lv[k].t1; sl2 = g_lv[k].price; }
        }
     }

   bool lowerHigh  = (sh1 > 0 && sh2 > 0 && sh1 < sh2);
   bool lowerLow   = (sl1 > 0 && sl2 > 0 && sl1 < sl2);
   bool higherHigh = (sh1 > 0 && sh2 > 0 && sh1 > sh2);
   bool higherLow  = (sl1 > 0 && sl2 > 0 && sl1 > sl2);

   if(lowerHigh  && lowerLow)       g_msDir = -1;
   else if(higherHigh && higherLow) g_msDir =  1;
  }

//+------------------------------------------------------------------+
//  GET NEXT N PIVOT TARGETS
//+------------------------------------------------------------------+
void GetNextPivots(bool isBuy, double refPrice, double &tp[], int n)
  {
   ArrayResize(tp, n);
   ArrayInitialize(tp, 0.0);
   double found[];
   int    fCount = 0;

   for(int k = 0; k < g_nLv; k++)
     {
      if(g_lv[k].broken) continue;
      if( isBuy && !g_lv[k].isHigh) continue;
      if(!isBuy &&  g_lv[k].isHigh) continue;
      if( isBuy && g_lv[k].price <= refPrice) continue;
      if(!isBuy && g_lv[k].price >= refPrice) continue;
      ArrayResize(found, fCount + 1);
      found[fCount++] = g_lv[k].price;
     }

   for(int a = 0; a < fCount - 1; a++)
      for(int b = a + 1; b < fCount; b++)
        {
         bool sw = isBuy ? (found[b] < found[a]) : (found[b] > found[a]);
         if(sw) { double tmp = found[a]; found[a] = found[b]; found[b] = tmp; }
        }

   for(int i = 0; i < n && i < fCount; i++)
      tp[i] = found[i];
  }

//+------------------------------------------------------------------+
int OnInit()
  {
   SetIndexBuffer(0, RSI_Buffer,      INDICATOR_DATA);
   SetIndexBuffer(1, SAR_Buffer,      INDICATOR_DATA);
   SetIndexBuffer(2, SigUp_Buffer,    INDICATOR_DATA);
   SetIndexBuffer(3, SigDn_Buffer,    INDICATOR_DATA);
   SetIndexBuffer(4, StrongUp_Buffer, INDICATOR_DATA);
   SetIndexBuffer(5, StrongDn_Buffer, INDICATOR_DATA);
   SetIndexBuffer(6, IsBelow_Buffer,  INDICATOR_CALCULATIONS);
   SetIndexBuffer(7, SAR_Internal,    INDICATOR_CALCULATIONS);

   PlotIndexSetInteger(1, PLOT_ARROW, 159);
   PlotIndexSetInteger(2, PLOT_ARROW, 117);
   PlotIndexSetInteger(3, PLOT_ARROW, 117);
   PlotIndexSetInteger(4, PLOT_ARROW, 110);
   PlotIndexSetInteger(5, PLOT_ARROW, 110);

   g_atrHandle = iATR(NULL, 0, InpATRLen);
   if(g_atrHandle == INVALID_HANDLE) return INIT_FAILED;

   InitPendingSignals();
   IndicatorSetString(INDICATOR_SHORTNAME, "LHWANZU 1903 v2.1");
   return INIT_SUCCEEDED;
  }

//+------------------------------------------------------------------+
void OnDeinit(const int reason)
  {
   if(g_atrHandle != INVALID_HANDLE) IndicatorRelease(g_atrHandle);
   if(g_rsiHandle != INVALID_HANDLE) IndicatorRelease(g_rsiHandle);
  }

//+------------------------------------------------------------------+
int OnCalculate(
   const int rates_total,
   const int prev_calculated,
   const datetime &time[],
   const double   &open[],
   const double   &high[],
   const double   &low[],
   const double   &close[],
   const long     &tick_volume[],
   const long     &volume[],
   const int      &spread[])
  {
   if(rates_total < RSI_Length + 10) return 0;

   if(g_rsiHandle == INVALID_HANDLE)
     { g_rsiHandle = iRSI(_Symbol, PERIOD_CURRENT, RSI_Length, PRICE_CLOSE);
       if(g_rsiHandle == INVALID_HANDLE) return 0; }

   double rsiTemp[];
   ArraySetAsSeries(rsiTemp, true);
   if(CopyBuffer(g_rsiHandle, 0, 0, rates_total, rsiTemp) <= 0) return 0;

   double atrRaw[];
   ArraySetAsSeries(atrRaw, true);
   bool atrReady = (CopyBuffer(g_atrHandle, 0, 0, rates_total, atrRaw) == rates_total);

   if(prev_calculated == 0)
     {
      ArrayResize(g_lv, 0); g_nLv = 0;
      g_lastFlipBar        = -1;
      g_isRanging          = false; g_rangePH = 0.0; g_rangePL = 0.0;
      g_lastRSIRevDir      = 0;     g_lastRSIRevTime  = 0;
      g_lastRSINowDir      = 0;     g_lastRSINowTime  = 0;
      g_lastRBSSBRDir      = 0;
      g_lastRSRevDir       = 0;     g_lastRSRevTime   = 0;
      g_lastAlertTime      = 0;
      g_lastRSIRevFireTime = 0;
      g_msDir              = 0;
      g_pathA_dir          = 0; g_pathA_armTime = 0; g_pathA_armed = false;
      g_pathB_dir          = 0; g_pathB_armTime = 0; g_pathB_armed = false;
      g_confluenceTime     = 0; g_confluenceDir = 0;
      g_pathBLastFiredDir  = 0;
      InitPendingSignals();
     }

   if(atrReady)
      CalcRS(rates_total, prev_calculated, close, atrRaw, time);

   static double maxMin       = 0;
   static double acceleration = SAR_Start;
   static bool   isBelow      = false;

   if(prev_calculated == 0)
     { maxMin = 0; acceleration = SAR_Start; isBelow = false; }

   int start = (prev_calculated == 0) ? RSI_Length : MathMax(prev_calculated - 1, RSI_Length);

   //── ENGINE 1: RSI PSAR ─────────────────────────────────────────
   for(int i = start; i < rates_total; i++)
     {
      RSI_Buffer[i]  = rsiTemp[rates_total - 1 - i];
      double prev_rsi     = RSI_Buffer[i-1];
      double prev_rsi2    = (i >= 2) ? RSI_Buffer[i-2] : RSI_Buffer[i-1];
      double sar_result   = (i > 0) ? SAR_Internal[i-1] : RSI_Buffer[i];
      bool   prev_isBelow = isBelow;

      CalculateSAR(i, RSI_Buffer[i], prev_rsi, prev_rsi2,
                   sar_result, isBelow, maxMin, acceleration);

      SAR_Internal[i]   = sar_result;
      IsBelow_Buffer[i] = isBelow ? 1 : 0;

      if(DisplaySAR)
         SAR_Buffer[i] = (i > 0 && IsBelow_Buffer[i] != IsBelow_Buffer[i-1])
                         ? EMPTY_VALUE : sar_result;
      else
         SAR_Buffer[i] = EMPTY_VALUE;

      bool sig_up   = (isBelow != prev_isBelow) && isBelow;
      bool sig_dn   = (isBelow != prev_isBelow) && !isBelow;
      bool s_sig_up = sig_up && (sar_result <= Lower_Threshold);
      bool s_sig_dn = sig_dn && (sar_result >= Upper_Threshold);

      double rsTrend    = (atrReady && i < rates_total) ? g_rsTrendArr[i] : 0.0;
      bool   rsGateBull = (rsTrend > 0.0);
      bool   rsGateBear = (rsTrend < 0.0);

      bool gated_sig_up = sig_up && (sar_result >= Lower_Threshold) && (g_lastRBSSBRDir != -1);
      bool gated_sig_dn = sig_dn && (sar_result <= Upper_Threshold) && (g_lastRBSSBRDir !=  1);

      SigUp_Buffer[i]    = gated_sig_up ? sar_result : EMPTY_VALUE;
      SigDn_Buffer[i]    = gated_sig_dn ? sar_result : EMPTY_VALUE;
      StrongUp_Buffer[i] = s_sig_up     ? sar_result : EMPTY_VALUE;
      StrongDn_Buffer[i] = s_sig_dn     ? sar_result : EMPTY_VALUE;

      //── Range detection on confirmed closed bar ──────────────────
      if(i == rates_total - 2)
        {
         double   recentPH = 0.0, recentPL = DBL_MAX;
         datetime recentPHTime = 0, recentPLTime = 0;

         for(int k = 0; k < g_nLv; k++)
           {
            if(g_lv[k].broken) continue;
            if( g_lv[k].isHigh && g_lv[k].t1 > recentPHTime)
              { recentPH = g_lv[k].price; recentPHTime = g_lv[k].t1; }
            if(!g_lv[k].isHigh && g_lv[k].t1 > recentPLTime)
              { recentPL = g_lv[k].price; recentPLTime = g_lv[k].t1; }
           }

         bool hasBothPivots = (recentPHTime > 0 && recentPLTime > 0);
         bool wasRanging    = g_isRanging;

         if(hasBothPivots)
           {
            g_rangePH          = recentPH;
            g_rangePL          = recentPL;
            double c           = close[i];
            double rangeWidth  = (g_rangePH - g_rangePL) / _Point;
            bool   inBox       = (c < g_rangePH && c > g_rangePL);
            bool   tightEnough = (rangeWidth < InpRangeMinPoints);
            g_isRanging        = inBox && tightEnough;

            if(g_isRanging && !wasRanging)
               FireAlert("⏸ RANGING — SIGNALS PAUSED | " + _Symbol + " " +
                         EnumToString((ENUM_TIMEFRAMES)_Period) +
                         " | Box:" + DoubleToString(g_rangePL, _Digits) +
                         "-"       + DoubleToString(g_rangePH, _Digits) +
                         " | Width:$" + DoubleToString(g_rangePH - g_rangePL, 2) +
                         " | Min:$"   + DoubleToString(InpRangeMinPoints * _Point, 2), true);

            if(!g_isRanging && wasRanging)
               FireAlert("▶ RANGE BROKEN — SIGNALS LIVE | " + _Symbol + " " +
                         EnumToString((ENUM_TIMEFRAMES)_Period) +
                         " | Breakout:" + DoubleToString(c, _Digits), true);
           }
         else
            g_isRanging = false;

         // ── Check pending signals on every confirmed bar ──────────
         // Note: runs even when ranging (hold through range by design)
         if(prev_calculated > 0)
            CheckPendingSignals(close, high, low, i, time[i]);
        }

      //── RSI alerts on confirmed closed bar ───────────────────────
      if(i == rates_total - 2 && !g_isRanging && prev_calculated > 0)
        {
         double curAtr = atrReady ? atrRaw[rates_total - 1 - i] : 0;

         if(s_sig_up && !(g_lastRSIRevDir == 1 &&
            (time[i] - g_lastRSIRevFireTime) < (datetime)(InpSeqLookback * PeriodSeconds())))
           { g_lastRSIRevDir = 1; g_lastRSIRevTime = time[i]; g_lastRSIRevFireTime = time[i];
             FireAlert("RSI BUY REVERSAL ◈ " + (rsGateBull ? "✅ SAFE" : "⚠️ RISK") +
                       " | " + _Symbol + " " + EnumToString((ENUM_TIMEFRAMES)_Period));
             g_lastAlertTime = time[i];
             CheckSequence(SEQ_RSI_REV, 1, time[i], close[i], curAtr); }
         else if(s_sig_dn && !(g_lastRSIRevDir == -1 &&
            (time[i] - g_lastRSIRevFireTime) < (datetime)(InpSeqLookback * PeriodSeconds())))
           { g_lastRSIRevDir = -1; g_lastRSIRevTime = time[i]; g_lastRSIRevFireTime = time[i];
             FireAlert("RSI SELL REVERSAL ◈ " + (rsGateBear ? "✅ SAFE" : "⚠️ RISK") +
                       " | " + _Symbol + " " + EnumToString((ENUM_TIMEFRAMES)_Period));
             g_lastAlertTime = time[i];
             CheckSequence(SEQ_RSI_REV, -1, time[i], close[i], curAtr); }
         else if(gated_sig_up && g_lastRSINowDir != 1 && time[i] != g_lastAlertTime)
           { g_lastRSINowDir = 1; g_lastRSINowTime = time[i];
             FireAlert("RSI BUY NOW ◇ | " + _Symbol + " " +
                       EnumToString((ENUM_TIMEFRAMES)_Period));
             g_lastAlertTime = time[i];
             CheckSequence(SEQ_RSI_NOW, 1, time[i], close[i], curAtr); }
         else if(gated_sig_dn && g_lastRSINowDir != -1 && time[i] != g_lastAlertTime)
           { g_lastRSINowDir = -1; g_lastRSINowTime = time[i];
             FireAlert("RSI SELL NOW ◇ | " + _Symbol + " " +
                       EnumToString((ENUM_TIMEFRAMES)_Period));
             g_lastAlertTime = time[i];
             CheckSequence(SEQ_RSI_NOW, -1, time[i], close[i], curAtr); }
        }
     }

   //── ENGINE 2: PIVOT DETECTION ──────────────────────────────────
   int pivStart = (prev_calculated == 0)
                  ? InpSwingLeft
                  : MathMax(InpSwingLeft, prev_calculated - InpSwingRight - 1);

   for(int i = pivStart; i < rates_total; i++)
     {
      int pBar = i - InpSwingRight;
      if(pBar < InpSwingLeft) continue;

      if(IsPivotHigh(high, pBar, InpSwingLeft, InpSwingRight, rates_total))
        {
         bool exists = false;
         for(int k = 0; k < g_nLv; k++)
            if(g_lv[k].isHigh && g_lv[k].t1 == time[pBar]) { exists = true; break; }
         if(!exists)
            AddLevel(high[pBar], high[pBar], low[pBar], time[pBar], true);
        }

      if(IsPivotLow(low, pBar, InpSwingLeft, InpSwingRight, rates_total))
        {
         bool exists = false;
         for(int k = 0; k < g_nLv; k++)
            if(!g_lv[k].isHigh && g_lv[k].t1 == time[pBar]) { exists = true; break; }
         if(!exists)
            AddLevel(low[pBar], high[pBar], low[pBar], time[pBar], false);
        }

      for(int j = 0; j < g_nLv; j++)
        {
         if(g_lv[j].broken) continue;
         if(g_lv[j].isHigh ? (close[i] > g_lv[j].top) : (close[i] < g_lv[j].bot))
            g_lv[j].broken = true;
        }
     }

   UpdateMarketStructure();

   //── ENGINE 3: RBS/SBR ──────────────────────────────────────────
   int lastBar = rates_total - 1;
   if(prev_calculated > 0 && lastBar != g_lastFlipBar && !g_isRanging)
     {
      g_lastFlipBar = lastBar;
      int prevBar   = lastBar - 1;

      for(int j = 0; j < g_nLv; j++)
        {
         if(!g_lv[j].broken)     continue;
         if(g_lv[j].flipAlerted) continue;

         //── RBS BUY ──────────────────────────────────────────────
         if(g_lv[j].isHigh &&
            close[prevBar] <= g_lv[j].top &&
            close[lastBar]  > g_lv[j].top &&
            g_lastRBSSBRDir != 1)
           {
            if(InpHTFGateEnable && GlobalVariableCheck(InpSRZonesDirVar))
              {
               double srDir = GlobalVariableGet(InpSRZonesDirVar);
               if(srDir != 1.0)
                 { Print("[HTF GATE] RBS BUY suppressed — SR Zones dir=", srDir); continue; }
               if(GlobalVariableCheck(InpSRZonesTimeVar))
                 {
                  datetime srTime = (datetime)GlobalVariableGet(InpSRZonesTimeVar);
                  if((time[lastBar] - srTime) > (datetime)(InpHTFGateMaxBars * PeriodSeconds()))
                    { Print("[HTF GATE] RBS BUY suppressed — SR Zones signal too old"); continue; }
                 }
              }

            g_lv[j].flipAlerted = true;
            g_lastRBSSBRDir     = 1;
            double tp[];
            GetNextPivots(true, g_lv[j].top, tp, 3);
            string tpStr = "";
            for(int t = 0; t < 3; t++)
               tpStr += " TP" + IntegerToString(t+1) + ":" +
                        (tp[t] > 0 ? DoubleToString(tp[t], _Digits) : "N/A") +
                        (t < 2 ? " |" : "");
            FireAlert("RBS BUY NOW | " + _Symbol + " " +
                      EnumToString((ENUM_TIMEFRAMES)_Period) +
                      " | ENTRY:" + DoubleToString(g_lv[j].bot, _Digits) +
                      "-"         + DoubleToString(g_lv[j].top, _Digits) +
                      " | SL:"    + DoubleToString(g_lv[j].bot, _Digits) +
                      " |"        + tpStr);
            // SBR/RBS exempt from swing gate: pass atr=0
            CheckSequence(SEQ_RBSSBR, 1, time[lastBar], close[lastBar], 0);
           }

         //── SBR SELL ─────────────────────────────────────────────
         if(!g_lv[j].isHigh &&
            close[prevBar] >= g_lv[j].bot &&
            close[lastBar]  < g_lv[j].bot &&
            g_lastRBSSBRDir != -1)
           {
            if(InpHTFGateEnable && GlobalVariableCheck(InpSRZonesDirVar))
              {
               double srDir = GlobalVariableGet(InpSRZonesDirVar);
               if(srDir != -1.0)
                 { Print("[HTF GATE] SBR SELL suppressed — SR Zones dir=", srDir); continue; }
               if(GlobalVariableCheck(InpSRZonesTimeVar))
                 {
                  datetime srTime = (datetime)GlobalVariableGet(InpSRZonesTimeVar);
                  if((time[lastBar] - srTime) > (datetime)(InpHTFGateMaxBars * PeriodSeconds()))
                    { Print("[HTF GATE] SBR SELL suppressed — SR Zones signal too old"); continue; }
                 }
              }

            g_lv[j].flipAlerted = true;
            g_lastRBSSBRDir     = -1;
            double tp[];
            GetNextPivots(false, g_lv[j].bot, tp, 3);
            string tpStr = "";
            for(int t = 0; t < 3; t++)
               tpStr += " TP" + IntegerToString(t+1) + ":" +
                        (tp[t] > 0 ? DoubleToString(tp[t], _Digits) : "N/A") +
                        (t < 2 ? " |" : "");
            FireAlert("SBR SELL NOW | " + _Symbol + " " +
                      EnumToString((ENUM_TIMEFRAMES)_Period) +
                      " | ENTRY:" + DoubleToString(g_lv[j].top, _Digits) +
                      "-"         + DoubleToString(g_lv[j].bot, _Digits) +
                      " | SL:"    + DoubleToString(g_lv[j].top, _Digits) +
                      " |"        + tpStr);
            // SBR/RBS exempt from swing gate: pass atr=0
            CheckSequence(SEQ_RBSSBR, -1, time[lastBar], close[lastBar], 0);
           }
        }
     }

   return rates_total;
  }
