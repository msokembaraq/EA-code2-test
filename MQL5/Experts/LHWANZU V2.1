//+------------------------------------------------------------------+
//  SWING PROXIMITY HELPER
//  Returns nearest unbroken blocking swing price within InpSwingProxATR*atr
//  BUY blocked by swing HIGH above price
//  SELL blocked by swing LOW below price
//+------------------------------------------------------------------+
double FindBlockingSwing(int dir, double refPrice, double atr)
  {
   if(!InpSwingProxEnable || atr <= 0) return 0;
   double threshold = InpSwingProxATR * atr;
   double nearest   = 0;
   double nearDist  = DBL_MAX;

   for(int k = 0; k < g_nLv; k++)
     {
      if(g_lv[k].broken) continue;
      if(dir ==  1 && !g_lv[k].isHigh) continue;  // BUY: only swing HIGHs block
      if(dir == -1 &&  g_lv[k].isHigh) continue;  // SELL: only swing LOWs block

      double dist = (dir == 1) ? (g_lv[k].price - refPrice)
                                : (refPrice - g_lv[k].price);
      if(dist <= 0) continue;  // swing already behind price
      if(dist <= threshold && dist < nearDist)
        { nearDist = dist; nearest = g_lv[k].price; }
     }
   return nearest;
  }

//+------------------------------------------------------------------+
//  PENDING SIGNAL CHECK — called on every confirmed closed bar
//  Checks break, expiry, and opposite-signal cancellation
//+------------------------------------------------------------------+
void CheckPendingSignals(const double &close[], const double &high[],
                         const double &low[], int confirmBar,
                         datetime barTime)
  {
   // ── Cancel pending if opposite confluence fired this bar ────────
   // (handled inline in FireConfluenceA/B before this is called)

   // ── PATH A ──────────────────────────────────────────────────────
   if(g_pendingA.active)
     {
      g_pendingA.barCount++;

      // Expiry check
      if(g_pendingA.barCount > InpSwingProxExpiry)
        {
         Print("[SWING EXPIRED] PATH A ", (g_pendingA.dir==1?"BUY":"SELL"),
               " discarded after ", InpSwingProxExpiry, " bars | ", _Symbol);
         ClearPending(g_pendingA);
        }
      else
        {
         // Break check — candle CLOSE only, not wick
         bool broken = (g_pendingA.dir == 1)
                       ? (close[confirmBar] > g_pendingA.blockLevel)
                       : (close[confirmBar] < g_pendingA.blockLevel);
         if(broken)
           {
            FireAlert(g_pendingA.msg + " [SWING BREAK +" +
                      DoubleToString(g_pendingA.barCount,0) + "bars]", true);
            g_confluenceTime = barTime;
            g_confluenceDir  = g_pendingA.dir;
            ClearPending(g_pendingA);
           }
        }
     }

   // ── PATH B ──────────────────────────────────────────────────────
   if(g_pendingB.active)
     {
      g_pendingB.barCount++;

      if(g_pendingB.barCount > InpSwingProxExpiry)
        {
         Print("[SWING EXPIRED] PATH B ", (g_pendingB.dir==1?"BUY":"SELL"),
               " discarded after ", InpSwingProxExpiry, " bars | ", _Symbol);
         ClearPending(g_pendingB);
        }
      else
        {
         bool broken = (g_pendingB.dir == 1)
                       ? (close[confirmBar] > g_pendingB.blockLevel)
                       : (close[confirmBar] < g_pendingB.blockLevel);
         if(broken)
           {
            FireAlert(g_pendingB.msg + " [SWING BREAK +" +
                      DoubleToString(g_pendingB.barCount,0) + "bars]", true);
            g_confluenceTime = barTime;
            g_confluenceDir  = g_pendingB.dir;
            ClearPending(g_pendingB);
           }
        }
     }
  }

//+------------------------------------------------------------------+
//  ALERT
//+------------------------------------------------------------------+
void FireAlert(string msg, bool alwaysFire = false)
  {
   if(!InpPushAll && !alwaysFire) return;
   Print("SIGNAL: ", msg);
   if(InpAlerts) Alert(msg);
   if(InpPush && !SendNotification(msg)) Print("Push failed: ", msg);
  }

//+------------------------------------------------------------------+
//  CONFLUENCE FIRE — PATH A + PATH B with swing proximity gate
//  SBR/RBS calls pass atr=0 to bypass swing gate (exempt by design)
//+------------------------------------------------------------------+
void FireConfluenceA(int dir, datetime sigTime, double refPrice, double atr)
  {
   if(g_confluenceTime == sigTime && g_confluenceDir == dir) return;
   string circle = (dir == 1) ? "🟢" : "🔴";
   string side   = (dir == 1) ? "BUY" : "SELL";
   string msg    = "🔥🔥" + circle + " CONFLUENCE " + side +
                   " [PATH A] ✅ STRUCTURE | " + _Symbol + " " +
                   EnumToString((ENUM_TIMEFRAMES)_Period);

   // Opposite signal cancels pending PATH A
   if(g_pendingA.active && g_pendingA.dir != dir)
     {
      Print("[SWING CANCEL] PATH A ", (g_pendingA.dir==1?"BUY":"SELL"),
            " cancelled by opposite ", side, " | ", _Symbol);
      ClearPending(g_pendingA);
     }

   double blockLevel = FindBlockingSwing(dir, refPrice, atr);
   if(blockLevel > 0)
     {
      if(!g_pendingA.active || g_pendingA.dir != dir)
        {
         g_pendingA.active     = true;
         g_pendingA.dir        = dir;
         g_pendingA.msg        = msg;
         g_pendingA.armTime    = sigTime;
         g_pendingA.blockLevel = blockLevel;
         g_pendingA.barCount   = 0;
         Print("[SWING HOLD] PATH A ", side, " pending — swing at ",
               DoubleToString(blockLevel, _Digits),
               " | price:", DoubleToString(refPrice, _Digits), " | ", _Symbol);
        }
      return;
     }

   FireAlert(msg, true);
   g_confluenceTime    = sigTime;
   g_confluenceDir     = dir;
   g_pathBLastFiredDir = dir;
  }

void FireConfluenceB(int dir, datetime sigTime, double refPrice, double atr)
  {
   if(g_confluenceTime == sigTime && g_confluenceDir == dir) return;
   bool withStructure = (g_msDir != 0 && g_msDir == dir);
   string fire   = withStructure ? "🔥🔥" : "🔥";
   string circle = (dir == 1) ? "🟢" : "🔴";
   string side   = (dir == 1) ? "BUY" : "SELL";
   string msTag  = withStructure ? " ✅ MOMENTUM" : " ⚠️ COUNTER";
   string msg    = fire + circle + " CONFLUENCE " + side +
                   " [PATH B]" + msTag + " | " + _Symbol + " " +
                   EnumToString((ENUM_TIMEFRAMES)_Period);

   // Opposite signal cancels pending PATH B
   if(g_pendingB.active && g_pendingB.dir != dir)
     {
      Print("[SWING CANCEL] PATH B ", (g_pendingB.dir==1?"BUY":"SELL"),
            " cancelled by opposite ", side, " | ", _Symbol);
      ClearPending(g_pendingB);
     }

   double blockLevel = FindBlockingSwing(dir, refPrice, atr);
   if(blockLevel > 0)
     {
      if(!g_pendingB.active || g_pendingB.dir != dir)
        {
         g_pendingB.active     = true;
         g_pendingB.dir        = dir;
         g_pendingB.msg        = msg;
         g_pendingB.armTime    = sigTime;
         g_pendingB.blockLevel = blockLevel;
         g_pendingB.barCount   = 0;
         Print("[SWING HOLD] PATH B ", side, " pending — swing at ",
               DoubleToString(blockLevel, _Digits),
               " | price:", DoubleToString(refPrice, _Digits), " | ", _Symbol);
        }
      return;
     }

   FireAlert(msg, true);
   g_confluenceTime = sigTime;
   g_confluenceDir  = dir;
  }

//+------------------------------------------------------------------+
//  SEQUENCE ENGINE
//+------------------------------------------------------------------+
void CheckSequence(int sigType, int dir, datetime sigTime,
                   double refPrice, double atr)
  {
   if(!InpSeqEnable) return;

   long lookbackSecs = (long)InpSeqLookback * (long)PeriodSeconds();

   if(sigType == SEQ_RBSSBR)
     {
      if(g_pathA_armed && g_pathA_dir != dir)
        {
         FireAlert("🚫 SEQ CANCELLED | " + _Symbol + " " +
                   EnumToString((ENUM_TIMEFRAMES)_Period) +
                   " | Was:" + (g_pathA_dir == 1 ? "BUY" : "SELL") +
                   " → Now:" + (dir == 1 ? "BUY" : "SELL"));
        }
      g_pathA_dir     = dir;
      g_pathA_armTime = sigTime;
      g_pathA_armed   = true;
      if(g_pathB_armed && g_pathB_dir != dir)
        { g_pathB_armed = false; g_pathB_dir = 0; g_pathB_armTime = 0; }

      if(g_lastRSRevDir == dir && g_lastRSRevTime > 0)
        {
         long diff = (long)(sigTime - g_lastRSRevTime);
         if(diff >= 0 && diff <= lookbackSecs)
           // SBR/RBS exempt: atr=0 bypasses swing gate
           { FireConfluenceA(dir, sigTime, refPrice, 0); g_pathA_armed = false; return; }
        }
      if(g_lastRSIRevDir == dir && g_lastRSIRevTime > 0)
        {
         long diff = (long)(sigTime - g_lastRSIRevTime);
         if(diff >= 0 && diff <= lookbackSecs)
           { FireConfluenceA(dir, sigTime, refPrice, 0); g_pathA_armed = false; return; }
        }
      if(g_lastRSINowDir == dir && g_lastRSINowTime > 0)
        {
         long diff = (long)(sigTime - g_lastRSINowTime);
         if(diff >= 0 && diff <= lookbackSecs)
           { FireConfluenceA(dir, sigTime, refPrice, 0); g_pathA_armed = false; return; }
        }
      return;
     }

   if(sigType == SEQ_RS)
     {
      if(g_pathA_armed && g_pathA_dir != dir)
        { g_pathA_armed = false; g_pathA_dir = 0; g_pathA_armTime = 0; }
      if(g_pathA_armed && g_pathA_dir == dir && sigTime >= g_pathA_armTime)
        { FireConfluenceA(dir, sigTime, refPrice, atr); g_pathA_armed = false; return; }
      if(g_pathB_armed && g_pathB_dir == dir && sigTime >= g_pathB_armTime)
        { FireConfluenceB(dir, sigTime, refPrice, atr); g_pathB_armed = false; return; }
      return;
     }

   if(sigType == SEQ_RSI_REV || sigType == SEQ_RSI_NOW)
     {
      if(g_pathA_armed && g_pathA_dir != dir)
        { g_pathA_armed = false; g_pathA_dir = 0; g_pathA_armTime = 0; }
      if(g_pathB_armed && g_pathB_dir != dir)
        { g_pathB_armed = false; g_pathBLastFiredDir = 0; }

      if(g_pathBLastFiredDir == dir) return;

      if(g_pathA_armed && g_pathA_dir == dir && sigTime >= g_pathA_armTime)
        { FireConfluenceA(dir, sigTime, refPrice, atr); g_pathA_armed = false; }

      g_pathB_dir     = dir;
      g_pathB_armTime = sigTime;
      g_pathB_armed   = true;

      if(g_lastRSRevDir == dir && g_lastRSRevTime > 0)
        {
         long diff = (long)(sigTime - g_lastRSRevTime);
         if(diff >= 0 && diff <= lookbackSecs)
           { FireConfluenceB(dir, sigTime, refPrice, atr); g_pathB_armed = false; }
        }
      return;
     }
  }

//+------------------------------------------------------------------+
//  SAR CALCULATION
//+------------------------------------------------------------------+
void CalculateSAR(
   int i,
   double src,
   double prev_src,
   double prev_src2,
   double &result,
   bool &isBelow,
   double &maxMin,
   double &acceleration)
  {
   double src_high      = src + 1.0;
   double src_low       = src - 1.0;
   bool   isFirstTrendBar = false;

   if(i <= RSI_Length + 2)
     {
      if(src > prev_src)
        { isBelow = true;  maxMin = src_high; result = prev_src - 1.0; }
      else
        { isBelow = false; maxMin = src_low;  result = prev_src + 1.0; }
      isFirstTrendBar = true;
      acceleration    = SAR_Start;
     }

   result = result + acceleration * (maxMin - result);

   if(isBelow)
     {
      if(result > src_low)
        { isFirstTrendBar = true; isBelow = false;
          result = MathMax(src_high, maxMin); maxMin = src_low; acceleration = SAR_Start; }
     }
   else
     {
      if(result < src_high)
        { isFirstTrendBar = true; isBelow = true;
          result = MathMin(src_low, maxMin); maxMin = src_high; acceleration = SAR_Start; }
     }

   if(!isFirstTrendBar)
     {
      if(isBelow)
        { if(src_high > maxMin) { maxMin = src_high; acceleration = MathMin(acceleration + SAR_Inc, SAR_Max); } }
      else
        { if(src_low  < maxMin) { maxMin = src_low;  acceleration = MathMin(acceleration + SAR_Inc, SAR_Max); } }
     }

   if(isBelow)
     {
      result = MathMin(result, prev_src  - 1.0);
      if(i > 1) result = MathMin(result, prev_src2 - 1.0);
     }
   else
     {
      result = MathMax(result, prev_src  + 1.0);
      if(i > 1) result = MathMax(result, prev_src2 + 1.0);
     }
  }

//+------------------------------------------------------------------+
//  ROLLING SEGMENT
//+------------------------------------------------------------------+
void CalcRS(const int rates_total, const int prev_calculated,
            const double &close[], const double &atrRaw[],
            const datetime &time[])
  {
   ArrayResize(g_rsTrendArr, rates_total);
   ArrayResize(g_rollSegArr, rates_total);
   ArrayInitialize(g_rsTrendArr, 0.0);
   ArrayInitialize(g_rollSegArr, 0.0);

   if(rates_total < InpATRLen + 2) return;

   double rollSeg    = close[InpATRLen];
   double rsTrend    = 1.0;
   double actSlope   = 0.0;
   bool   isFastMode = false;

   g_rsTrendArr[InpATRLen] = rsTrend;
   g_rollSegArr[InpATRLen] = rollSeg;

   for(int i = InpATRLen + 1; i < rates_total; i++)
     {
      double atr = atrRaw[rates_total - 1 - i];
      if(atr <= 0.0 || atr >= EMPTY_VALUE || !MathIsValidNumber(atr))
        {
         g_rsTrendArr[i] = rsTrend;
         g_rollSegArr[i] = close[i];
         continue;
        }

      double dist    = close[i] - rollSeg;
      bool   bullRev = (rsTrend < 0) && ( dist >  InpRSRevThresh * atr);
      bool   bearRev = (rsTrend > 0) && (-dist >  InpRSRevThresh * atr);

      if(bullRev)      rsTrend =  1.0;
      else if(bearRev) rsTrend = -1.0;

      bool newFast = (MathAbs(dist) > InpRSFastThresh * atr);
      if(bullRev || bearRev || (newFast != isFastMode) || actSlope == 0.0)
        { isFastMode = newFast;
          actSlope   = isFastMode ? atr / InpRSFastLen : atr / InpRSSlowLen; }

      rollSeg += rsTrend * actSlope;

      g_rsTrendArr[i] = rsTrend;
      g_rollSegArr[i] = rollSeg;

      if(i == rates_total - 2 && !g_isRanging && prev_calculated > 0)
        {
         double curAtr = atrRaw[rates_total - 1 - i];
         if(bullRev && g_lastRSRevDir != 1)
           {
            g_lastRSRevDir  = 1;
            g_lastRSRevTime = time[i];
            FireAlert("📈 RS BUY EMA CROSS| " + _Symbol + " " +
                      EnumToString((ENUM_TIMEFRAMES)_Period) +
                      " | Price:" + DoubleToString(close[i], _Digits));
            CheckSequence(SEQ_RS, 1, time[i], close[i], curAtr);
           }
         else if(bearRev && g_lastRSRevDir != -1)
           {
            g_lastRSRevDir  = -1;
            g_lastRSRevTime = time[i];
            FireAlert("📉 RS SELL EMA CROSS | " + _Symbol + " " +
                      EnumToString((ENUM_TIMEFRAMES)_Period) +
                      " | Price:" + DoubleToString(close[i], _Digits));
            CheckSequence(SEQ_RS, -1, time[i], close[i], curAtr);
           }
        }
     }
  }

//+------------------------------------------------------------------+
//  PIVOT HELPERS
//+------------------------------------------------------------------+
bool IsPivotHigh(const double &h[], int pos, int L, int R, int total)
  {
   if(pos - L < 0 || pos + R >= total) return false;
   double v = h[pos];
   for(int k = 1; k <= L; k++) if(h[pos-k] >= v) return false;
   for(int k = 1; k <= R; k++) if(h[pos+k] >= v) return false;
   return true;
  }

bool IsPivotLow(const double &l[], int pos, int L, int R, int total)
  {
   if(pos - L < 0 || pos + R >= total) return false;
   double v = l[pos];
   for(int k = 1; k <= L; k++) if(l[pos-k] <= v) return false;
   for(int k = 1; k <= R; k++) if(l[pos+k] <= v) return false;
   return true;
  }

void AddLevel(double price, double top, double bot, datetime t1, bool isHigh)
  {
   if(g_nLv >= 2000)
     { for(int i = 0; i < g_nLv - 1; i++) g_lv[i] = g_lv[i+1]; g_nLv--; }
   ArrayResize(g_lv, g_nLv + 1);
   g_lv[g_nLv].price       = price;
   g_lv[g_nLv].top         = top;
   g_lv[g_nLv].bot         = bot;
   g_lv[g_nLv].t1          = t1;
   g_lv[g_nLv].isHigh      = isHigh;
   g_lv[g_nLv].broken      = false;
   g_lv[g_nLv].flipAlerted = false;
   g_nLv++;
  }

