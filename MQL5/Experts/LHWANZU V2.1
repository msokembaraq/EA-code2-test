//════════════════════════════════════════════════════════════════════
struct PendingSignal
  {
   bool     active;
   int      dir;          // 1=buy  -1=sell
   string   msg;          // stored alert text — fires as-is + [SWING BREAK] appended
   datetime armTime;      // bar time when signal was held
   double   blockLevel;   // unbroken swing price blocking signal
   int      barCount;     // confirmed bars elapsed since armed
  };

PendingSignal g_pendingA;   // PATH A — independent
PendingSignal g_pendingB;   // PATH B — independent

void ClearPending(PendingSignal &p)
  { p.active=false; p.dir=0; p.msg=""; p.armTime=0; p.blockLevel=0; p.barCount=0; }

void InitPendingSignals()
  { ClearPending(g_pendingA); ClearPending(g_pendingB); }

