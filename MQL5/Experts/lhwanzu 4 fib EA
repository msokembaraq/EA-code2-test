bool ADR_Consolidation()
{
   // ── STEP 1: ADR CONTRACTION ───────────────────────────────────
   int dTotal=iBars(_Symbol,PERIOD_D1);
   if(dTotal < ADR_Periods+2) return g_inConsolidation;
   double totalRange=0;
   for(int i=1;i<=ADR_Periods;i++)
      totalRange+=iHigh(_Symbol,PERIOD_D1,i)-iLow(_Symbol,PERIOD_D1,i);
   g_adrValue=totalRange/ADR_Periods;
   double todayRange=iHigh(_Symbol,PERIOD_D1,0)-iLow(_Symbol,PERIOD_D1,0);
   int barsToday=(int)((TimeCurrent()-(datetime)iTime(_Symbol,PERIOD_D1,0))/300);
   bool adrContracted=(g_adrValue>0 && todayRange<g_adrValue*ADR_ConsolPct && barsToday>=48);

   // ── STEP 2: EQUAL HIGHS / EQUAL LOWS (ICT BSL/SSL) ───────────
   double tol=EHL_TolerancePts*GetPointsize()*g_priceScalar;
   double refHigh=iHigh(_Symbol,PERIOD_CURRENT,1);
   double refLow =iLow (_Symbol,PERIOD_CURRENT,1);
   for(int i=2;i<=EHL_LookbackBars;i++)
   { double h=iHigh(_Symbol,PERIOD_CURRENT,i),l=iLow(_Symbol,PERIOD_CURRENT,i);
     if(h>refHigh) refHigh=h;
     if(l<refLow)  refLow =l; }
   int highCount=0,lowCount=0;
   for(int i=1;i<=EHL_LookbackBars;i++)
   { if(MathAbs(iHigh(_Symbol,PERIOD_CURRENT,i)-refHigh)<=tol) highCount++;
     if(MathAbs(iLow (_Symbol,PERIOD_CURRENT,i)-refLow) <=tol) lowCount++; }
   bool equalHighs=(highCount>=2);
   bool equalLows =(lowCount >=2);
   if(equalHighs) g_consolHigh=refHigh;
   if(equalLows)  g_consolLow =refLow;
   if(!equalHighs) g_consolHigh=0;
   if(!equalLows)  g_consolLow =0;

   bool detected=adrContracted&&(equalHighs||equalLows);
   if(detected!=g_inConsolidation)
   { g_inConsolidation=detected;
     if(detected)
        Log(StringFormat("📦 CONSOLIDATION | ADR=%.0fpts today=%.0fpts(%.0f%%) | BSL=%s SSL=%s",
            g_adrValue/GetPointsize(),todayRange/GetPointsize(),
            todayRange/g_adrValue*100,
            equalHighs?DoubleToString(g_consolHigh,_Digits):"none",
            equalLows?DoubleToString(g_consolLow,_Digits):"none"));
     else
        Log(StringFormat("📦 CONSOLIDATION CLEARED | ADR=%.0fpts today=%.0fpts | price expanding",
            g_adrValue/GetPointsize(),todayRange/GetPointsize())); }
   return detected;
}

