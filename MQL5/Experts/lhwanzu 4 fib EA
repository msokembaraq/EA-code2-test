void Fib_CalcLevels()
{
   if(!g_fib.valid||g_fib.fibRange<=0) return;
   double L=g_fib.fibLow, r=g_fib.fibRange;
   g_fibLevel0  =L+0.000*r; g_fibLevel025=L+0.250*r; g_fibLevel382=L+0.382*r;
   g_fibLevel05 =L+0.500*r; g_fibLevel618=L+0.618*r;
   g_fibLevel075=L+0.750*r; g_fibLevel1  =L+1.000*r;
   g_fibRevH    =L+1.500*r; g_fibLev1644 =L+1.644*r; g_fibSD1H    =L+2.000*r;
   g_fibLev225H =L+2.250*r; g_fibSD2H    =L+2.500*r; g_fibLevel30 =L+3.000*r;
   g_fibLev325  =L+3.250*r; g_fibLev35   =L+3.500*r;
   g_fibRevL    =L-0.500*r; g_fibLevN0644=L-0.644*r; g_fibSD1L    =L-1.000*r;
   g_fibLevN125 =L-1.250*r; g_fibSD2L    =L-1.500*r; g_fibLevN20  =L-2.000*r;
   g_fibLevN225 =L-2.250*r; g_fibLevN25  =L-2.500*r;
}

void Fib_SetAnchor(double low, double high, bool resetFlips=true)
{
   if(high<=low) return;
   g_fib.fibLow=low; g_fib.fibHigh=high; g_fib.fibRange=high-low;
   g_fib.anchorBar=g_barCount; g_fib.valid=true;
   if(resetFlips){g_fib.highFlipped=false;g_fib.lowFlipped=false;}
   // Reset zone touch counters — new anchor = fresh zones
   g_fibBuyZoneTouches=0; g_fibSellZoneTouches=0;
   ArrayInitialize(g_sdBuyZoneTouches,0);
   ArrayInitialize(g_sdSellZoneTouches,0);
   g_inConsolidation=false; g_consolHigh=0; g_consolLow=0; g_adrValue=0;
   Fib_CalcLevels();
}

// Record a level that just broke and flipped roles
// dir = +1 → was BUY floor, now SELL resistance
// dir = -1 → was SELL ceiling, now BUY support
void Fib_AddFlippedLevel(double price, int dir)
{
   if(price <= 0) return;
   double tol = Fib_PDBuffer * GetPointsize() * 3.0;
   for(int i=0; i<g_fibFlippedCount; i++)
      if(MathAbs(g_fibFlippedLevels[i]-price)<=tol && g_fibFlippedDir[i]==dir) return;
   if(g_fibFlippedCount >= 32)
   { // Ring buffer: evict oldest entry to make room
     for(int i=0; i<31; i++) { g_fibFlippedLevels[i]=g_fibFlippedLevels[i+1]; g_fibFlippedDir[i]=g_fibFlippedDir[i+1]; }
     g_fibFlippedCount = 31;
     Log("⚠️ FLIP BUFFER FULL — oldest level evicted"); }
   g_fibFlippedLevels[g_fibFlippedCount] = price;
   g_fibFlippedDir[g_fibFlippedCount]    = dir;
   g_fibFlippedCount++;
   Log(StringFormat("📌 ROLE FLIP RECORDED | %.5f | %s",
       price, dir==1?"BUY→SELL resistance":"SELL→BUY support"));
}

void Fib_ReAnchorOnBreak(int direction)
{
   // ── ONE-SIDE REANCHOR ──────────────────────────────────────────
   // Break UP:   floor (0 BUY) stays locked. Only ceiling (1 SELL) moves up.
   // Break DOWN: ceiling (1 SELL) stays locked. Only floor (0 BUY) moves down.
   // Fib stays VALID throughout — old levels still apply during transition.

   if(direction == 1)
   {
      // Break UP — lock the floor, wait for new ceiling at RevH
      Fib_AddFlippedLevel(g_fibLevel1, -1); // old 1 SELL → now BUY support on retest
      g_fibLockedFloor       = g_fibLevel0;  // 0 BUY stays here permanently
      g_fibWaitingNewCeiling = true;
      g_fibWaitingNewFloor   = false;
      g_fib.state            = FIB_TREND_UP;
      g_fib.highFlipped      = true;
      ZeroMemory(g_fibWatch);
      Log(StringFormat("🔺 FIB BREAK UP|%s|0 FLOOR LOCKED=%.5f|waiting swing high near RevH=%.5f",
          _Symbol, g_fibLockedFloor, g_fibRevH));
      Notify(StringFormat("🔺 FIB BREAK UP|%s|0 LOCKED=%.5f|target RevH=%.5f|→new 1 SELL there",
             _Symbol, g_fibLockedFloor, g_fibRevH));
   }
   else
   {
      // Break DOWN — lock the ceiling, wait for new floor at RevL
      Fib_AddFlippedLevel(g_fibLevel0, +1); // old 0 BUY → now SELL resistance on retest
      g_fibLockedCeiling     = g_fibLevel1;  // 1 SELL stays here permanently
      g_fibWaitingNewFloor   = true;
      g_fibWaitingNewCeiling = false;
      g_fib.state            = FIB_TREND_DOWN;
      g_fib.lowFlipped       = true;
      ZeroMemory(g_fibWatch);
      Log(StringFormat("🔻 FIB BREAK DOWN|%s|1 CEILING LOCKED=%.5f|waiting swing low near RevL=%.5f",
          _Symbol, g_fibLockedCeiling, g_fibRevL));
      Notify(StringFormat("🔻 FIB BREAK DOWN|%s|1 LOCKED=%.5f|target RevL=%.5f|→new 0 BUY there",
             _Symbol, g_fibLockedCeiling, g_fibRevL));
   }
}

void Fib_BackfillAnchor()
{
   int total=iBars(_Symbol,Fib_HTF);
   int scanWindow=50;
   int sr=MathMin(scanWindow+Fib_PivotLookback, total-Fib_PivotLookback-2);
   Print("💾 Fib Backfill: scanning recent ",sr," ",EnumToString(Fib_HTF)," bars...");
   double bH=0; int bHb=-1; double bL=DBL_MAX; int bLb=-1;
   for(int bar=Fib_PivotLookback; bar<=sr; bar++)
   {
      double h=iHigh(_Symbol,Fib_HTF,bar); bool ph=true;
      for(int k=1;k<=Fib_PivotLookback&&ph;k++)
      { if(bar-k<0||bar+k>=total){ph=false;break;}
        if(iHigh(_Symbol,Fib_HTF,bar-k)>=h||iHigh(_Symbol,Fib_HTF,bar+k)>=h) ph=false;}
      if(ph&&bHb<0){bH=h;bHb=bar;}
      double l=iLow(_Symbol,Fib_HTF,bar); bool pl=true;
      for(int k=1;k<=Fib_PivotLookback&&pl;k++)
      { if(bar-k<0||bar+k>=total){pl=false;break;}
        if(iLow(_Symbol,Fib_HTF,bar-k)<=l||iLow(_Symbol,Fib_HTF,bar+k)<=l) pl=false;}
      if(pl&&bLb<0){bL=l;bLb=bar;}
      if(bHb>=0&&bLb>=0) break;
   }
   if(bHb<0||bLb<0||bH<=bL)
   { Print(StringFormat("⚠️ Fib Backfill: no valid H/L in last %d bars",scanWindow));
     Notify(StringFormat("⚠️ FIB NO ANCHOR|%s|Waiting live pivot",_Symbol)); return;}
   if(MathAbs(bHb-bLb)>Fib_MaxHLGapBars)
   { Print(StringFormat("⚠️ Fib Backfill: H(bar%d) L(bar%d) gap=%d > max=%d — adjusting",
           bHb,bLb,MathAbs(bHb-bLb),Fib_MaxHLGapBars));
     if(bHb>bLb)
     { bH=0;bHb=-1;
       for(int bar=Fib_PivotLookback;bar<=bLb+Fib_MaxHLGapBars&&bar<=sr;bar++)
       { double h=iHigh(_Symbol,Fib_HTF,bar);bool ph=true;
         for(int k=1;k<=Fib_PivotLookback&&ph;k++)
         { if(bar-k<0||bar+k>=total){ph=false;break;}
           if(iHigh(_Symbol,Fib_HTF,bar-k)>=h||iHigh(_Symbol,Fib_HTF,bar+k)>=h)ph=false;}
         if(ph&&bar!=bLb){bH=h;bHb=bar;break;}}}
     else
     { bL=DBL_MAX;bLb=-1;
       for(int bar=Fib_PivotLookback;bar<=bHb+Fib_MaxHLGapBars&&bar<=sr;bar++)
       { double l=iLow(_Symbol,Fib_HTF,bar);bool pl=true;
         for(int k=1;k<=Fib_PivotLookback&&pl;k++)
         { if(bar-k<0||bar+k>=total){pl=false;break;}
           if(iLow(_Symbol,Fib_HTF,bar-k)<=l||iLow(_Symbol,Fib_HTF,bar+k)<=l)pl=false;}
         if(pl&&bar!=bHb){bL=l;bLb=bar;break;}}}
     if(bHb<0||bLb<0||bH<=bL)
     { // Adjustment failed — fall back to raw range high/low of scan window
       double fbH=0; double fbL=DBL_MAX;
       for(int bar=0;bar<=sr;bar++)
       { double h=iHigh(_Symbol,Fib_HTF,bar); if(h>fbH) fbH=h;
         double l=iLow (_Symbol,Fib_HTF,bar); if(l<fbL) fbL=l; }
       if(fbH>fbL && fbH>0 && fbL<DBL_MAX)
       { bH=fbH; bL=fbL;
         Print(StringFormat("💾 Fib Backfill: gap adjustment fallback — using raw range H=%.5f L=%.5f",bH,bL)); }
       else
       { Print("⚠️ Fib Backfill: H/L gap too wide — no anchor set");
         Notify(StringFormat("⚠️ FIB NO ANCHOR|%s|H/L gap too wide",_Symbol)); return; }}}   double pip=ScaledPip(), cl=iClose(_Symbol,PERIOD_CURRENT,1);
   Fib_SetAnchor(bL,bH,true);
   if(cl>g_fibLevel1+Fib_BreakBuffer*pip)
   { g_fib.state=FIB_TREND_UP;
     g_fibLockedFloor      = g_fibLevel0;  // lock floor
     g_fibWaitingNewCeiling= true;          // arm cascade watch upward
     Log(StringFormat("💾 Fib Backfill: price above 1 — CEILING SHIFT armed | locked floor=%.5f | RevH=%.5f",
         g_fibLockedFloor, g_fibRevH)); }
   else if(cl<g_fibLevel0-Fib_BreakBuffer*pip)
   { g_fib.state=FIB_TREND_DOWN;
     g_fibLockedCeiling    = g_fibLevel1;  // lock ceiling
     g_fibWaitingNewFloor  = true;          // arm cascade watch downward
     Log(StringFormat("💾 Fib Backfill: price below 0 — FLOOR SHIFT armed | locked ceiling=%.5f | RevL=%.5f",
         g_fibLockedCeiling, g_fibRevL)); }
   else
     g_fib.state=FIB_RANGE;
   Print(StringFormat("💾 Fib Backfill DONE | L=%.5f(bar%d) H=%.5f(bar%d) | Range=%.1fpts | %s",
         bL,bLb,bH,bHb,g_fib.fibRange/pip,EnumToString(g_fib.state)));
   Notify(StringFormat("📐 FIB ANCHORED|%s|0=%.5f|1=%.5f|Range=%.0fpts|0.25=%.5f|0.75=%.5f|%s",
          _Symbol,g_fibLevel0,g_fibLevel1,g_fib.fibRange/pip,
          g_fibLevel025,g_fibLevel075,EnumToString(g_fib.state)));
}

bool Fib_DetectHTFPivot()
{
   // Only active when waiting for new ceiling or new floor
   if(!g_fibWaitingNewCeiling && !g_fibWaitingNewFloor) return false;
   int total=iBars(_Symbol,Fib_HTF);
   if(total<Fib_PivotLookback*2+2) return false;
   int prd=Fib_PivotLookback;
   double pip=ScaledPip();
   double tol=Fib_PDBuffer*pip*4.0; // proximity to SD target level

   if(g_fibWaitingNewCeiling)
   {
      // Break UP — looking for swing HIGH near RevH (SD 1.5 extension)
      // That becomes the new 1 SELL. 0 BUY (g_fibLockedFloor) stays unchanged.
      double phH=iHigh(_Symbol,Fib_HTF,prd); bool isPH=true;
      for(int k=1;k<=prd&&isPH;k++)
         if(iHigh(_Symbol,Fib_HTF,prd-k)>=phH||iHigh(_Symbol,Fib_HTF,prd+k)>=phH) isPH=false;
      if(isPH && phH > g_fibLevel1) // must be above old 1 SELL
      {
         // Check proximity to RevH or extended SD levels
         bool nearTarget = (MathAbs(phH-g_fibRevH)<=tol || phH>=g_fibRevH-tol);
         if(!nearTarget)
         { Log(StringFormat("⏳ FIB CEILING: pivot @ %.5f | not near RevH %.5f | holding",phH,g_fibRevH));
           return false; }
         // Set new anchor: floor=locked, ceiling=new swing high
         double newFloor   = g_fibLockedFloor;
         double newCeiling = phH;
         Fib_SetAnchor(newFloor, newCeiling, false);
         g_fibWaitingNewCeiling = false;
         g_fib.state = FIB_RANGE;
         Log(StringFormat("✅ FIB NEW CEILING | 0=%.5f (LOCKED) | 1=%.5f (NEW) | 0.25=%.5f | 0.75=%.5f",
             g_fibLevel0, g_fibLevel1, g_fibLevel025, g_fibLevel075));
         Notify(StringFormat("✅ FIB CEILING SHIFT|%s|0 FLOOR=%.5f|1 NEW=%.5f|0.25=%.5f|0.75=%.5f|RevH→%.5f",
                _Symbol,g_fibLevel0,g_fibLevel1,g_fibLevel025,g_fibLevel075,g_fibRevH));
         return true;
      }
   }
   else if(g_fibWaitingNewFloor)
   {
      // Break DOWN — looking for swing LOW near RevL (SD -0.5 extension)
      // That becomes the new 0 BUY. 1 SELL (g_fibLockedCeiling) stays unchanged.
      double plL=iLow(_Symbol,Fib_HTF,prd); bool isPL=true;
      for(int k=1;k<=prd&&isPL;k++)
         if(iLow(_Symbol,Fib_HTF,prd-k)<=plL||iLow(_Symbol,Fib_HTF,prd+k)<=plL) isPL=false;
      if(isPL && plL < g_fibLevel0) // must be below old 0 BUY
      {
         bool nearTarget = (MathAbs(plL-g_fibRevL)<=tol || plL<=g_fibRevL+tol);
         if(!nearTarget)
         { Log(StringFormat("⏳ FIB FLOOR: pivot @ %.5f | not near RevL %.5f | holding",plL,g_fibRevL));
           return false; }
         // Set new anchor: floor=new swing low, ceiling=locked
         double newFloor   = plL;
         double newCeiling = g_fibLockedCeiling;
         Fib_SetAnchor(newFloor, newCeiling, false);
         g_fibWaitingNewFloor = false;
         g_fib.state = FIB_RANGE;
         Log(StringFormat("✅ FIB NEW FLOOR | 0=%.5f (NEW) | 1=%.5f (LOCKED) | 0.25=%.5f | 0.75=%.5f",
             g_fibLevel0, g_fibLevel1, g_fibLevel025, g_fibLevel075));
         Notify(StringFormat("✅ FIB FLOOR SHIFT|%s|0 NEW=%.5f|1 CEILING=%.5f|0.25=%.5f|0.75=%.5f|RevL→%.5f",
                _Symbol,g_fibLevel0,g_fibLevel1,g_fibLevel025,g_fibLevel075,g_fibRevL));
         return true;
      }
   }
   return false;
}

// ── CANDLE PATTERN DETECTION ─────────────────────────────────────
// Returns pattern score: 0=none, 1=doji, 2=hammer/star, 3=engulfing
int Fib_CheckCandlePattern(int direction, int bar=1)
{
   double o1=iOpen (_Symbol,PERIOD_CURRENT,bar);
   double c1=iClose(_Symbol,PERIOD_CURRENT,bar);
   double h1=iHigh (_Symbol,PERIOD_CURRENT,bar);
   double l1=iLow  (_Symbol,PERIOD_CURRENT,bar);
   double o2=iOpen (_Symbol,PERIOD_CURRENT,bar+1);
   double c2=iClose(_Symbol,PERIOD_CURRENT,bar+1);
   double range1=h1-l1; if(range1<=0) return 0;
   double body1 =MathAbs(c1-o1);
   double lowerWick=MathMin(o1,c1)-l1;
   double upperWick=h1-MathMax(o1,c1);

   // Doji — body <= 10% of range
   if(body1/range1 <= 0.10) return 1;

   if(direction==1) // BUY patterns
   {
      // Bullish engulfing: current bullish, previous bearish, current body engulfs previous
      if(c1>o1 && c2<o2 && o1<=c2 && c1>=o2) return 3;
      // Hammer: lower wick >= 60%, body <= 30%
      if(lowerWick/range1>=0.60 && body1/range1<=0.30) return 2;
   }
   else // SELL patterns
   {
      // Bearish engulfing: current bearish, previous bullish, current body engulfs previous
      if(c1<o1 && c2>o2 && o1>=c2 && c1<=o2) return 3;
      // Shooting star: upper wick >= 60%, body <= 30%
      if(upperWick/range1>=0.60 && body1/range1<=0.30) return 2;
   }
   return 0;
}

// ── PRICE VALUE CONFLUENCE ────────────────────────────────────────
// Checks if wick terminus ends at institutional decimal (.14 or .44)
// Returns 2=primary confluence, 1=secondary, 0=none
int Fib_CheckPriceValueConfluence(double wickPrice)
{
   // Get cents portion (2 decimal places)
   double cents = MathRound((wickPrice - MathFloor(wickPrice)) * 100.0);
   double tol   = Fib_PriceValueTol * 100.0; // convert to cents scale
   // Primary: .14 and .44
   if(MathAbs(cents - 14.0) <= tol) return 2;
   if(MathAbs(cents - 44.0) <= tol) return 2;
   // Secondary patterns from live observation
   if(MathAbs(cents - 36.0) <= tol) return 1;
   if(MathAbs(cents - 65.0) <= tol) return 1;
   if(MathAbs(cents - 17.0) <= tol) return 1;
   if(MathAbs(cents -  4.0) <= tol) return 1;
   return 0;
}

// ── ZONE ENTRY SCORER ─────────────────────────────────────────────
// Combines zone + candle pattern + price value confluence
// Score 1=watch only, 2=valid entry, 3+=high conviction
int Fib_ScoreZoneEntry(int direction, double price, int bar=1)
{
   int score = 0;
   string log = "";

   // ── FACTOR 1: PD ZONE — only active INSIDE the 0-1 range ────────
   // Outside range (broke 0 or 1): PD inactive — SBR/RBS roles apply instead
   if(g_fib.valid)
   {
     double buf = Fib_PDBuffer * GetPointsize();
     bool priceInsideRange = (price >= g_fibLevel0 - buf && price <= g_fibLevel1 + buf);

     if(priceInsideRange)
     {
       bool inPD = (direction==1)
                   ? (price<=g_fibLevel025+buf && price>=g_fibLevel0-buf*2)
                   : (price>=g_fibLevel075-buf && price<=g_fibLevel1+buf*2);
       if(inPD){ score+=3; log+="+3[PD] "; }
       // RANGE state bonus — buying floor / selling ceiling
       if(g_fib.state==FIB_RANGE)
       {
          if(direction==1  && price<=g_fibLevel0+buf) { score+=3; log+="+3[RANGE-FLOOR] "; }
          if(direction==-1 && price>=g_fibLevel1-buf) { score+=3; log+="+3[RANGE-CEILING] "; }
       }
     }

     // SBR/RBS — role reversal scoring on retest of broken level
     // Break UP: old 1 SELL → now SUPPORT → BUY on retest = RBS (Resistance Becomes Support)
     if(g_fibWaitingNewCeiling && direction==1)
     { if(MathAbs(price-g_fibLevel1)<=buf*3){ score+=3; log+="+3[RBS] "; } }
     // Break DOWN: old 0 BUY → now RESISTANCE → SELL on retest = SBR (Support Becomes Resistance)
     if(g_fibWaitingNewFloor && direction==-1)
     { if(MathAbs(price-g_fibLevel0)<=buf*3){ score+=3; log+="+3[SBR] "; } }

     // RevL/RevH ZONE BONUS — highest-conviction reversal zones in the fib system
     // BUY at RevL during floor cascade: price at -0.5 SD extension = institutional buy zone
     // SELL at RevH during ceiling cascade: price at +1.5 SD extension = institutional sell zone
     // Uses wide tolerance (6×PDBuffer=300pts) — RevL/RevH are projected, price often reverses before exact touch
     if(g_fibWaitingNewFloor && direction==1 && g_fibRevL>0)
     { double revTol=Fib_PDBuffer*6.0*GetPointsize();
       if(MathAbs(price-g_fibRevL)<=revTol){ score+=3; log+="+3[REVL-ZONE] "; } }
     if(g_fibWaitingNewCeiling && direction==-1 && g_fibRevH>0)
     { double revTol=Fib_PDBuffer*6.0*GetPointsize();
       if(MathAbs(price-g_fibRevH)<=revTol){ score+=3; log+="+3[REVH-ZONE] "; } }
   }

   // ── FACTOR 2: SR CHANNEL (weight 2) ──────────────────────────
   // SR channel at or near entry price — confluence only, not blocking
   if(UseSRChannels && g_srChannelCount>0)
   { double pip=ScaledPip(), buf=SR_ConfluenceBuffer*pip;
     for(int i=0; i<g_srChannelCount; i++)
     { double top=g_srChannels[i].top, bot=g_srChannels[i].bottom;
       bool inZone=(price>=bot-buf && price<=top+buf);
       if(inZone)
       { score+=2; log+="+2[SR] "; break; } } }

   // ── FACTOR 2b: FLIPPED SD LEVEL (weight 3) ───────────────────
   // Previously broken SD level retested from the CORRECT side — role reversal
   if(g_fibFlippedCount>0)
   { double buf=Fib_PDBuffer*GetPointsize()*3.0;
     for(int i=0; i<g_fibFlippedCount; i++)
     { if(g_fibFlippedLevels[i]<=0) continue;
       // dir=+1 means now SELL resistance → only score for SELL direction
       // dir=-1 means now BUY support    → only score for BUY direction
       bool dirMatch = (direction==-1 && g_fibFlippedDir[i]==+1) ||
                       (direction== 1 && g_fibFlippedDir[i]==-1);
       if(!dirMatch) continue;
       // Approach-side validation:
       // SBR (dir=+1): old support → new resistance → SELL must approach from BELOW
       // RBS (dir=-1): old resistance → new support → BUY must approach from ABOVE
       bool approachOK = false;
       if(g_fibFlippedDir[i]==+1 && price <= g_fibFlippedLevels[i]+buf)
          approachOK = true;  // SELL: price at or below the new resistance
       else if(g_fibFlippedDir[i]==-1 && price >= g_fibFlippedLevels[i]-buf)
          approachOK = true;  // BUY: price at or above the new support
       if(approachOK && MathAbs(price-g_fibFlippedLevels[i])<=buf)
       { score+=3; log+="+3[ROLE-FLIP] "; break; } } }

   // ── FACTOR 3: SD LEVEL (weight 2) ────────────────────────────
   // Price at an SD extension level
   // RevL (index 8) and RevH (index 0) use wider tolerance — projected levels
   if(g_fib.valid)
   { double pip=ScaledPip(), tol=DeviationTolerancePts*pip;
     double revTol=Fib_PDBuffer*6.0*pip;  // 300pts for RevL/RevH
     double sdZ[16]={g_fibRevH,g_fibLev1644,g_fibSD1H,g_fibLev225H,g_fibSD2H,g_fibLevel30,g_fibLev325,g_fibLev35,
                     g_fibRevL,g_fibLevN0644,g_fibSD1L,g_fibLevN125,g_fibSD2L,g_fibLevN20,g_fibLevN225,g_fibLevN25};
     double hi1=iHigh(_Symbol,PERIOD_CURRENT,bar), lo1=iLow(_Symbol,PERIOD_CURRENT,bar);
     for(int i=0; i<16; i++)
     { if(sdZ[i]<=0) continue;
       double sdTol = (i==0||i==8) ? revTol : tol;  // RevH=i0, RevL=i8: wider tolerance
       bool hit=(direction==1) ? (lo1>=sdZ[i]-sdTol&&lo1<=sdZ[i]+sdTol)
                               : (hi1>=sdZ[i]-sdTol&&hi1<=sdZ[i]+sdTol);
       if(hit){ score+=2; log+="+2[SD] "; break; } } }

   // ── FACTOR 4: REJECTION CANDLE ───────────────────────────────
   // Engulfing=3, Hammer/Star=2, Doji=1
   int patternScore = Fib_CheckCandlePattern(direction, bar);
   if(patternScore==3){ score+=3; log+="+3[ENGULF] "; }
   else if(patternScore==2){ score+=2; log+="+2[HAMMER] "; }
   else if(patternScore==1){ score+=1; log+="+1[DOJI] "; }

   // ── FACTOR 5: PRICE DECIMAL (.14/.44) ────────────────────────
   // Wick terminus at institutional decimal level
   double wickPrice = (direction==1) ? iLow (_Symbol,PERIOD_CURRENT,bar)
                                     : iHigh(_Symbol,PERIOD_CURRENT,bar);
   int pvScore = Fib_CheckPriceValueConfluence(wickPrice);
   if(pvScore==2){ score+=3; log+="+3[.14/.44] "; }  // primary
   else if(pvScore==1){ score+=1; log+="+1[decimal] "; } // secondary

   // ── FACTOR 8: H&S PATTERN (weight 3) ─────────────────────────
   // Confirmed H&S or Inverse H&S neckline break adds structural bonus
   if(direction==1  && g_invHSDetected && g_invHSNeckline>0)
   { score+=3; log+="+3[INV-H&S] "; }
   if(direction==-1 && g_hsDetected    && g_hsNeckline>0)
   { score+=3; log+="+3[H&S] "; }

   // ── FACTOR 9: CASCADE MOMENTUM (weight 2) ─────────────────────
   // Price beyond fib range in active cascade direction
   // BUY above fib1 in ceiling cascade = momentum continuation breakout
   // SELL below fib0 in floor cascade  = momentum continuation breakdown
   // Symmetric — same rule applies to both directions
   if(g_fib.valid)
   { bool above1CascadeBuy  = (direction== 1 && g_fibWaitingNewCeiling
                               && price > g_fibLevel1);
     bool below0CascadeSell = (direction==-1 && g_fibWaitingNewFloor
                               && price < g_fibLevel0);
     if(above1CascadeBuy || below0CascadeSell)
     { score+=2; log+="+2[CASCADE-MOM] "; } }

   // ── GRADE ─────────────────────────────────────────────────────
   string grade = (score>=13)?"🏆PERFECT":
                  (score>=9) ?"💎GOLDMINE":
                  (score>=6) ?"✅STRONG":
                  (score>=4) ?"📊MODERATE":
                              "⚠️WEAK";

   if(PrintToLog && score>0)
      Log(StringFormat("📊 FIB SCORE | %s | %s | score=%d %s | %s",
          direction==1?"BUY":"SELL", _Symbol, score, grade, log));
   return score;
}

// ── FIB-BASED TP LEVELS ───────────────────────────────────────────
// Override fixed TP_Points with actual fib levels
// ── TP DISPATCHER — routes to fib levels (default) or fixed points ──
// TPMode=FIB:    fib structure levels used as TP1/TP2/TP3
// TPMode=POINTS: fixed TP1_Points/TP2_Points/TP3_Points inputs used
// Fib fallback:  if fib invalid, always falls back to CalcLevels (points)
void CalcTP(int direction, double entry,
            double &slOut, double &tp1Out, double &tp2Out, double &tp3Out)
{
   if(TPMode == TP_MODE_POINTS)
   { CalcLevels(direction, entry, slOut, tp1Out, tp2Out, tp3Out); return; }
   // FIB mode — consolidation gets range TPs, normal gets fib structure TPs
   if(g_inConsolidation && g_fib.valid)
      Range_CalcLevels(direction, entry, slOut, tp1Out, tp2Out, tp3Out);
   else if(g_fib.valid)
      Fib_CalcEntryLevels(direction, entry, slOut, tp1Out, tp2Out, tp3Out);
   else
      CalcLevels(direction, entry, slOut, tp1Out, tp2Out, tp3Out); // no fib — points fallback
}

void Fib_CalcEntryLevels(int direction, double entry,
                          double &slOut, double &tp1Out, double &tp2Out, double &tp3Out)
{
   // B4 FIX: guard against invalid fib — fall back to fixed points
   if(!g_fib.valid || g_fib.fibRange<=0)
   { CalcLevels(direction, entry, slOut, tp1Out, tp2Out, tp3Out); return; }
   int dg=(int)SymbolInfoInteger(_Symbol,SYMBOL_DIGITS);
   double pip=ScaledPip(), mn=GetMinStop();
   double slD=0;
   if(UseATRBasedSL){double a=GetATRSlDist();slD=(a>0)?a:MathMax(SL_Points*pip,mn);}
   else slD=(SL_Points>0)?MathMax(SL_Points*pip,mn):0;

   if(direction==1)
   {
      // CASCADE BUY: price above fib1 (ceiling cascade) — fib0 SL would be thousands of pts away
      // OR TP would be inverted (fib0.5 below entry for BUY)
      bool tpWouldBeInverted_BUY = (g_fibLevel05 <= entry + mn); // standard TP1 at or below entry
      bool cascadeBuy = (tpWouldBeInverted_BUY || entry > g_fibLevel075)
                        && g_fibWaitingNewCeiling && g_fibRevH > 0;
      if(cascadeBuy)
      {
         double vsl = (VirtualSL_Points > 0) ? VirtualSL_Points * GetPointsize() * 1.5
                                             : MathMax(slD > 0 ? slD : mn, mn);
         vsl    = MathMax(vsl, mn + ScaledPip() * 2.0);
         slOut  = NormalizeDouble(entry - vsl, dg);
         double revDist = MathAbs(g_fibRevH - entry);
         tp1Out = NormalizeDouble(entry + revDist*0.33, dg);
         tp2Out = NormalizeDouble(entry + revDist*0.66, dg);
         tp3Out = NormalizeDouble(g_fibRevH, dg);
      }
      else
      {
         // SL priority: physical (SL_Points/ATR) if set → otherwise VirtualSL
         // Physical SL set explicitly by user → respect it
         // VirtualSL = fallback when no physical SL configured
         double vsl = (VirtualSL_Points > 0) ? VirtualSL_Points * GetPointsize()
                                             : MathMax(mn + ScaledPip(), mn);
         vsl    = MathMax(vsl, mn + ScaledPip());
         double useSL = (slD > 0) ? slD : vsl;  // physical wins if set
         slOut  = NormalizeDouble(entry - useSL, dg);
         tp1Out = NormalizeDouble(g_fibLevel05,  dg);
         tp2Out = NormalizeDouble(g_fibLevel075, dg);
         tp3Out = (g_fibWaitingNewCeiling||g_fib.state==FIB_TREND_UP)
                  ? NormalizeDouble(g_fibRevH, dg)
                  : NormalizeDouble(g_fibLevel1, dg);
      }
   }
   else
   {
      // CASCADE SELL: fires when standard SELL TPs would be inverted (fib0.5 ABOVE entry)
      // Covers: price below fib0 (deep cascade), price in discount during floor shift,
      // and GOLDMINE entries fractionally above fib0 that miss naive distance checks
      // Also requires: active floor shift + RevL anchor exists
      bool tpWouldBeInverted = (g_fibLevel05 >= entry - mn);  // standard TP1 at or above entry
      bool cascadeSell = (tpWouldBeInverted || entry < g_fibLevel025)
                         && g_fibWaitingNewFloor && g_fibRevL > 0;
      if(cascadeSell)
      {
         double vsl = (VirtualSL_Points > 0) ? VirtualSL_Points * GetPointsize() * 1.5
                                              : MathMax(slD > 0 ? slD : mn, mn);
         vsl = MathMax(vsl, mn + ScaledPip() * 2.0);
         slOut  = NormalizeDouble(entry + vsl, dg);
         double revDist = MathAbs(entry - g_fibRevL);
         tp1Out = NormalizeDouble(entry - revDist*0.33, dg);
         tp2Out = NormalizeDouble(entry - revDist*0.66, dg);
         tp3Out = NormalizeDouble(g_fibRevL, dg);
      }
      else
      {
         // SL priority: physical (SL_Points/ATR) if set → otherwise VirtualSL
         double vsl = (VirtualSL_Points > 0) ? VirtualSL_Points * GetPointsize()
                                             : MathMax(mn + ScaledPip(), mn);
         vsl    = MathMax(vsl, mn + ScaledPip());
         double useSL = (slD > 0) ? slD : vsl;  // physical wins if set
         slOut  = NormalizeDouble(entry + useSL, dg);
         tp1Out = NormalizeDouble(g_fibLevel05,  dg);
         tp2Out = NormalizeDouble(g_fibLevel025, dg);
         tp3Out = (g_fibWaitingNewFloor||g_fib.state==FIB_TREND_DOWN)
                  ? NormalizeDouble(g_fibRevL, dg)
                  : NormalizeDouble(g_fibLevel0, dg);
      }
   }
   // Ensure minimum separation
   if(direction==1)
   { tp1Out=MathMax(tp1Out,entry+mn); tp2Out=MathMax(tp2Out,tp1Out+mn); tp3Out=MathMax(tp3Out,tp2Out+mn); }
   else
   { tp1Out=MathMin(tp1Out,entry-mn); tp2Out=MathMin(tp2Out,tp1Out-mn); tp3Out=MathMin(tp3Out,tp2Out-mn); }
}

// ── INTERNAL BIAS TRACKER ─────────────────────────────────────────
// Tracks which side of the range price last came FROM
// BUY bias (+1): price last closed near fib0 (discount) → bouncing up
//   → all retrace levels (0.382, 0.5, 0.618) valid for BUY pullbacks
// SELL bias (-1): price last closed near fib1 (premium) → falling down
//   → all retrace levels (0.618, 0.5, 0.382) valid for SELL pullbacks
// Reset: bias clears when price crosses 0.5 against bias direction
void Fib_UpdateInternalBias()
{ if(!g_fib.valid||g_fib.fibRange<=0||g_fibWaitingNewFloor||g_fibWaitingNewCeiling) return;
  double cl1=iClose(_Symbol,PERIOD_CURRENT,1);
  double buf=Fib_PDBuffer*GetPointsize()*2.0;
  if(cl1<=g_fibLevel025+buf)
  { if(g_fibInternalBias!=1)
    { g_fibInternalBias=1;
      Log(StringFormat("🔼 BIAS SET BUY|price %.5f near fib0 zone|retrace levels 0.382/0.5/0.618 now valid BUY",cl1)); }}
  else if(cl1>=g_fibLevel075-buf)
  { if(g_fibInternalBias!=-1)
    { g_fibInternalBias=-1;
      Log(StringFormat("🔽 BIAS SET SELL|price %.5f near fib1 zone|retrace levels 0.618/0.5/0.382 now valid SELL",cl1)); }}
  // Reset if price crosses 0.5 against bias
  if(g_fibInternalBias==1  && cl1 < g_fibLevel05) { g_fibInternalBias=0; Log("⚖️ BIAS RESET|price crossed below 0.5|BUY bias cleared"); }
  if(g_fibInternalBias==-1 && cl1 > g_fibLevel05) { g_fibInternalBias=0; Log("⚖️ BIAS RESET|price crossed above 0.5|SELL bias cleared"); }
}

void Fib_ArmWatch(int direction, string source, bool isPO3=false, double specificLevel=0)
{
   if(!Fib_WatchEnabled||!g_fib.valid||g_fib.fibRange<=0) return;

   // ── DUPLICATE SUPPRESSION ─────────────────────────────────────
   // 1. Already in a position same direction near current price?
   double ep=(direction==1)?SymbolInfoDouble(_Symbol,SYMBOL_ASK)
                           :SymbolInfoDouble(_Symbol,SYMBOL_BID);
   double dupBuf=ScaledPip()*300;
   for(int i=PositionsTotal()-1;i>=0;i--)
   { ulong t=PositionGetTicket(i);
     if(!t||!PositionSelectByTicket(t)) continue;
     if(PositionGetString(POSITION_SYMBOL)!=_Symbol) continue;
     if((ulong)PositionGetInteger(POSITION_MAGIC)!=(ulong)MagicNumber) continue;
     int pt=(int)PositionGetInteger(POSITION_TYPE);
     bool sameDir=(direction==1&&pt==POSITION_TYPE_BUY)||(direction==-1&&pt==POSITION_TYPE_SELL);
     if(sameDir && MathAbs(ep-PositionGetDouble(POSITION_PRICE_OPEN))<=dupBuf)
     { Log(StringFormat("🔁 WATCH SUPPRESSED|%s|already in position near %.5f",
           direction==1?"BUY":"SELL", PositionGetDouble(POSITION_PRICE_OPEN)));
       return; } }

   // 2. Cooldown — same direction recently fired?
   int lastBar = (direction==1)?g_watchLastBuyBar:g_watchLastSellBar;
   if(g_barCount - lastBar < g_watchCooldownBars && lastBar > 0)
   { Log(StringFormat("⏱️ WATCH COOLDOWN|%s|%d bars remaining",
         direction==1?"BUY":"SELL", g_watchCooldownBars-(g_barCount-lastBar)));
     return; }

   // ── SCORE + PRIORITY ──────────────────────────────────────────
   int incomingScore    = g_fib.valid ? Fib_ScoreZoneEntry(direction, ep, 1) : 0;
   int incomingPriority = WatchSourcePriority(source);

   // ── PRIORITY QUEUE DECISION ───────────────────────────────────
   bool isUpgrade = false;
   if(g_fibWatch.active)
   {
      bool sameDirection = (g_fibWatch.direction == direction);

      if(sameDirection)
      { // UPGRADE: only if incoming is clearly better
        bool higherPriority = (incomingPriority < g_fibWatch.priority);
        bool higherScore    = (incomingScore > g_fibWatch.score + 1);
        if(higherPriority || higherScore)
        { isUpgrade = true;
          Log(StringFormat("⬆️ WATCH UPGRADED|%s→%s|score %d→%d|priority %d→%d",
              g_fibWatch.signalSource, source,
              g_fibWatch.score, incomingScore,
              g_fibWatch.priority, incomingPriority)); }
        else
        { Log(StringFormat("🔁 WATCH KEPT|existing %s score=%d p=%d >= incoming %s score=%d p=%d",
              g_fibWatch.signalSource, g_fibWatch.score, g_fibWatch.priority,
              source, incomingScore, incomingPriority));
          return; }
      }
      else // opposite direction
      { bool strongEnough = (incomingScore >= 7);
        bool goldmine     = (incomingScore >= 9);
        if(!strongEnough)
        { Log(StringFormat("🛡️ WATCH PROTECTED|existing %s %s score=%d|incoming %s score=%d < 7|rejected",
              g_fibWatch.direction==1?"BUY":"SELL",
              g_fibWatch.signalSource, g_fibWatch.score,
              direction==1?"BUY":"SELL", incomingScore));
          return; }
        Log(StringFormat("🔄 WATCH REPLACED|%s score=%d → %s score=%d%s",
            g_fibWatch.signalSource, g_fibWatch.score,
            source, incomingScore, goldmine?" GOLDMINE":""));
        if(g_fibWatch.direction==1) g_watchLastBuyBar=g_barCount;
        else                        g_watchLastSellBar=g_barCount;
      }
   }

   // Zone touch limit — skip for high-priority sources AND upgrades
   if(Fib_MaxZoneTouches>0 && !isPO3 && incomingPriority > 2 && !isUpgrade)
   { int touches=(direction==1)?g_fibBuyZoneTouches:g_fibSellZoneTouches;
     if(touches>=Fib_MaxZoneTouches)
     { Log(StringFormat("🚫 ZONE EXHAUSTED | %s | %d/%d touches | ignoring",
           direction==1?"BUY 0.25":"SELL 0.75", touches, Fib_MaxZoneTouches));
       return; }
     if(direction==1) g_fibBuyZoneTouches++;
     else             g_fibSellZoneTouches++;
     Log(StringFormat("👆 ZONE TOUCH %d/%d | %s",
         direction==1?g_fibBuyZoneTouches:g_fibSellZoneTouches,
         Fib_MaxZoneTouches, direction==1?"BUY 0.25":"SELL 0.75")); }

   // ── COMPUTE WATCH ZONE ────────────────────────────────────────
   double buf=Fib_PDBuffer*GetPointsize();
   double prox=Fib_WatchProximityPts*GetPointsize();
   double zT,zB;

   // RBS BUY:  zone = fib1 → 0.618  (golden ratio deep retest still valid)
   // SBR SELL: zone = 0.382 → fib0  (golden ratio deep retest still valid)
   // 0.5 crossing = thesis invalid (handled in Fib_CheckWatch)
   if(direction==-1 && g_fibWaitingNewFloor)
   { zT = g_fibLevel382 + buf; zB = g_fibLevel0 - buf; }
   else if(direction==1 && g_fibWaitingNewCeiling)
   { zT = g_fibLevel1 + buf; zB = g_fibLevel618 - buf; }
   else if(direction==1 && g_fibWaitingNewFloor && g_fibRevL > 0)
   { zT = g_fibRevL + buf*7; zB = g_fibRevL - buf; }   // buf*7=350pts: RevL is projected, price often reverses before exact touch
   else if(direction==-1 && g_fibWaitingNewCeiling && g_fibRevH > 0)
   { zT = g_fibRevH + buf; zB = g_fibRevH - buf*7; }   // buf*7=350pts: same logic for RevH
   else
   { // Bias-driven retracement: expand zone to full equil range (0.25→0.75)
     // Price anywhere in equil with matching bias = valid pullback entry
     if(g_fibInternalBias==direction)
     { zT=g_fibLevel075+buf;   // full equil range for aligned-bias entry
       zB=g_fibLevel025-buf; }
     else
     { zT=(direction==1)?MathMin(g_fibLevel025+buf+prox,g_fibLevel05):(g_fibLevel075+buf);
       zB=(direction==1)?(g_fibLevel025-buf):MathMax(g_fibLevel075-buf-prox,g_fibLevel05); } }

   // ── ARM ───────────────────────────────────────────────────────
   g_fibWatch.active       = true;
   g_fibWatch.direction    = direction;
   g_fibWatch.zoneTop      = zT;
   g_fibWatch.zoneBot      = zB;
   g_fibWatch.armedBar     = g_barCount;
   g_fibWatch.signalSource = source;
   g_fibWatch.isPO3        = isPO3;
   g_fibWatch.wasCascade   = (g_fibWaitingNewFloor && direction==1) ||
                             (g_fibWaitingNewCeiling && direction==-1);
   g_fibWatch.score        = incomingScore;
   g_fibWatch.priority     = incomingPriority;

   Log(StringFormat("⏳ Fib Watch ARMED | %s | %s | score=%d | priority=%d | zone[%.5f–%.5f]%s%s",
       direction==1?"BUY":"SELL", source, incomingScore, incomingPriority, zB, zT,
       isPO3?" [PO3]":"",
       (g_fibWaitingNewFloor&&direction==-1)?" [BREAKDOWN-RETEST]":
       (g_fibWaitingNewCeiling&&direction==1)?" [BREAKOUT-RETEST]":""));
}

void Fib_CheckWatch()
{
   if(!g_fibWatch.active) return;
   if(Fib_MaxWatchBars>0&&g_barCount-g_fibWatch.armedBar>Fib_MaxWatchBars)
   { Log("⏰ Fib Watch expired | "+string(g_fibWatch.direction==1?"BUY":"SELL"));
     if(g_fibWatch.direction==1) g_watchLastBuyBar=g_barCount;
     else                        g_watchLastSellBar=g_barCount;
     g_fibWatch.active=false; return;}
   double hi1=iHigh(_Symbol,PERIOD_CURRENT,1),lo1=iLow(_Symbol,PERIOD_CURRENT,1),cl1=iClose(_Symbol,PERIOD_CURRENT,1);

   // ── 0.5 INVALIDATION ─────────────────────────────────────────
   // RBS BUY watch: if price closes below 0.5 → thesis broken, cancel
   // SBR SELL watch: if price closes above 0.5 → thesis broken, cancel
   // Continuation case: if price exits zone toward 0.5 but hasn't crossed it,
   // the watch stays armed — recovery back into zone = continuation confirmation
   if(g_fib.valid && g_fibLevel05 > 0)
   { bool rbs = (g_fibWatch.direction==1  && g_fibWaitingNewCeiling);
     bool sbr = (g_fibWatch.direction==-1 && g_fibWaitingNewFloor);
     if(rbs && cl1 < g_fibLevel05)
     { string inv="❌ RBS INVALID|price %.5f crossed 0.5(%.5f)|BUY watch cancelled";
       Log(StringFormat(inv,cl1,g_fibLevel05));
       Notify(StringFormat(inv,cl1,g_fibLevel05));
       g_fibWatch.active=false; return; }
     if(sbr && cl1 > g_fibLevel05)
     { string inv="❌ SBR INVALID|price %.5f crossed 0.5(%.5f)|SELL watch cancelled";
       Log(StringFormat(inv,cl1,g_fibLevel05));
       Notify(StringFormat(inv,cl1,g_fibLevel05));
       g_fibWatch.active=false; return; }
     // Continuation detection: price between golden ratio and 0.5 — watch stays armed
     if(rbs && cl1 < g_fibLevel618 && cl1 >= g_fibLevel05)
     { Log(StringFormat("⏳ RBS CONTINUATION MODE|price %.5f below 0.618|waiting recovery above 0.618",cl1)); return; }
     if(sbr && cl1 > g_fibLevel382 && cl1 <= g_fibLevel05)
     { Log(StringFormat("⏳ SBR CONTINUATION MODE|price %.5f above 0.382|waiting drop below 0.382",cl1)); return; }
   }

   bool zh=false;
   if(g_fibWatch.direction==1)
      zh=(lo1<=g_fibWatch.zoneTop&&lo1>=g_fibWatch.zoneBot&&cl1>=g_fibWatch.zoneBot);
   else
      zh=(hi1>=g_fibWatch.zoneBot&&hi1<=g_fibWatch.zoneTop&&cl1<=g_fibWatch.zoneTop);
   if(!zh) return;

   // Score the entry — candle patterns + structural confluences.
   // Use max(arm-time score, fresh score): arm-time score was computed while cascade flags
   // were still active (RevL/RevH zone bonus intact); fresh score is more up-to-date on
   // candle patterns. Taking the max avoids penalising cascade watches for the flag race.
   int freshScore = Fib_ScoreZoneEntry(g_fibWatch.direction, cl1, 1);
   int score = MathMax(g_fibWatch.score, freshScore);

   // Min score — cascade uses lower threshold (no PD zone bonus available).
   // wasCascade preserves the cascade context even after the re-anchor clears the shift flag
   // (re-anchor happens inside Fib_UpdateState before Fib_CheckWatch runs in the same tick).
   bool watchCascade  = (g_fibWaitingNewFloor || g_fibWaitingNewCeiling) || g_fibWatch.wasCascade;
   int  watchMinScore = watchCascade ? Fib_CascadeMinScore : Fib_EntryMinScore;
   if(score < watchMinScore)
   { Log(StringFormat("⏳ FIB WATCH: zone hit | score=%d < min=%d%s | waiting for pattern",
         score, watchMinScore, watchCascade?" [CASCADE]":""));
     Notify(StringFormat("⏳ FIB ZONE HIT|%s|%s|score=%d|waiting pattern confirmation",
            _Symbol, g_fibWatch.direction==1?"BUY":"SELL", score));
     return; }

   int dg=(int)SymbolInfoInteger(_Symbol,SYMBOL_DIGITS);
   double ep=(g_fibWatch.direction==1)?SymbolInfoDouble(_Symbol,SYMBOL_ASK):SymbolInfoDouble(_Symbol,SYMBOL_BID);
   string convict=(score>=13)?"🏆PERFECT":(score>=9)?"💎GOLDMINE":(score>=6)?"✅STRONG":(score>=4)?"📊MODERATE":"⚠️WEAK";
   string push=StringFormat("%s FIB %s ENTRY|%s|%s|score=%d %s|%s%s",
      (g_fibWatch.direction==1)?"🟢":"🔴",(g_fibWatch.direction==1)?"BUY":"SELL",
      _Symbol,(g_fibWatch.direction==1)?"0.25-DISC":"0.75-PREM",
      score,convict,g_fibWatch.signalSource,
      g_fibWatch.isPO3?"|🎯PO3":"");
   Log(push);Notify(push,true,true);
   double sl,tp1,tp2,tp3;
   CalcTP(g_fibWatch.direction,ep,sl,tp1,tp2,tp3);
   if(EAMode==EA_MODE_TRADE) OpenPositions(g_fibWatch.direction,cl1,sl,tp1,tp2,tp3);
   if(g_fibWatch.direction==1) g_watchLastBuyBar=g_barCount;
   else                        g_watchLastSellBar=g_barCount;
   g_fibWatch.active=false;
}

void Fib_CheckSDReversalZones()
{
   if(!UseStdDevReversal||!g_fib.valid) return;

   // Direction filter — only check zones aligned with current M12 trend
   // Downtrend or floor-shift in progress → BUY zones only (looking for reversal up)
   // Uptrend or ceiling-shift in progress → SELL zones only (looking for reversal down)
   // Range → check both
   bool checkBuySD  = (g_fib.state != FIB_TREND_UP   && !g_fibWaitingNewCeiling);
   bool checkSellSD = (g_fib.state != FIB_TREND_DOWN  && !g_fibWaitingNewFloor);
   if(!checkBuySD && !checkSellSD) return;
   double pip=ScaledPip(),tol=DeviationTolerancePts*pip;
   double hi1=iHigh(_Symbol,PERIOD_CURRENT,1),lo1=iLow(_Symbol,PERIOD_CURRENT,1);
   double cl1=iClose(_Symbol,PERIOD_CURRENT,1);

   // Cooldown — prevents same SD level firing every bar while price hovers
   static int lastSDSellBar[8]={0,0,0,0,0,0,0,0};
   static int lastSDBuyBar[8] ={0,0,0,0,0,0,0,0};
   int sdCooldown=12; // M5 bars (~1 hour)

   double sellZ[8]={g_fibRevH,g_fibLev1644,g_fibSD1H,g_fibLev225H,g_fibSD2H,g_fibLevel30,g_fibLev325,g_fibLev35};
   string sellN[8]={"1.5-REV","1.644-REV","FLIP2","2.25","2.5","FLIP3","3.25","3.5"};
   if(checkSellSD)
   for(int i=0;i<8;i++)
   { if(sellZ[i]<=0) continue;
     // RevH (i=0) is a projected level — use wider tolerance than fixed SD levels
     double zoneTol = (i==0) ? MathMax(tol, Fib_PDBuffer*6.0*pip) : tol;
     if(hi1>=sellZ[i]-zoneTol&&hi1<=sellZ[i]+zoneTol)
     { if(g_barCount-lastSDSellBar[i]<sdCooldown) break; // cooldown active
       if(Fib_MaxZoneTouches>0 && g_sdSellZoneTouches[i]>=Fib_MaxZoneTouches)
       { Log(StringFormat("🚫 SD SELL EXHAUSTED|%s|%d/%d touches",sellN[i],g_sdSellZoneTouches[i],Fib_MaxZoneTouches)); break; }
       lastSDSellBar[i]=g_barCount;
       g_sdSellZoneTouches[i]++;
       int score=Fib_ScoreZoneEntry(-1,cl1,1);
       string msg=StringFormat("🔴 SD SELL ZONE|%s|%s @ %.5f|score=%d",_Symbol,sellN[i],sellZ[i],score);
       Log(msg);
       if(score>=(g_fibWaitingNewFloor||g_fibWaitingNewCeiling?Fib_CascadeMinScore:Fib_EntryMinScore))
       { Notify(msg+"|✅ARMED"); Fib_ArmWatch(-1,"SD-"+sellN[i],false); }
       else
         Notify(msg+"|⏳waiting pattern");
       break; }}

   double buyZ[8]={g_fibRevL,g_fibLevN0644,g_fibSD1L,g_fibLevN125,g_fibSD2L,g_fibLevN20,g_fibLevN225,g_fibLevN25};
   string buyN[8]={"-0.5-REV","-0.644-REV","FLIP-1","-1.25","-1.5","FLIP-2","-2.25","-2.5"};
   if(checkBuySD)
   for(int i=0;i<8;i++)
   { if(buyZ[i]<=0) continue;
     // RevL (i=0) is a projected level — use wider tolerance than fixed SD levels
     double zoneTol = (i==0) ? MathMax(tol, Fib_PDBuffer*6.0*pip) : tol;
     if(lo1>=buyZ[i]-zoneTol&&lo1<=buyZ[i]+zoneTol)
     { if(g_barCount-lastSDBuyBar[i]<sdCooldown) break;
       if(Fib_MaxZoneTouches>0 && g_sdBuyZoneTouches[i]>=Fib_MaxZoneTouches)
       { Log(StringFormat("🚫 SD BUY EXHAUSTED|%s|%d/%d touches",buyN[i],g_sdBuyZoneTouches[i],Fib_MaxZoneTouches)); break; }
       lastSDBuyBar[i]=g_barCount;
       g_sdBuyZoneTouches[i]++;
       int score=Fib_ScoreZoneEntry(1,cl1,1);
       string msg=StringFormat("🟢 SD BUY ZONE|%s|%s @ %.5f|score=%d",_Symbol,buyN[i],buyZ[i],score);
       Log(msg);
       if(score>=(g_fibWaitingNewFloor||g_fibWaitingNewCeiling?Fib_CascadeMinScore:Fib_EntryMinScore))
       { Notify(msg+"|✅ARMED"); Fib_ArmWatch(1,"SD-"+buyN[i],false); }
       else
         Notify(msg+"|⏳waiting pattern");
       break; }}

   // ── FLIPPED LEVEL RETEST CHECK ────────────────────────────────
   // Notify when price retests a previously broken level from the other side
   if(g_fibFlippedCount>0)
   { if(!g_lastFlipBarInit){ ArrayInitialize(g_lastFlipBar,0); g_lastFlipBarInit=true; }
     // Seed any uncooldown slots with current bar to prevent startup burst
     for(int j=0;j<32;j++) if(g_lastFlipBar[j]==0) g_lastFlipBar[j]=g_barCount-sdCooldown;
     double buf=Fib_PDBuffer*GetPointsize()*3.0;
     for(int i=0;i<g_fibFlippedCount;i++)
     { if(g_fibFlippedLevels[i]<=0)continue;
       if(g_barCount-g_lastFlipBar[i]<sdCooldown)continue;
       bool sellRetest=(g_fibFlippedDir[i]==+1 && hi1>=g_fibFlippedLevels[i]-buf && hi1<=g_fibFlippedLevels[i]+buf && checkSellSD);
       bool buyRetest =(g_fibFlippedDir[i]==-1 && lo1>=g_fibFlippedLevels[i]-buf && lo1<=g_fibFlippedLevels[i]+buf && checkBuySD);
       if(sellRetest||buyRetest)
       { g_lastFlipBar[i]=g_barCount;
         int dir=(sellRetest)?-1:1;
         int score=Fib_ScoreZoneEntry(dir,cl1,1);
         string label=sellRetest?"🔴 ROLE-FLIP SELL":"🟢 ROLE-FLIP BUY";
         string msg=StringFormat("%s RETEST|%s|%.5f|score=%d",label,_Symbol,g_fibFlippedLevels[i],score);
         Log(msg);
         if(score>=(g_fibWaitingNewFloor||g_fibWaitingNewCeiling?Fib_CascadeMinScore:Fib_EntryMinScore))
         { Notify(msg+"|✅CONFIRMED", true, true);  // isEntry=true — fires in signal-only mode
           Fib_ArmWatch(dir,"ROLE-FLIP",false,g_fibFlippedLevels[i]); }
         else
           Notify(msg+"|⏳waiting confirmation"); }}}
}

// ── SD CASCADE RE-ANCHOR ──────────────────────────────────────────
// Handles consecutive SD level breaks — extends 0/1 reanchor logic to all SD levels
// Called every M5 bar when g_fibWaitingNewFloor or g_fibWaitingNewCeiling is active
void Fib_CheckSDCascadeReAnchor()
{
   double pip=ScaledPip(), bb=Fib_BreakBuffer*pip, tol=DeviationTolerancePts*pip;
   double cl1=iClose(_Symbol,PERIOD_CURRENT,1);
   double lo1=iLow (_Symbol,PERIOD_CURRENT,1);
   double hi1=iHigh(_Symbol,PERIOD_CURRENT,1);

   // ── FLOOR CASCADE (break DOWN) ────────────────────────────────
   if(g_fibWaitingNewFloor)
   {
      double target=g_fibRevL; // current target = RevL (-0.5 of current range)

      // PROXIMITY ARM — price approaching RevL within 5×PDBuffer (250pts)
      // RevL is a projected level — price often reverses before exact touch
      // Arm BUY watch early so pattern confirmation catches the actual low
      if(!g_fibWatch.active && target > 0)
      { double proxBuf = Fib_PDBuffer * 5.0 * pip;
        if(lo1 <= target + proxBuf)
        { Log(StringFormat("📍 REVL PROXIMITY|lo=%.5f within %.0fpts of RevL=%.5f|arming BUY watch early",
              lo1, (lo1-(target))/pip, target));
          Fib_ArmWatch(1,"REVL-PROXIMITY",false); }}

      // HOLD: wick touched target zone, close above → rejection/hold → confirm re-anchor
      // Use wider tolerance for RevL — it is a projected level, not an exact measured one
      double revTol = MathMax(tol, Fib_PDBuffer * 6.0 * pip); // 300pts vs 30pts default
      bool wickHit    = (lo1 <= target + revTol && lo1 >= target - bb*4);
      bool closeAbove = (cl1 > target - tol);

      if(wickHit && closeAbove)
      {
         // Arm the BUY watch BEFORE re-anchoring so:
         // (a) zone is set around the current RevL, and
         // (b) wasCascade=true is captured (g_fibWaitingNewFloor still true here).
         // Fib_CheckWatch() runs after Fib_UpdateState() in the same OnTick and will
         // execute the trade with cascade-level score threshold.
         ZeroMemory(g_fibWatch);  // clear any stale proximity/SD watch
         Fib_ArmWatch(1, "REVL-HOLD", false);
         Fib_AddFlippedLevel(target, -1); // held as BUY floor → stays support on future retest
         Fib_SetAnchor(target, g_fibLockedCeiling, false);
         g_fibWaitingNewFloor = false;
         g_fib.state = FIB_RANGE;
         Log(StringFormat("✅ FIB CASCADE HOLD↓|new 0=%.5f|1=%.5f(LOCKED)|new RevL=%.5f|BUY watch armed",
             g_fibLevel0, g_fibLevel1, g_fibRevL));
         Notify(StringFormat("✅ FIB CASCADE HOLD|%s|new 0=%.5f|1=%.5f|0.25=%.5f|0.75=%.5f|RevL→%.5f",
                _Symbol,g_fibLevel0,g_fibLevel1,g_fibLevel025,g_fibLevel075,g_fibRevL));
         return;
      }

      // CASCADE: price broke through target without holding — shift to next SD level
      if(cl1 < target - bb)
      {
         // Use target as new floor, recalculate all levels, new RevL is next watch target
         Fib_AddFlippedLevel(target, +1); // target level broke down → now SELL resistance on retest
         Fib_SetAnchor(target, g_fibLockedCeiling, false);
         g_fibWaitingNewFloor = true;  // still waiting — new RevL is next target
         g_fib.state = FIB_TREND_DOWN;
         Log(StringFormat("🔻 FIB CASCADE↓|broke %.5f|next RevL target=%.5f",target,g_fibRevL));
         Notify(StringFormat("🔻 FIB CASCADE|%s|broke %.5f|→next target=%.5f",_Symbol,target,g_fibRevL));
      }
   }

   // ── CEILING CASCADE (break UP) ────────────────────────────────
   if(g_fibWaitingNewCeiling)
   {
      double target=g_fibRevH; // current target = RevH (+1.5 of current range)

      // PROXIMITY ARM — price approaching RevH within 5×PDBuffer (250pts)
      if(!g_fibWatch.active && target > 0)
      { double proxBuf = Fib_PDBuffer * 5.0 * pip;
        if(hi1 >= target - proxBuf)
        { Log(StringFormat("📍 REVH PROXIMITY|hi=%.5f within %.0fpts of RevH=%.5f|arming SELL watch early",
              hi1, (target-hi1)/pip, target));
          Fib_ArmWatch(-1,"REVH-PROXIMITY",false); }}

      double revTol = MathMax(tol, Fib_PDBuffer * 6.0 * pip); // 300pts wider tolerance
      bool wickHit    = (hi1 >= target - revTol && hi1 <= target + bb*4);
      bool closeBelow = (cl1 < target + tol);

      if(wickHit && closeBelow)
      {
         // Arm the SELL watch BEFORE re-anchoring so:
         // (a) zone is set around the current RevH, and
         // (b) wasCascade=true is captured (g_fibWaitingNewCeiling still true here).
         ZeroMemory(g_fibWatch);  // clear any stale proximity/SD watch
         Fib_ArmWatch(-1, "REVH-HOLD", false);
         Fib_AddFlippedLevel(target, +1); // held as SELL ceiling → stays resistance on future retest
         Fib_SetAnchor(g_fibLockedFloor, target, false);
         g_fibWaitingNewCeiling = false;
         g_fib.state = FIB_RANGE;
         Log(StringFormat("✅ FIB CASCADE HOLD↑|new 1=%.5f|0=%.5f(LOCKED)|new RevH=%.5f|SELL watch armed",
             g_fibLevel1, g_fibLevel0, g_fibRevH));
         Notify(StringFormat("✅ FIB CASCADE HOLD|%s|new 1=%.5f|0=%.5f|0.25=%.5f|0.75=%.5f|RevH→%.5f",
                _Symbol,g_fibLevel1,g_fibLevel0,g_fibLevel025,g_fibLevel075,g_fibRevH));
         return;
      }

      if(cl1 > target + bb)
      {
         Fib_AddFlippedLevel(target, -1); // target level broke up → now BUY support on retest
         Fib_SetAnchor(g_fibLockedFloor, target, false);
         g_fibWaitingNewCeiling = true;
         g_fib.state = FIB_TREND_UP;
         Log(StringFormat("🔺 FIB CASCADE↑|broke %.5f|next RevH target=%.5f",target,g_fibRevH));
         Notify(StringFormat("🔺 FIB CASCADE|%s|broke %.5f|→next target=%.5f",_Symbol,target,g_fibRevH));
      }
   }
}

void Fib_UpdateState()
{
   if(!g_fib.valid) return;
   double pip=ScaledPip(),bb=Fib_BreakBuffer*pip,rb=Fib_ReversalBuffer*pip;
   double cl1=iClose(_Symbol,PERIOD_CURRENT,1),hi1=iHigh(_Symbol,PERIOD_CURRENT,1),lo1=iLow(_Symbol,PERIOD_CURRENT,1);
   if(UseStdDevReversal) Fib_CheckSDReversalZones();
   if(cl1>g_fibLevel1+bb&&g_fib.state!=FIB_TREND_UP)
   { g_fib.state=FIB_TREND_UP;g_fib.highFlipped=true;
     if(g_fibWatch.active&&g_fibWatch.direction==1)g_fibWatch.active=false;
     Notify(StringFormat("🔺 FIB BREAK UP|%s|%.5f>1(%.5f)",_Symbol,cl1,g_fibLevel1));
     Fib_ReAnchorOnBreak(1);return;}
   if(cl1<g_fibLevel0-bb&&g_fib.state!=FIB_TREND_DOWN)
   { g_fib.state=FIB_TREND_DOWN;g_fib.lowFlipped=true;
     if(g_fibWatch.active&&g_fibWatch.direction==-1)g_fibWatch.active=false;
     Notify(StringFormat("🔻 FIB BREAK DOWN|%s|%.5f<0(%.5f)",_Symbol,cl1,g_fibLevel0));
     Fib_ReAnchorOnBreak(-1);return;}

   // ── PO3 FALSE BREAK DETECTION ────────────────────────────────────
   // Breakdown active: price must recover to 0.25 zone to confirm false break
   // Small bounces above fib0 are normal RBS — do NOT cancel floor shift
   if(g_fibWaitingNewFloor && cl1 > g_fibLevel025)
   { string msg=StringFormat("🔄 FALSE BREAK DOWN|%s|cl1=%.5f recovered above 0.25(%.5f)|cancelling floor shift|arming BUY",
         _Symbol, cl1, g_fibLevel025);
     Log(msg); Notify(msg);  // structural only — actual entry fires when watch executes
     if(g_fibWatch.active && StringFind(g_fibWatch.signalSource,"PO3")<0)
        Log(StringFormat("⚠️ FALSE BREAK: cancelled active '%s' watch — superseded by PO3-FALSE-BREAK",g_fibWatch.signalSource));
     g_fibWaitingNewFloor   = false;
     g_fib.state            = FIB_RANGE;
     ZeroMemory(g_fibWatch);
     g_fibBuyZoneTouches    = 0;
     g_fibSellZoneTouches   = 0;
     Fib_ArmWatch(1, "PO3-FALSE-BREAK", true);
     return; }

   // Breakout active: price must drop back to 0.75 zone to confirm false break
   // Small retracements below fib1 are normal — do NOT cancel ceiling shift
   if(g_fibWaitingNewCeiling && cl1 < g_fibLevel075)
   { string msg=StringFormat("🔄 FALSE BREAK UP|%s|cl1=%.5f dropped below 0.75(%.5f)|cancelling ceiling shift|arming SELL",
         _Symbol, cl1, g_fibLevel075);
     Log(msg); Notify(msg);  // structural only — actual entry fires when watch executes
     if(g_fibWatch.active && StringFind(g_fibWatch.signalSource,"PO3")<0)
        Log(StringFormat("⚠️ FALSE BREAK: cancelled active '%s' watch — superseded by PO3-FALSE-BREAK",g_fibWatch.signalSource));
     g_fibWaitingNewCeiling = false;
     g_fib.state            = FIB_RANGE;
     ZeroMemory(g_fibWatch);
     g_fibBuyZoneTouches    = 0;
     g_fibSellZoneTouches   = 0;
     Fib_ArmWatch(-1, "PO3-FALSE-BREAK", true);
     return; }
   // ── SD CASCADE: consecutive SD level breaks — chains infinitely ─
   if(g_fibWaitingNewFloor || g_fibWaitingNewCeiling)
   { Fib_CheckSDCascadeReAnchor(); return; }
   // PO3 manipulation detection — only when ADR/EHL confirms consolidation
   if(g_inConsolidation&&g_consolLow>0&&lo1<=g_fibRevL+rb&&cl1>=g_consolLow-bb&&g_fib.state!=FIB_MANIP_UP)
   { g_fib.state=FIB_MANIP_UP;
     string msg=StringFormat("🎯 FIB PO3↑|%s|Wick %.5f→REV %.5f|⏳→0.25",_Symbol,lo1,g_fibRevL);
     Log(msg);Notify(msg);Fib_ArmWatch(1,"PO3-MANIP",true);return;}
   if(g_inConsolidation&&g_consolHigh>0&&hi1>=g_fibRevH-rb&&cl1<=g_consolHigh+bb&&g_fib.state!=FIB_MANIP_DOWN)
   { g_fib.state=FIB_MANIP_DOWN;
     string msg=StringFormat("🎯 FIB PO3↓|%s|Wick %.5f→REV %.5f|⏳→0.75",_Symbol,hi1,g_fibRevH);
     Log(msg);Notify(msg);Fib_ArmWatch(-1,"PO3-MANIP",true);return;}
   if(g_fib.state==FIB_MANIP_UP)
   { if(cl1<g_fibRevL-rb){g_fib.state=FIB_TREND_DOWN;Notify(StringFormat("🔻 PO3 FAILED↓|%s|Next FLIP-1 %.5f",_Symbol,g_fibSD1L));return;}
     if(g_consolHigh>0&&cl1>g_consolHigh&&g_inConsolidation){g_fib.state=FIB_TREND_UP;Notify(StringFormat("✅ PO3 RESOLVED↑|%s",_Symbol));
       if(g_fibWatch.active&&g_fibWatch.isPO3)g_fibWatch.active=false;return;}}
   if(g_fib.state==FIB_MANIP_DOWN)
   { if(cl1>g_fibRevH+rb){g_fib.state=FIB_TREND_UP;Notify(StringFormat("🔺 PO3 FAILED↑|%s|Next FLIP2 %.5f",_Symbol,g_fibSD1H));return;}
     if(g_consolLow>0&&cl1<g_consolLow&&g_inConsolidation){g_fib.state=FIB_TREND_DOWN;Notify(StringFormat("✅ PO3 RESOLVED↓|%s",_Symbol));
       if(g_fibWatch.active&&g_fibWatch.isPO3)g_fibWatch.active=false;return;}}
   if((g_fib.state==FIB_TREND_UP||g_fib.state==FIB_TREND_DOWN)
      &&cl1>g_fibLevel0&&cl1<g_fibLevel1&&g_inConsolidation)
      g_fib.state=FIB_RANGE;
   if(g_fibWatch.active&&g_fibWatch.isPO3)
   { bool cancel=false;string cr="";
     if(g_fibWatch.direction==1&&cl1>g_fibLevel1+bb){cancel=true;cr="broke above 1";}
     if(g_fibWatch.direction==-1&&cl1<g_fibLevel0-bb){cancel=true;cr="broke below 0";}
     if(cancel){Log("❌ PO3 WATCH CANCEL|"+cr);g_fibWatch.active=false;}}
}

ENUM_FIB_FILTER Fib_FilterSignal(int direction, double price, string source, string &outLabel)
{
   outLabel="";

   // ── HARD GATE: no anchor = no trade ──────────────────────────
   if(!Fib_WatchEnabled||!g_fib.valid)
   { outLabel="❌ NO FIB ANCHOR";
     return FIB_BLOCKED; }

   // ── CASCADE REVERSAL GATE ────────────────────────────────────
   // During a ceiling shift (break UP waiting for new high at RevH):
   //   SELL is the expected reversal when price reaches RevH.
   //   Allow it if price is currently near RevH OR touched RevH within
   //   the last 5 bars (ST flip is often 1-3 bars after the actual wick).
   //   Block it everywhere else (still trending up toward RevH).
   // Mirror logic for floor shift (break DOWN) and BUY at RevL.
   if(g_fibWaitingNewCeiling && direction==-1 && g_fibRevH > 0)
   { double revTol2 = MathMax(DeviationTolerancePts*ScaledPip(), Fib_PDBuffer*6.0*GetPointsize());
     bool nearNow = (MathAbs(price - g_fibRevH) <= revTol2);
     bool recentTouch = false;
     for(int _b=1; _b<=5 && !recentTouch; _b++)
        if(iHigh(_Symbol,PERIOD_CURRENT,_b) >= g_fibRevH - revTol2) recentTouch = true;
     if(nearNow || recentTouch)
     { outLabel = nearNow ? "📍CEILING-SELL@RevH" : "📍CEILING-SELL@RevH(recent)";
       Log("✅ CASCADE REVERSAL|SELL near/at RevH during ceiling shift → FIB_EXEC_NOW");
       return FIB_EXEC_NOW; }
     Log("⚠️ FIB ADVISORY|SELL during ceiling shift|price not near RevH — blocked");
     outLabel="🚫CEILING↑"; return FIB_BLOCKED; }
   if(g_fibWaitingNewCeiling && direction==-1)   // RevH==0 edge case
   { Log("⚠️ FIB ADVISORY|SELL during ceiling shift|no RevH — blocked");
     outLabel="🚫CEILING↑"; return FIB_BLOCKED; }

   if(g_fibWaitingNewFloor && direction==1 && g_fibRevL > 0)
   { double revTol2 = MathMax(DeviationTolerancePts*ScaledPip(), Fib_PDBuffer*6.0*GetPointsize());
     bool nearNow = (MathAbs(price - g_fibRevL) <= revTol2);
     bool recentTouch = false;
     for(int _b=1; _b<=5 && !recentTouch; _b++)
        if(iLow(_Symbol,PERIOD_CURRENT,_b) <= g_fibRevL + revTol2) recentTouch = true;
     if(nearNow || recentTouch)
     { outLabel = nearNow ? "📍FLOOR-BUY@RevL" : "📍FLOOR-BUY@RevL(recent)";
       Log("✅ CASCADE REVERSAL|BUY near/at RevL during floor shift → FIB_EXEC_NOW");
       return FIB_EXEC_NOW; }
     Log("⚠️ FIB ADVISORY|BUY during floor shift|price not near RevL — blocked");
     outLabel="🚫FLOOR↓"; return FIB_BLOCKED; }
   if(g_fibWaitingNewFloor && direction==1)   // RevL==0 edge case
   { Log("⚠️ FIB ADVISORY|BUY during floor shift|no RevL — blocked");
     outLabel="🚫FLOOR↓"; return FIB_BLOCKED; }

   double buf=Fib_PDBuffer*GetPointsize();
   bool inDiscount  = (price<=g_fibLevel025+buf && price>=g_fibLevel0-buf*2);
   bool inPremium   = (price>=g_fibLevel075-buf && price<=g_fibLevel1+buf*2);
   bool inEquil     = (price>g_fibLevel025+buf && price<g_fibLevel075-buf);
   bool aboveCeiling= (price>g_fibLevel1+buf);
   bool belowFloor  = (price<g_fibLevel0-buf);

   outLabel = inDiscount?"📗DISCOUNT":inPremium?"📕PREMIUM":inEquil?"⚖️EQUIL":aboveCeiling?"🔺ABOVE1":"🔻BELOW0";

   if(g_fib.state==FIB_MANIP_UP  &&direction== 1) return FIB_WATCH_PO3;
   if(g_fib.state==FIB_MANIP_DOWN&&direction==-1) return FIB_WATCH_PO3;

   if(inEquil)
   { if(direction==1) Fib_ArmWatch(1,source,false);
     else             Fib_ArmWatch(-1,source,false);
     outLabel="⏳EQUIL→WATCH";
     return FIB_WATCH_WAIT; }

   // ── HTF TREND FILTER: gate entry direction by M12 fib state ─────
   // GOLDMINE (score≥9 checked externally) can override — handled in ExecuteSignal
   // Here we block weak/moderate counter-trend entries at the filter stage
   if(g_fib.state==FIB_TREND_DOWN)
   {
      // Downtrend: only BUY at 0.25 discount; SELL allowed only in premium or cascade
      if(direction==-1 && !inPremium && !g_fibWaitingNewFloor)
      { string bl=StringFormat("🚫 HTF TREND BLOCK|SELL in FIB_TREND_DOWN but not at 0.75 premium|price=%.5f|0.75=%.5f",
                  price, g_fibLevel075);
        Log(bl); outLabel="🚫HTF↓SELL_BLOCKED"; return FIB_BLOCKED; }
      if(direction==1 && !inDiscount && !inEquil && !g_fibWaitingNewFloor)
      { string bl=StringFormat("🚫 HTF TREND BLOCK|BUY in FIB_TREND_DOWN but not at 0.25 discount|price=%.5f|0.25=%.5f",
                  price, g_fibLevel025);
        Log(bl); outLabel="🚫HTF↓BUY_BLOCKED"; return FIB_BLOCKED; }
   }
   else if(g_fib.state==FIB_TREND_UP)
   {
      // Uptrend: only SELL at 0.75 premium; BUY allowed only in discount or cascade
      if(direction==1 && !inDiscount && !g_fibWaitingNewCeiling)
      { string bl=StringFormat("🚫 HTF TREND BLOCK|BUY in FIB_TREND_UP but not at 0.25 discount|price=%.5f|0.25=%.5f",
                  price, g_fibLevel025);
        Log(bl); outLabel="🚫HTF↑BUY_BLOCKED"; return FIB_BLOCKED; }
      if(direction==-1 && !inPremium && !inEquil && !g_fibWaitingNewCeiling)
      { string bl=StringFormat("🚫 HTF TREND BLOCK|SELL in FIB_TREND_UP but not at 0.75 premium|price=%.5f|0.75=%.5f",
                  price, g_fibLevel075);
        Log(bl); outLabel="🚫HTF↑SELL_BLOCKED"; return FIB_BLOCKED; }
   }
   // FIB_RANGE: both directions allowed at respective zones — no additional gate
   int zoneScore=0;
   if(direction==1&&inDiscount)   zoneScore=3;
   if(direction==1&&inPremium)    zoneScore=1;
   if(direction==1&&aboveCeiling) zoneScore=2;
   if(direction==1&&belowFloor)   zoneScore=1;
   if(direction==-1&&inPremium)   zoneScore=3;
   if(direction==-1&&inDiscount)  zoneScore=1;
   if(direction==-1&&belowFloor)  zoneScore=2;
   if(direction==-1&&aboveCeiling)zoneScore=1;
   if(PrintToLog&&zoneScore>0)
      Log(StringFormat("📐 FIB ZONE | %s | %s | zoneScore=%d",direction==1?"BUY":"SELL",outLabel,zoneScore));

   return FIB_EXEC_NOW;
}

string Fib_GetContextTag()
{ if(!g_fib.valid)return "";
  string st="";
  switch(g_fib.state){case FIB_RANGE:st="RANGE";break;case FIB_TREND_UP:st="TREND↑";break;
    case FIB_TREND_DOWN:st="TREND↓";break;case FIB_MANIP_UP:st="PO3↑";break;case FIB_MANIP_DOWN:st="PO3↓";break;default:st="?";}
  string fl=(g_fib.highFlipped?"|SBR":(g_fib.lowFlipped?"|RBS":""));
  return StringFormat("FIB:%s|0=%.5f|1=%.5f%s",st,g_fibLevel0,g_fibLevel1,fl);}

