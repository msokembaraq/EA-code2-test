// ── HEAD & SHOULDERS PATTERN DETECTION ───────────────────────────
double HS_HighBetween(int barOld, int barNew)
{ if(barNew > barOld) { int tmp=barOld; barOld=barNew; barNew=tmp; }
  double maxH=0;
  for(int i=barNew;i<=barOld;i++) maxH=MathMax(maxH,iHigh(_Symbol,PERIOD_CURRENT,i));
  return maxH; }

double HS_LowBetween(int barOld, int barNew)
{ if(barNew > barOld) { int tmp=barOld; barOld=barNew; barNew=tmp; }
  double minL=DBL_MAX;
  for(int i=barNew;i<=barOld;i++) minL=MathMin(minL,iLow(_Symbol,PERIOD_CURRENT,i));
  return minL; }

bool HS_NearZone(int direction, double price)
{ if(!HS_OnlyAtZones) return true;
  double tol = ScaledPip() * 200;
  if(direction==1  && g_fibRevL>0 && MathAbs(price-g_fibRevL)<=tol) return true;
  if(direction==-1 && g_fibRevH>0 && MathAbs(price-g_fibRevH)<=tol) return true;
  double sdZ[8]={g_fibRevL,g_fibLevN0644,g_fibSD1L,g_fibLevN125,
                 g_fibRevH,g_fibLev1644, g_fibSD1H,g_fibLev225H};
  for(int i=0;i<8;i++) if(sdZ[i]>0&&MathAbs(price-sdZ[i])<=tol) return true;
  return false; }

void HS_DetectPatterns()
{ if(!UseHSDetection) return;

  // ── NECKLINE INVALIDATION (item 8) ───────────────────────────
  double cl1=iClose(_Symbol,PERIOD_CURRENT,1);
  if(g_invHSDetected && cl1 < g_invHSNeckline)
  { g_invHSDetected=false; g_invHSNeckline=0;
    Log("❌ INV H&S INVALIDATED | price closed below neckline"); }
  if(g_hsDetected && cl1 > g_hsNeckline)
  { g_hsDetected=false; g_hsNeckline=0;
    Log("❌ H&S INVALIDATED | price closed above neckline"); }

  // ── FIND SWING LOWS (for Inverse H&S) ──────────────────────────
  int slBars[10]; double slPrices[10]; int slCount=0;
  ArrayInitialize(slBars,0); ArrayInitialize(slPrices,0);
  int prd=HS_PivotPeriod;
  for(int i=prd+1; i<HS_LookbackBars-prd && slCount<10; i++)
  { double lo=iLow(_Symbol,PERIOD_CURRENT,i); bool ok=true;
    for(int k=1;k<=prd&&ok;k++)
    { if(iLow(_Symbol,PERIOD_CURRENT,i-k)<=lo) ok=false;
      if(iLow(_Symbol,PERIOD_CURRENT,i+k)<=lo) ok=false; }
    if(ok){ slBars[slCount]=i; slPrices[slCount]=lo; slCount++; } }

  if(slCount>=3 && !g_invHSDetected)
  { double rS=slPrices[0], hd=slPrices[1], lS=slPrices[2];
    int    rB=slBars[0],   hB=slBars[1],   lB=slBars[2];
    bool headDeepest = (hd < rS && hd < lS);
    bool wideEnough  = (lB-rB >= HS_MinPatternBars);
    double avgH = ((rS-hd)+(lS-hd))/2.0;
    double symPct = (avgH>0) ? MathAbs(rS-lS)/avgH*100 : 999;
    bool symmetric = (symPct <= HS_ShoulderTolPct);
    if(headDeepest && wideEnough && symmetric && rS>hd)
    { double neckline = MathMin(HS_HighBetween(lB,hB), HS_HighBetween(hB,rB));
      bool atZone = HS_NearZone(1, hd);
      bool neckBroken = (cl1 > neckline);
      if(neckBroken && atZone)
      { g_invHSDetected=true; g_invHSNeckline=neckline;
        g_invHSHeadPrice=hd;  g_invHSBar=g_barCount;
        string msg=StringFormat("📐 INV H&S|%s|head=%.5f|neckline=%.5f|+3 score bonus active",_Symbol,hd,neckline);
        Log(msg); Notify(msg+"|✅NECKLINE BROKEN|awaiting ST confirmation",true); }
      else if(!g_invHSDetected && atZone && !neckBroken)
        Log(StringFormat("👀 INV H&S FORMING|head=%.5f|neckline=%.5f|waiting break",hd,neckline)); }}

  // ── FIND SWING HIGHS (for H&S) ─────────────────────────────────
  int shBars[10]; double shPrices[10]; int shCount=0;
  ArrayInitialize(shBars,0); ArrayInitialize(shPrices,0);
  for(int i=prd+1; i<HS_LookbackBars-prd && shCount<10; i++)
  { double hi=iHigh(_Symbol,PERIOD_CURRENT,i); bool ok=true;
    for(int k=1;k<=prd&&ok;k++)
    { if(iHigh(_Symbol,PERIOD_CURRENT,i-k)>=hi) ok=false;
      if(iHigh(_Symbol,PERIOD_CURRENT,i+k)>=hi) ok=false; }
    if(ok){ shBars[shCount]=i; shPrices[shCount]=hi; shCount++; } }

  if(shCount>=3 && !g_hsDetected)
  { double rS=shPrices[0], hd=shPrices[1], lS=shPrices[2];
    int    rB=shBars[0],   hB=shBars[1],   lB=shBars[2];
    bool headHighest = (hd > rS && hd > lS);
    bool wideEnough  = (lB-rB >= HS_MinPatternBars);
    double avgD = ((hd-rS)+(hd-lS))/2.0;
    double symPct = (avgD>0) ? MathAbs(rS-lS)/avgD*100 : 999;
    bool symmetric = (symPct <= HS_ShoulderTolPct);
    if(headHighest && wideEnough && symmetric && rS<hd)
    { double neckline = MathMax(HS_LowBetween(lB,hB), HS_LowBetween(hB,rB));
      bool atZone = HS_NearZone(-1, hd);
      bool neckBroken = (cl1 < neckline);
      if(neckBroken && atZone)
      { g_hsDetected=true; g_hsNeckline=neckline;
        g_hsHeadPrice=hd;  g_hsBar=g_barCount;
        string msg=StringFormat("📐 H&S|%s|head=%.5f|neckline=%.5f|+3 score bonus active",_Symbol,hd,neckline);
        Log(msg); Notify(msg+"|✅NECKLINE BROKEN|awaiting ST confirmation",true); }
      else if(!g_hsDetected && atZone && !neckBroken)
        Log(StringFormat("👀 H&S FORMING|head=%.5f|neckline=%.5f|waiting break",hd,neckline)); }}

  // 50-bar timeout
  if(g_invHSDetected && g_barCount-g_invHSBar > 50)
  { g_invHSDetected=false; g_invHSNeckline=0; }
  if(g_hsDetected    && g_barCount-g_hsBar    > 50)
  { g_hsDetected=false;    g_hsNeckline=0; }}

