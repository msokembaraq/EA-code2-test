      // Update high water mark
      if(d2==POSITION_TYPE_BUY){if(cp>g_unifiedPositions[i].highWaterMark)g_unifiedPositions[i].highWaterMark=cp;}
      else                     {if(cp<g_unifiedPositions[i].highWaterMark)g_unifiedPositions[i].highWaterMark=cp;}

      // ── BE PHASE ──────────────────────────────────────────────────
      if(!g_unifiedPositions[i].beDone)
      {
         // Only update riskDistance from live hard SL — VirtualSL path uses enrolled value
         if(cSL > 0)
         { double liveDist = MathAbs(op - cSL);
           if(liveDist > 0) g_unifiedPositions[i].riskDistance = liveDist; }
         double rd = g_unifiedPositions[i].riskDistance;
         if(rd <= 0) continue;
         double r = GetUnifiedR(g_unifiedPositions[i].ticket, op, rd, d2);
         if(r >= TriggerBE_R)
         {
            double be = (d2==POSITION_TYPE_BUY) ? NormalizeDouble(op+cush,dg)
                                                 : NormalizeDouble(op-cush,dg);
            bool improving = (d2==POSITION_TYPE_BUY) ? (be > cSL+pip) : (be < cSL-pip);
            if(improving && MathAbs(cp-be) >= minSt)
            { if(trade.PositionModify(g_unifiedPositions[i].ticket, be, cTP))
              { g_unifiedPositions[i].beDone=true; beCount++; beAvgR+=r; beSL=be; } }
            else
            { g_unifiedPositions[i].beDone=true; bePassedCount++; beAvgR+=r; }
         }
         continue;
      }

      // ── TRAIL PHASE ───────────────────────────────────────────────
      if(!UseCandleTrail) continue;
      if(cSL <= 0) continue;

      if(d2 == POSITION_TYPE_BUY)
      {
         if(!bar1Bull) continue;
         double newSL = NormalizeDouble(bar1Low, dg);
         if(newSL <= cSL + pip) continue;
         if(newSL <= op)        continue;   // never trail below entry
         if(cp - newSL < minSt) continue;
         if(trade.PositionModify(g_unifiedPositions[i].ticket, newSL, cTP))
         { trailBuyCount++; trailBuyNewSL=newSL; }
      }
      else
      {
         if(!bar1Bear) continue;
         double newSL = NormalizeDouble(bar1High, dg);
         if(newSL >= cSL - pip) continue;
         if(newSL >= op)        continue;   // never trail above entry
         if(newSL - cp < minSt) continue;
         if(trade.PositionModify(g_unifiedPositions[i].ticket, newSL, cTP))
         { trailSellCount++; trailSellNewSL=newSL; }
      }
   }

   // ── SUMMARY LOGS — one line per event type per bar ───────────────
   if(beCount>0)
      Log(StringFormat("🛡️ BE | %d trade%s | avg R=%.2f | SL→%.5f",
          beCount, beCount>1?"s":"", beAvgR/beCount, beSL));
   if(bePassedCount>0)
      Log(StringFormat("🛡️ BE PASSED | %d trade%s already protected | avg R=%.2f",
          bePassedCount, bePassedCount>1?"s":"", beAvgR/bePassedCount));
   if(trailBuyCount>0)
      Log(StringFormat("📉 TRAIL BUY | %d trade%s | SL→%.5f",
          trailBuyCount, trailBuyCount>1?"s":"", trailBuyNewSL));
   if(trailSellCount>0)
      Log(StringFormat("📈 TRAIL SELL | %d trade%s | SL→%.5f",
          trailSellCount, trailSellCount>1?"s":"", trailSellNewSL));
}

