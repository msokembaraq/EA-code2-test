// Source priority lookup — lower number = higher priority
int WatchSourcePriority(string source)
{
   if(StringFind(source,"FIB2-SBR")>=0) return 1;
   if(StringFind(source,"FIB2-RBS")>=0) return 1;
   if(StringFind(source,"FIB2-FLIP")>=0) return 1; // legacy fallback
   if(StringFind(source,"FIB1-FLIP")>=0) return 1;
   if(StringFind(source,"ROLE-FLIP")>=0) return 2;
   if(StringFind(source,"SD-")>=0) return 3;
   return 4;
}

