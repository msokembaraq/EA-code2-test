   bool   bar1Bull  = (bar1Close > bar1Open);   // bullish candle just closed
   bool   bar1Bear  = (bar1Close < bar1Open);   // bearish candle just closed

   // Batch counters for summary logs
   int    beCount=0; double beAvgR=0; double beSL=0;
   int    trailBuyCount=0; double trailBuyNewSL=0;
   int    trailSellCount=0; double trailSellNewSL=0;
   int    bePassedCount=0;

   for(int i=0; i<g_unifiedPosCount; i++)
   {
      if(!PositionSelectByTicket(g_unifiedPositions[i].ticket)) continue;

      int    d2  = g_unifiedPositions[i].direction;
      double op  = g_unifiedPositions[i].openPrice;
      double cp  = PositionGetDouble(POSITION_PRICE_CURRENT);
      double cSL = PositionGetDouble(POSITION_SL);
