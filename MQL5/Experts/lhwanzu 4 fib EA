double GetMinStop()
{
   double pt = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   long   sl = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
   long   fl = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_FREEZE_LEVEL);
   return (double)MathMax(sl,fl)*pt + pt;
}

ENUM_ORDER_TYPE_FILLING GetFill()
{
   long fm = SymbolInfoInteger(_Symbol, SYMBOL_FILLING_MODE);
   if((fm & ORDER_FILLING_FOK)    != 0) return ORDER_FILLING_FOK;
   if((fm & ORDER_FILLING_IOC)    != 0) return ORDER_FILLING_IOC;
   if((fm & ORDER_FILLING_RETURN) != 0) return ORDER_FILLING_RETURN;
   return ORDER_FILLING_IOC;
}

double GetPointsize() { return SymbolInfoDouble(_Symbol, SYMBOL_POINT); }

// ScaledPip — use for ALL buffer/tolerance calculations
// Automatically scales for high-value instruments (BTC, etc.)
// Same as GetPointsize() on XAUUSD, larger on BTC
double ScaledPip() { return GetPointsize() * g_priceScalar; }

double GetATRSlDist()
{
   double mn=GetMinStop(), raw=0;
   double buf[1];
   if(g_stATRHandle!=INVALID_HANDLE && CopyBuffer(g_stATRHandle,0,1,1,buf)>0) raw=buf[0];
   if(raw<=0) return 0;
   return MathMax(raw*ATR_SL_Multiplier, mn);
}

double GetSTATR(int shift=1)
{
   if(ST_UseWilderATR)
   { if(g_stATRHandle==INVALID_HANDLE) return 0;
     double buf[1]; if(CopyBuffer(g_stATRHandle,0,shift,1,buf)<=0) return 0; return buf[0]; }
   double sum=0;
   for(int i=shift; i<shift+ST_ATR_Periods; i++)
   { double hi=iHigh(_Symbol,PERIOD_CURRENT,i), lo=iLow(_Symbol,PERIOD_CURRENT,i), pc=iClose(_Symbol,PERIOD_CURRENT,i+1);
     sum+=MathMax(hi-lo, MathMax(MathAbs(hi-pc), MathAbs(lo-pc))); }
   return sum/ST_ATR_Periods;
}

int GetLowerWickRatio(int index)
{
   double o=iOpen(_Symbol,PERIOD_CURRENT,index), c=iClose(_Symbol,PERIOD_CURRENT,index);
   double h=iHigh(_Symbol,PERIOD_CURRENT,index), l=iLow(_Symbol,PERIOD_CURRENT,index);
   double range=h-l; if(range<=0) return 0;
   return (int)((MathMin(o,c)-l)/range*100);
}

int GetUpperWickRatio(int index)
{
   double o=iOpen(_Symbol,PERIOD_CURRENT,index), c=iClose(_Symbol,PERIOD_CURRENT,index);
   double h=iHigh(_Symbol,PERIOD_CURRENT,index), l=iLow(_Symbol,PERIOD_CURRENT,index);
   double range=h-l; if(range<=0) return 0;
   return (int)((h-MathMax(o,c))/range*100);
}

//| SUPERTREND ENGINE                                               |
int UpdateSuperTrend()
{
   double atr=GetSTATR(1); if(atr<=0) return 0;
   double hi=iHigh(_Symbol,PERIOD_CURRENT,1), lo=iLow(_Symbol,PERIOD_CURRENT,1), cl=iClose(_Symbol,PERIOD_CURRENT,1);
   double src=(hi+lo)/2.0, pbc=iClose(_Symbol,PERIOD_CURRENT,2);
   double ru=src-ST_Multiplier*atr, rd=src+ST_Multiplier*atr, nu, nd;
   if(g_st_up_prev==0){nu=ru; nd=rd;}
   else{nu=(pbc>g_st_up_prev)?MathMax(ru,g_st_up_prev):ru; nd=(pbc<g_st_dn_prev)?MathMin(rd,g_st_dn_prev):rd;}
   int pt=g_st_trend;
   g_st_up_prev=g_st_up; g_st_dn_prev=g_st_dn; g_st_up=nu; g_st_dn=nd;
   if(g_st_trend==0) g_st_trend=(cl>nd)?1:-1;
   else if(g_st_trend==-1&&cl>g_st_dn_prev) g_st_trend=1;
   else if(g_st_trend== 1&&cl<g_st_up_prev) g_st_trend=-1;
   int flip=0; if(g_st_trend==1&&pt==-1)flip=1; if(g_st_trend==-1&&pt==1)flip=-1;
   static uint sn=0; sn++;
   if(PrintToLog&&(sn<=10||flip!=0))
      Print("═══ ST #",sn," bar=",g_barCount," trend=",pt,"→",g_st_trend," FLIP=",flip);
   return flip;
}

//| SR CHANNEL SYSTEM (M5)                                          |
double SR_CalcChannelWidth()
{
   int scan=MathMin(300, iBars(_Symbol,PERIOD_CURRENT)-1);
   double hi=-DBL_MAX, lo=DBL_MAX;
   for(int i=0;i<scan;i++)
   { double h=iHigh(_Symbol,PERIOD_CURRENT,i), l=iLow(_Symbol,PERIOD_CURRENT,i);
     if(h>hi)hi=h; if(l<lo)lo=l; }
   if(hi<=lo||hi==-DBL_MAX) return 0;
   return (hi-lo)*SR_ChannelWidthPct/100.0;
}

void SR_GetSRVals(int ind, double cwidth, double &hi, double &lo, int &numpp)
{
   hi=g_srPivotVals[ind]; lo=g_srPivotVals[ind]; numpp=0;
   for(int y=0;y<g_srPivotCount;y++)
   { double cpp=g_srPivotVals[y];
     double wdth=(cpp<=hi)?(hi-cpp):(cpp-lo);
     if(wdth<=cwidth){if(cpp<=hi)lo=MathMin(lo,cpp);else hi=MathMax(hi,cpp);numpp+=20;} }
}

void SR_BuildChannels()
{
   if(!UseSRChannels||g_srPivotCount==0){g_srChannelCount=0;return;}
   double cwidth=SR_CalcChannelWidth(); if(cwidth<=0) return;
   int n=g_srPivotCount;
   double sStr[500],sHi[500],sLo[500];
   for(int x=0;x<n;x++){double h;double l;int np;SR_GetSRVals(x,cwidth,h,l,np);sStr[x]=(double)np;sHi[x]=h;sLo[x]=l;}
   int sb=MathMin(SR_Loopback,iBars(_Symbol,PERIOD_CURRENT)-1);
   for(int x=0;x<n;x++)
   { double h=sHi[x];double l=sLo[x];int s=0;
     for(int y=0;y<=sb;y++){double bH=iHigh(_Symbol,PERIOD_CURRENT,y),bL=iLow(_Symbol,PERIOD_CURRENT,y);
       if((bH<=h&&bH>=l)||(bL<=h&&bL>=l))s++;}
     sStr[x]+=s;}
   double sT[10],sB[10],sSt[10];int sc=0;
   int mc=MathMin(MathMin(SR_MaxChannels,10),n);
   for(int x=0;x<mc;x++)
   { double stv=-1.0;int stl=-1;
     for(int y=0;y<n;y++) if(sStr[y]>stv&&sStr[y]>=(double)(SR_MinStrength*20)){stv=sStr[y];stl=y;}
     if(stl<0) break;
     double hh=sHi[stl],ll=sLo[stl];
     if(hh-ll<GetPointsize()*5)continue;
     sT[sc]=hh;sB[sc]=ll;sSt[sc]=stv;sc++;
     for(int y=0;y<n;y++){bool ti=(sHi[y]<=hh&&sHi[y]>=ll),bi=(sLo[y]<=hh&&sLo[y]>=ll);if(ti||bi)sStr[y]=-1.0;}}
   for(int x=0;x<sc-1;x++) for(int y=x+1;y<sc;y++) if(sSt[y]>sSt[x])
   {double t;t=sSt[y];sSt[y]=sSt[x];sSt[x]=t;t=sT[y];sT[y]=sT[x];sT[x]=t;t=sB[y];sB[y]=sB[x];sB[x]=t;}
   g_srChannelCount=sc;
   for(int i=0;i<sc;i++){g_srChannels[i].top=sT[i];g_srChannels[i].bottom=sB[i];g_srChannels[i].strength=(int)sSt[i];}
   if(PrintToLog) Print(StringFormat("📊 SR Channels: %d zones | pivots=%d",g_srChannelCount,g_srPivotCount));
}

bool SR_DetectPivot()
{
   if(!UseSRChannels) return false;
   int total=iBars(_Symbol,PERIOD_CURRENT); if(total<SR_PivotPeriod*2+3) return false;
   bool np=false; int prd=SR_PivotPeriod;
   double s1=SR_UseHighLow?iHigh(_Symbol,PERIOD_CURRENT,prd):MathMax(iClose(_Symbol,PERIOD_CURRENT,prd),iOpen(_Symbol,PERIOD_CURRENT,prd));
   bool isPH=true;
   for(int k=1;k<=prd&&isPH;k++)
   { if(prd-k<0||prd+k>=total){isPH=false;break;}
     double lv=SR_UseHighLow?iHigh(_Symbol,PERIOD_CURRENT,prd+k):MathMax(iClose(_Symbol,PERIOD_CURRENT,prd+k),iOpen(_Symbol,PERIOD_CURRENT,prd+k));
     double rv=SR_UseHighLow?iHigh(_Symbol,PERIOD_CURRENT,prd-k):MathMax(iClose(_Symbol,PERIOD_CURRENT,prd-k),iOpen(_Symbol,PERIOD_CURRENT,prd-k));
     if(lv>=s1||rv>=s1) isPH=false;}
   if(isPH){bool ex=false;for(int k=0;k<g_srPivotCount;k++) if(g_srPivotBars[k]==g_barCount&&MathAbs(g_srPivotVals[k]-s1)<_Point){ex=true;break;}
     if(!ex&&g_srPivotCount<500){g_srPivotVals[g_srPivotCount]=s1;g_srPivotBars[g_srPivotCount]=g_barCount;g_srPivotCount++;np=true;
       Log(StringFormat("📍 SR Pivot H @ %.5f",s1));}}
   double s2=SR_UseHighLow?iLow(_Symbol,PERIOD_CURRENT,prd):MathMin(iClose(_Symbol,PERIOD_CURRENT,prd),iOpen(_Symbol,PERIOD_CURRENT,prd));
   bool isPL=true;
   for(int k=1;k<=prd&&isPL;k++)
   { if(prd-k<0||prd+k>=total){isPL=false;break;}
     double lv=SR_UseHighLow?iLow(_Symbol,PERIOD_CURRENT,prd+k):MathMin(iClose(_Symbol,PERIOD_CURRENT,prd+k),iOpen(_Symbol,PERIOD_CURRENT,prd+k));
     double rv=SR_UseHighLow?iLow(_Symbol,PERIOD_CURRENT,prd-k):MathMin(iClose(_Symbol,PERIOD_CURRENT,prd-k),iOpen(_Symbol,PERIOD_CURRENT,prd-k));
     if(lv<=s2||rv<=s2) isPL=false;}
   if(isPL){bool ex=false;for(int k=0;k<g_srPivotCount;k++) if(g_srPivotBars[k]==g_barCount&&MathAbs(g_srPivotVals[k]-s2)<_Point){ex=true;break;}
     if(!ex&&g_srPivotCount<500){g_srPivotVals[g_srPivotCount]=s2;g_srPivotBars[g_srPivotCount]=g_barCount;g_srPivotCount++;np=true;
       Log(StringFormat("📍 SR Pivot L @ %.5f",s2));}}
   for(int i=g_srPivotCount-1;i>=0;i--)
     if(g_barCount-g_srPivotBars[i]>SR_Loopback)
     {for(int j=i;j<g_srPivotCount-1;j++){g_srPivotVals[j]=g_srPivotVals[j+1];g_srPivotBars[j]=g_srPivotBars[j+1];}g_srPivotCount--;np=true;}
   return np;
}

void SR_BackfillPivots()
{
   if(!UseSRChannels) return;
   int total=iBars(_Symbol,PERIOD_CURRENT), sr=SR_Loopback+SR_PivotPeriod;
   if(total<sr+SR_PivotPeriod+3){Print("⚠️ SR Backfill: insufficient bars");return;}
   Print("💾 SR Backfill scanning ",sr," bars...");
   for(int bar=sr;bar>=SR_PivotPeriod&&g_srPivotCount<500;bar--)
   { int prd=SR_PivotPeriod, sb2=g_barCount-bar;
     double s1c=SR_UseHighLow?iHigh(_Symbol,PERIOD_CURRENT,bar):MathMax(iClose(_Symbol,PERIOD_CURRENT,bar),iOpen(_Symbol,PERIOD_CURRENT,bar));
     bool ph=true;
     for(int k=1;k<=prd&&ph;k++){if(bar-k<0||bar+k>=total){ph=false;break;}
       double lv=SR_UseHighLow?iHigh(_Symbol,PERIOD_CURRENT,bar+k):MathMax(iClose(_Symbol,PERIOD_CURRENT,bar+k),iOpen(_Symbol,PERIOD_CURRENT,bar+k));
       double rv=SR_UseHighLow?iHigh(_Symbol,PERIOD_CURRENT,bar-k):MathMax(iClose(_Symbol,PERIOD_CURRENT,bar-k),iOpen(_Symbol,PERIOD_CURRENT,bar-k));
       if(lv>=s1c||rv>=s1c)ph=false;}
     if(ph){bool ex=false;for(int k=0;k<g_srPivotCount;k++) if(g_srPivotBars[k]==sb2&&MathAbs(g_srPivotVals[k]-s1c)<_Point){ex=true;break;}
       if(!ex){g_srPivotVals[g_srPivotCount]=s1c;g_srPivotBars[g_srPivotCount]=sb2;g_srPivotCount++;}}
     if(g_srPivotCount>=500) break;
     double s2c=SR_UseHighLow?iLow(_Symbol,PERIOD_CURRENT,bar):MathMin(iClose(_Symbol,PERIOD_CURRENT,bar),iOpen(_Symbol,PERIOD_CURRENT,bar));
     bool pl=true;
     for(int k=1;k<=prd&&pl;k++){if(bar-k<0||bar+k>=total){pl=false;break;}
       double lv=SR_UseHighLow?iLow(_Symbol,PERIOD_CURRENT,bar+k):MathMin(iClose(_Symbol,PERIOD_CURRENT,bar+k),iOpen(_Symbol,PERIOD_CURRENT,bar+k));
       double rv=SR_UseHighLow?iLow(_Symbol,PERIOD_CURRENT,bar-k):MathMin(iClose(_Symbol,PERIOD_CURRENT,bar-k),iOpen(_Symbol,PERIOD_CURRENT,bar-k));
       if(lv<=s2c||rv<=s2c)pl=false;}
     if(pl){bool ex=false;for(int k=0;k<g_srPivotCount;k++) if(g_srPivotBars[k]==sb2&&MathAbs(g_srPivotVals[k]-s2c)<_Point){ex=true;break;}
       if(!ex){g_srPivotVals[g_srPivotCount]=s2c;g_srPivotBars[g_srPivotCount]=sb2;g_srPivotCount++;}}}
   Print(StringFormat("💾 SR Backfill: %d pivots — building channels...",g_srPivotCount));
   SR_BuildChannels();
}

string SR_GetConfluenceTag(int direction, double price)
{
   if(!UseSRChannels||g_srChannelCount==0) return "";
   double pip=ScaledPip(), buf=SR_ConfluenceBuffer*pip;
   double bestDist=DBL_MAX; int bestIdx=-1; string bestTag="";
   for(int i=0;i<g_srChannelCount;i++)
   { double top=g_srChannels[i].top, bot=g_srChannels[i].bottom;
     int str=g_srChannels[i].strength; double zH=top-bot;
     if(zH<=0)continue;
     double dist=DBL_MAX; string tag="";
     if(direction==1)
     { if(price>top&&price-top<=buf){dist=price-top;tag=StringFormat("⬆️SR-SUP[str=%d]",str);}
       else if(price>=bot&&price<=top&&(price-bot)/zH<=0.5){dist=price-bot;tag=StringFormat("⬆️SR-SUP[str=%d]",str);}}
     else
     { if(price<bot&&bot-price<=buf){dist=bot-price;tag=StringFormat("⬇️SR-RES[str=%d]",str);}
       else if(price>=bot&&price<=top&&(price-bot)/zH>=0.5){dist=top-price;tag=StringFormat("⬇️SR-RES[str=%d]",str);}}
     if(tag!=""&&dist<bestDist){bestDist=dist;bestIdx=i;bestTag=tag;}}
   if(bestIdx>=0)
   { static int lastSRLog=0;
     if(g_barCount-lastSRLog>5)
     { lastSRLog=g_barCount;
       Log(StringFormat("📍 SR MATCH: %s @ %.5f → zone[%.5f-%.5f] str=%d dist=%.1fpts",
