void CalcLevels(int dir, double entry, double &slOut, double &tp1Out, double &tp2Out, double &tp3Out)
{
   int dg=(int)SymbolInfoInteger(_Symbol,SYMBOL_DIGITS);
   double pip=ScaledPip(),mn=GetMinStop(),slD=0;
   if(UseATRBasedSL){double a=GetATRSlDist();slD=(a>0)?a:MathMax(SL_Points*pip,mn);}
   else slD=(SL_Points>0)?MathMax(SL_Points*pip,mn):0;
   double j1=(MathRand()%41-20)/100.0,j2=(MathRand()%41-20)/100.0,j3=(MathRand()%41-20)/100.0;
   if(dir==1)
   { slOut=(slD>0)?NormalizeDouble(entry-slD,dg):0;
     tp1Out=NormalizeDouble(MathMax(entry+mn,entry+TP1_Points*pip*(1.0+j1)),dg);
     tp2Out=NormalizeDouble(MathMax(tp1Out+mn,entry+TP2_Points*pip*(1.0+j2)),dg);
     tp3Out=NormalizeDouble(MathMax(tp2Out+mn,entry+TP3_Points*pip*(1.0+j3)),dg);}
   else
   { slOut=(slD>0)?NormalizeDouble(entry+slD,dg):0;
     tp1Out=NormalizeDouble(MathMin(entry-mn,entry-TP1_Points*pip*(1.0-j1)),dg);
     tp2Out=NormalizeDouble(MathMin(tp1Out-mn,entry-TP2_Points*pip*(1.0-j2)),dg);
     tp3Out=NormalizeDouble(MathMin(tp2Out-mn,entry-TP3_Points*pip*(1.0-j3)),dg);}
}

