   g_fibRevL=0;g_fibLevN0644=0;g_fibSD1L=0;g_fibLevN125=0;g_fibSD2L=0;g_fibLevN20=0;g_fibLevN225=0;g_fibLevN25=0;
   g_lastFibHTFBar=0;
   g_inConsolidation=false; g_consolHigh=0; g_consolLow=0; g_adrValue=0;
}

//| SR M30 CHANNEL SYSTEM                                           |
double SR_M30_CalcChannelWidth()
{
   int scan=MathMin(SR_M30_Loopback,iBars(_Symbol,Fib_HTF2)-1);
   double hi=-DBL_MAX,lo=DBL_MAX;
   for(int i=0;i<scan;i++)
   { double h=iHigh(_Symbol,Fib_HTF2,i),l=iLow(_Symbol,Fib_HTF2,i);if(h>hi)hi=h;if(l<lo)lo=l;}
   if(hi<=lo||hi==-DBL_MAX)return 0;
   return (hi-lo)*SR_ChannelWidthPct/100.0;
}

void SR_M30_BuildChannels()
{
   if(g_srM30PivotCount==0){g_srM30ChannelCount=0;return;}
   double cwidth=SR_M30_CalcChannelWidth();if(cwidth<=0)return;
   int n=g_srM30PivotCount;
   double sStr[200],sHi[200],sLo[200];
   for(int x=0;x<n;x++)
   { double h=g_srM30PivotVals[x],l=g_srM30PivotVals[x];int np=0;
     for(int y=0;y<n;y++)
     { double cp=g_srM30PivotVals[y],wd=(cp<=h)?(h-cp):(cp-l);
       if(wd<=cwidth){if(cp<=h)l=MathMin(l,cp);else h=MathMax(h,cp);np+=20;}}
     sStr[x]=(double)np;sHi[x]=h;sLo[x]=l;}
   int sb=MathMin(SR_M30_Loopback,iBars(_Symbol,Fib_HTF2)-1);
   for(int x=0;x<n;x++)
   { double h=sHi[x],l=sLo[x];int s=0;
     for(int y=0;y<=sb;y++){double bH=iHigh(_Symbol,Fib_HTF2,y),bL=iLow(_Symbol,Fib_HTF2,y);
       if((bH<=h&&bH>=l)||(bL<=h&&bL>=l))s++;}
     sStr[x]+=(double)s;}
   double sT[10],sB[10],sSt[10];int sc=0;
   int mc=MathMin(MathMin(SR_MaxChannels,10),n);
   for(int x=0;x<mc;x++)
   { double stv=-1.0;int stl=-1;
     for(int y=0;y<n;y++) if(sStr[y]>stv&&sStr[y]>=(double)(SR_MinStrength*20)){stv=sStr[y];stl=y;}
     if(stl<0)break;
     double hh=sHi[stl],ll=sLo[stl];if(hh-ll<GetPointsize()*5)continue;
     sT[sc]=hh;sB[sc]=ll;sSt[sc]=stv;sc++;
     for(int y=0;y<n;y++){bool ti=(sHi[y]<=hh&&sHi[y]>=ll),bi=(sLo[y]<=hh&&sLo[y]>=ll);if(ti||bi)sStr[y]=-1.0;}}
   for(int x=0;x<sc-1;x++) for(int y=x+1;y<sc;y++) if(sSt[y]>sSt[x])
   {double t;t=sSt[y];sSt[y]=sSt[x];sSt[x]=t;t=sT[y];sT[y]=sT[x];sT[x]=t;t=sB[y];sB[y]=sB[x];sB[x]=t;}
   g_srM30ChannelCount=sc;
   for(int i=0;i<sc;i++){g_srM30Channels[i].top=sT[i];g_srM30Channels[i].bottom=sB[i];g_srM30Channels[i].strength=(int)sSt[i];}
   Log(StringFormat("📊 M30 SR: %d zones | pivots=%d",g_srM30ChannelCount,g_srM30PivotCount));
}

bool SR_M30_DetectPivot()
{
   int total=iBars(_Symbol,Fib_HTF2);if(total<SR_M30_PivotPeriod*2+3)return false;
   bool np=false;int prd=SR_M30_PivotPeriod;
   double s1=iHigh(_Symbol,Fib_HTF2,prd);bool isPH=true;
   for(int k=1;k<=prd&&isPH;k++)
   { if(prd-k<0||prd+k>=total){isPH=false;break;}
     if(iHigh(_Symbol,Fib_HTF2,prd+k)>=s1||iHigh(_Symbol,Fib_HTF2,prd-k)>=s1)isPH=false;}
   if(isPH){bool ex=false;for(int k=0;k<g_srM30PivotCount;k++) if(MathAbs(g_srM30PivotVals[k]-s1)<_Point){ex=true;break;}
     if(!ex&&g_srM30PivotCount<200){g_srM30PivotVals[g_srM30PivotCount]=s1;g_srM30PivotBars[g_srM30PivotCount]=g_barCount;g_srM30PivotCount++;np=true;}}
   double s2=iLow(_Symbol,Fib_HTF2,prd);bool isPL=true;
   for(int k=1;k<=prd&&isPL;k++)
   { if(prd-k<0||prd+k>=total){isPL=false;break;}
     if(iLow(_Symbol,Fib_HTF2,prd+k)<=s2||iLow(_Symbol,Fib_HTF2,prd-k)<=s2)isPL=false;}
   if(isPL){bool ex=false;for(int k=0;k<g_srM30PivotCount;k++) if(MathAbs(g_srM30PivotVals[k]-s2)<_Point){ex=true;break;}
     if(!ex&&g_srM30PivotCount<200){g_srM30PivotVals[g_srM30PivotCount]=s2;g_srM30PivotBars[g_srM30PivotCount]=g_barCount;g_srM30PivotCount++;np=true;}}
   for(int i=g_srM30PivotCount-1;i>=0;i--)
     if(g_barCount-g_srM30PivotBars[i]>SR_M30_Loopback)
     {for(int j=i;j<g_srM30PivotCount-1;j++){g_srM30PivotVals[j]=g_srM30PivotVals[j+1];g_srM30PivotBars[j]=g_srM30PivotBars[j+1];}g_srM30PivotCount--;np=true;}
   return np;
}

void SR_M30_BackfillPivots()
{
   int total=iBars(_Symbol,Fib_HTF2),sr=SR_M30_Loopback+SR_M30_PivotPeriod;
   if(total<sr+SR_M30_PivotPeriod+3){Print("⚠️ M30 SR Backfill: insufficient bars");return;}
   Print("💾 M30 SR Backfill: scanning ",sr," bars...");
   for(int bar=sr;bar>=SR_M30_PivotPeriod&&g_srM30PivotCount<200;bar--)
   { int barAge=g_barCount-bar;
     double s1c=iHigh(_Symbol,Fib_HTF2,bar);bool ph=true;
     for(int k=1;k<=SR_M30_PivotPeriod&&ph;k++){if(bar-k<0||bar+k>=total){ph=false;break;}
       if(iHigh(_Symbol,Fib_HTF2,bar+k)>=s1c||iHigh(_Symbol,Fib_HTF2,bar-k)>=s1c)ph=false;}
     if(ph){bool ex=false;for(int k=0;k<g_srM30PivotCount;k++) if(MathAbs(g_srM30PivotVals[k]-s1c)<_Point){ex=true;break;}
       if(!ex){g_srM30PivotVals[g_srM30PivotCount]=s1c;g_srM30PivotBars[g_srM30PivotCount]=barAge;g_srM30PivotCount++;}}
     if(g_srM30PivotCount>=200)break;
     double s2c=iLow(_Symbol,Fib_HTF2,bar);bool pl=true;
     for(int k=1;k<=SR_M30_PivotPeriod&&pl;k++){if(bar-k<0||bar+k>=total){pl=false;break;}
       if(iLow(_Symbol,Fib_HTF2,bar+k)<=s2c||iLow(_Symbol,Fib_HTF2,bar-k)<=s2c)pl=false;}
     if(pl){bool ex=false;for(int k=0;k<g_srM30PivotCount;k++) if(MathAbs(g_srM30PivotVals[k]-s2c)<_Point){ex=true;break;}
       if(!ex){g_srM30PivotVals[g_srM30PivotCount]=s2c;g_srM30PivotBars[g_srM30PivotCount]=barAge;g_srM30PivotCount++;}}}
   Print(StringFormat("💾 M30 SR Backfill: %d pivots — building channels...",g_srM30PivotCount));
   SR_M30_BuildChannels();
}

