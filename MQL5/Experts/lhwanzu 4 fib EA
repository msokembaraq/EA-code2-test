//| EXECUTE SIGNAL                                                  |
void ExecuteSignal(int direction, double signalClose)
{
   // Bar guard — prevent duplicate execution same bar same direction
   static int lastExecBarBuy  = 0;
   static int lastExecBarSell = 0;
   if(direction== 1 && g_barCount==lastExecBarBuy)  { Log("⏭️ ExecuteSignal BUY  skipped — already executed bar "+IntegerToString(g_barCount)); return; }
   if(direction==-1 && g_barCount==lastExecBarSell) { Log("⏭️ ExecuteSignal SELL skipped — already executed bar "+IntegerToString(g_barCount)); return; }
   if(direction== 1) lastExecBarBuy  = g_barCount;
   if(direction==-1) lastExecBarSell = g_barCount;
   int dg=(int)SymbolInfoInteger(_Symbol,SYMBOL_DIGITS);
   double ep=(direction==1)?SymbolInfoDouble(_Symbol,SYMBOL_ASK):SymbolInfoDouble(_Symbol,SYMBOL_BID);

   // CONSOLIDATION GATE — ST suppressed in range mode
   // Zone touches handled exclusively by Range_CheckZoneTouches()
   if(g_inConsolidation)
   { Log(StringFormat("📦 RANGE MODE | ST suppressed | %s | zone watches only",
         direction==1?"BUY":"SELL"));
     return; }

   // MTF Gate — M30 SR
   string mtfSRReason="";
   if(!SR_M30_ContextOK(direction,ep,mtfSRReason)){Log(mtfSRReason);Notify(mtfSRReason);return;}

   // SR tag — confluence only, not blocking
   string srConf=SR_GetConfluenceTag(direction,ep);

   // M12 Fib zone — HARD GATE (wrong zone or no anchor = block)
   double sl,tp1,tp2,tp3;
   string fPL=""; ENUM_FIB_FILTER fR=Fib_FilterSignal(direction,ep,"ST",fPL);
   string fCtx=g_fib.valid?"|"+fPL+"|"+Fib_GetContextTag():"";
   string mtfCtx="";
   string emoji=(direction==1)?"🟢":"🔴", dirStr=(direction==1)?"BUY":"SELL";

   if(fR==FIB_BLOCKED)
   {
      // GOLDMINE override — compute score first, allow if ≥9
      if(g_fib.valid)
      { int overrideScore = Fib_ScoreZoneEntry(direction,ep,1);
        if(overrideScore >= Fib_EntryMinScore)
        { Log(StringFormat("⚡ HTF BLOCK OVERRIDDEN | score=%d >= min=%d | %s", overrideScore, Fib_EntryMinScore, fPL));
          Notify(StringFormat("⚡ HTF BLOCK OVERRIDDEN|%s|score=%d|%s", _Symbol, overrideScore, fPL));
          fR = FIB_EXEC_NOW; }
        else { return; } }
      else { return; }
   }

   // Route to fib structure TPs (default) or fixed points based on TPMode input
   CalcTP(direction, ep, sl, tp1, tp2, tp3);

   // Score the entry — all 6 confluences
   int entryScore = g_fib.valid ? Fib_ScoreZoneEntry(direction,ep,1) : 0;
   string grade   = (entryScore>=13)?"🏆PERFECT":
                    (entryScore>=9) ?"💎GOLDMINE":
                    (entryScore>=6) ?"✅STRONG":
                    (entryScore>=4) ?"📊MODERATE":"⚠️WEAK";

   // ── HARD DIRECTION BLOCK ─────────────────────────────────────────
   // SELL in discount (below 0.5) = wrong side → block
   // BUY in premium (above 0.5) = wrong side → block
   //   1. GOLDMINE score (>=9) → overrides structure
   //   2. Active breakdown (g_fibWaitingNewFloor) → SELL with trend allowed
   //   3. Active breakout (g_fibWaitingNewCeiling) → BUY with trend allowed
   if(g_fib.valid && entryScore < 9)
   { bool sellInDiscount = (direction==-1 && ep < g_fibLevel05);
     bool buyInPremium   = (direction== 1 && ep > g_fibLevel05);
     // Also allow when fR signals a cascade reversal at RevH/RevL
     // (outLabel set by Fib_FilterSignal to "📍CEILING-SELL@RevH*" or "📍FLOOR-BUY@RevL*")
     bool cascadeRevSell = (StringFind(fPL,"CEILING-SELL@RevH")>=0);
     bool cascadeRevBuy  = (StringFind(fPL,"FLOOR-BUY@RevL")>=0);
     if(sellInDiscount && !g_fibWaitingNewFloor && !cascadeRevSell)
     { string bl=StringFormat("🚫 SELL BLOCKED|price %.5f below 0.5(%.5f)|DISCOUNT|score=%d < GOLDMINE",
                  ep,g_fibLevel05,entryScore);
       Log(bl); Notify(bl); return; }
     if(buyInPremium && !g_fibWaitingNewCeiling && !cascadeRevBuy)
     { string bl=StringFormat("🚫 BUY BLOCKED|price %.5f above 0.5(%.5f)|PREMIUM|score=%d < GOLDMINE",
                  ep,g_fibLevel05,entryScore);
       Log(bl); Notify(bl); return; }
     // Active breakdown/breakout — notify and allow with-trend entry
     if(sellInDiscount && g_fibWaitingNewFloor)
        Notify(StringFormat("⚠️ SELL below 0.5|BREAKDOWN active|score=%d|allowing with-trend",entryScore));
     if(buyInPremium && g_fibWaitingNewCeiling)
        Notify(StringFormat("⚠️ BUY above 0.5|BREAKOUT active|score=%d|allowing with-trend",entryScore)); }

   if(fR==FIB_EXEC_NOW)
   { if(g_fib.valid)
     { // Use lower threshold in cascade — PD zone bonus unavailable below fib0/above fib1
       bool cascadeActive = (g_fibWaitingNewFloor || g_fibWaitingNewCeiling);
       int  minScore      = cascadeActive ? Fib_CascadeMinScore : Fib_EntryMinScore;
       if(entryScore < minScore)
       { string sw=StringFormat("⏳ %s SCORE LOW|%s|score=%d < min=%d|%s|%s|arming watch",
                    dirStr,_Symbol,entryScore,minScore,
                    cascadeActive?"CASCADE":"NORMAL",fPL);
         Log(sw);Notify(sw,true);
         Fib_ArmWatch(direction,"ST",false);
         return; } }
     string s1=StringFormat("%s ST %s|%s|score=%d %s%s%s%s",
        emoji,dirStr,_Symbol,entryScore,grade,fCtx,mtfCtx,
        (srConf!=""?"|SR:"+srConf:""));
     Log(s1);Notify(s1,true,true); // isEntry=true — trade signal
     string s2=StringFormat("%s %s @%.*f|SL:%.*f|TP1:%.*f TP2:%.*f TP3:%.*f",
        emoji,dirStr,dg,signalClose,dg,sl,dg,tp1,dg,tp2,dg,tp3);
     Log(s2);Notify(s2,true,true); // isEntry=true — trade signal
     if(EAMode==EA_MODE_TRADE) OpenPositions(direction,signalClose,sl,tp1,tp2,tp3); }
   else if(fR==FIB_WATCH_WAIT)
   { string wl=(direction==1)?"0.25":"0.75";
     string s1=StringFormat("%s ST %s|%s|score=%d %s%s|⏳WAIT→%s",
        emoji,dirStr,_Symbol,entryScore,grade,fCtx,wl);
     Log(s1);Notify(s1,true); }
   else if(fR==FIB_WATCH_PO3)
      Log("📐 PO3 watch active for "+dirStr);
}

//| STATE PERSISTENCE — STATE_VER=38                               |
string StateFile()
{ string tf=EnumToString(PERIOD_CURRENT);StringReplace(tf,":","_");
  // B4 FIX: include MagicNumber — prevents state collision between EA instances on same symbol/TF
  return "LinerX_Snflow_v8.0_"+_Symbol+"_"+tf+"_"+IntegerToString(MagicNumber)+".state";}
#define STATE_VER 38

void SaveStateFile()
{
   if(!SaveState)return;
   int h=FileOpen(StateFile(),FILE_WRITE|FILE_BIN|FILE_COMMON);if(h==INVALID_HANDLE)return;
   FileWriteInteger(h,STATE_VER);
   FileWriteLong(h,(long)TimeCurrent());
   FileWriteDouble(h,g_st_up);FileWriteDouble(h,g_st_dn);
   FileWriteDouble(h,g_st_up_prev);FileWriteDouble(h,g_st_dn_prev);
   FileWriteInteger(h,g_st_trend);
   FileWriteInteger(h,g_barCount);
   FileWriteInteger(h,g_openTradeCount);
   for(int i=0;i<g_openTradeCount;i++)
   { FileWriteLong(h,(long)g_openTrades[i].ticket);FileWriteDouble(h,g_openTrades[i].openPrice);
     FileWriteDouble(h,g_openTrades[i].originalLots);FileWriteInteger(h,g_openTrades[i].direction);
     FileWriteDouble(h,g_openTrades[i].slPrice);FileWriteDouble(h,g_openTrades[i].assignedTP);
     FileWriteInteger(h,g_openTrades[i].tpBucket);}
   // SR M5
   FileWriteInteger(h,g_srChannelCount);
   for(int i=0;i<g_srChannelCount;i++){FileWriteDouble(h,g_srChannels[i].top);FileWriteDouble(h,g_srChannels[i].bottom);FileWriteInteger(h,g_srChannels[i].strength);}
   FileWriteInteger(h,g_srPivotCount);
   for(int i=0;i<g_srPivotCount;i++){FileWriteDouble(h,g_srPivotVals[i]);FileWriteInteger(h,g_srPivotBars[i]);}
   // M12 Fib
   FileWriteInteger(h,g_fib.valid?1:0);FileWriteDouble(h,g_fib.fibHigh);FileWriteDouble(h,g_fib.fibLow);
   FileWriteInteger(h,g_fib.anchorBar);FileWriteInteger(h,(int)g_fib.state);
   FileWriteInteger(h,g_fib.highFlipped?1:0);FileWriteInteger(h,g_fib.lowFlipped?1:0);
   FileWriteInteger(h,g_fibWatch.active?1:0);FileWriteInteger(h,g_fibWatch.direction);
   FileWriteDouble(h,g_fibWatch.zoneTop);FileWriteDouble(h,g_fibWatch.zoneBot);
   FileWriteInteger(h,g_fibWatch.armedBar);FileWriteInteger(h,g_fibWatch.isPO3?1:0);
   FileWriteString(h,g_fibWatch.signalSource+"\n");
   // M12 ReAnchor — one-side locked extremes
   FileWriteDouble(h,g_fibLockedFloor);
   FileWriteDouble(h,g_fibLockedCeiling);
   FileWriteInteger(h,g_fibWaitingNewCeiling?1:0);
   FileWriteInteger(h,g_fibWaitingNewFloor?1:0);
   // H&S pattern state (STATE_VER 35)
   FileWriteInteger(h,g_invHSDetected?1:0); FileWriteDouble(h,g_invHSNeckline);
   FileWriteInteger(h,g_invHSBar);          FileWriteInteger(h,g_invHSArmed?1:0);
   FileWriteInteger(h,g_hsDetected?1:0);    FileWriteDouble(h,g_hsNeckline);
   FileWriteInteger(h,g_hsBar);             FileWriteInteger(h,g_hsArmed?1:0);
   // Watch cooldown (STATE_VER 35)
   FileWriteInteger(h,g_watchLastBuyBar);   FileWriteInteger(h,g_watchLastSellBar);
   // Watch score + priority (STATE_VER 35)
   FileWriteInteger(h,g_fibWatch.score);    FileWriteInteger(h,g_fibWatch.priority);
   // Flipped SD levels
   FileWriteInteger(h,g_fibFlippedCount);
   for(int i=0;i<g_fibFlippedCount;i++)
   { FileWriteDouble(h,g_fibFlippedLevels[i]); FileWriteInteger(h,g_fibFlippedDir[i]); }
   // Consolidation state (STATE_VER 38)
   FileWriteInteger(h,g_inConsolidation?1:0);
   FileWriteDouble(h,g_consolHigh); FileWriteDouble(h,g_consolLow); FileWriteDouble(h,g_adrValue);
   FileClose(h);
   Log("💾 Saved V8.0 | ST="+IntegerToString(g_st_trend)+" fib="+EnumToString(g_fib.state)+" watch="+(g_fibWatch.active?"ARMED":"IDLE")+" flips="+IntegerToString(g_fibFlippedCount)+" consol="+(g_inConsolidation?"YES":"NO"));
}

void LoadStateFile()
{
   if(!LoadState)return;
   string fn=StateFile();if(!FileIsExist(fn,FILE_COMMON))return;
   int h=FileOpen(fn,FILE_READ|FILE_BIN|FILE_COMMON);if(h==INVALID_HANDLE)return;
   int fmt=FileReadInteger(h);
   if(fmt!=STATE_VER)
   { FileClose(h); FileDelete(fn,FILE_COMMON);
     Print("⚠️ State version mismatch (got ",fmt,") expected ",STATE_VER," — fresh start");
     // Check if there are open positions that will be untracked (no SL/TP management)
     int openCount=0;
     for(int i=0;i<PositionsTotal();i++)
     { ulong t=PositionGetTicket(i);if(!t||!PositionSelectByTicket(t))continue;
       if(PositionGetString(POSITION_SYMBOL)==_Symbol&&(ulong)PositionGetInteger(POSITION_MAGIC)==(ulong)MagicNumber)openCount++;}
     if(openCount>0)
        Print("⚠️ WARNING: ",openCount," open position(s) on ",_Symbol," are now UNTRACKED — check SL/TP manually");
     return; }
   datetime ts=(datetime)FileReadLong(h);
   if(MaxStateAgeHours>0&&TimeCurrent()-ts>(datetime)(MaxStateAgeHours*3600)){FileClose(h);FileDelete(fn,FILE_COMMON);Print("⚠️ State expired");return;}
   g_st_up=FileReadDouble(h);g_st_dn=FileReadDouble(h);
   g_st_up_prev=FileReadDouble(h);g_st_dn_prev=FileReadDouble(h);
   g_st_trend=FileReadInteger(h);
   g_barCount=FileReadInteger(h);
   int cb=iBars(_Symbol,PERIOD_CURRENT);if(g_barCount>0&&MathAbs(g_barCount-cb)>5000) g_barCount=cb;
   int sC=FileReadInteger(h);g_openTradeCount=0;
   for(int i=0;i<sC&&i<200;i++)
   { ulong tk=(ulong)FileReadLong(h);double op=FileReadDouble(h);double ol=FileReadDouble(h);
     int d=FileReadInteger(h);double sp=FileReadDouble(h);double aT=FileReadDouble(h);int tB=FileReadInteger(h);
     if(PositionSelectByTicket(tk))
     { int idx=g_openTradeCount++;g_openTrades[idx].ticket=tk;g_openTrades[idx].openPrice=op;
       g_openTrades[idx].originalLots=ol;g_openTrades[idx].direction=d;g_openTrades[idx].slPrice=sp;
       g_openTrades[idx].assignedTP=aT;g_openTrades[idx].tpBucket=tB;}}
   // SR M5
   int sSR=FileReadInteger(h);g_srChannelCount=0;
   for(int i=0;i<sSR&&i<10;i++){g_srChannels[i].top=FileReadDouble(h);g_srChannels[i].bottom=FileReadDouble(h);g_srChannels[i].strength=FileReadInteger(h);g_srChannelCount++;}
   int sPV=FileReadInteger(h);g_srPivotCount=0;
   for(int i=0;i<sPV&&i<500;i++){g_srPivotVals[i]=FileReadDouble(h);g_srPivotBars[i]=FileReadInteger(h);g_srPivotCount++;}
   // M12 Fib
   bool fv=(FileReadInteger(h)==1);double fH=FileReadDouble(h);double fL=FileReadDouble(h);
   int fAB=FileReadInteger(h);int fSt=FileReadInteger(h);bool fHF=(FileReadInteger(h)==1);bool fLF=(FileReadInteger(h)==1);
   if(fv&&fH>fL){Fib_SetAnchor(fL,fH,false);g_fib.anchorBar=fAB;g_fib.state=(ENUM_FIB_STATE)fSt;g_fib.highFlipped=fHF;g_fib.lowFlipped=fLF;}
   bool wa=(FileReadInteger(h)==1);int wd=FileReadInteger(h);double wt=FileReadDouble(h);double wb=FileReadDouble(h);
   int wab=FileReadInteger(h);bool wpo=(FileReadInteger(h)==1);string wss=FileReadString(h);
   if(wa&&(wd==1||wd==-1)){g_fibWatch.active=true;g_fibWatch.direction=wd;g_fibWatch.zoneTop=wt;g_fibWatch.zoneBot=wb;g_fibWatch.armedBar=wab;g_fibWatch.isPO3=wpo;g_fibWatch.signalSource=wss;}
   // M12 ReAnchor — one-side locked extremes
   g_fibLockedFloor       = FileReadDouble(h);
   g_fibLockedCeiling     = FileReadDouble(h);
   g_fibWaitingNewCeiling = (FileReadInteger(h)==1);
   g_fibWaitingNewFloor   = (FileReadInteger(h)==1);
   if(g_fibWaitingNewCeiling)
      Log(StringFormat("💾 FIB CEILING SHIFT restored | floor=%.5f | waiting swing high near RevH",g_fibLockedFloor));
   if(g_fibWaitingNewFloor)
      Log(StringFormat("💾 FIB FLOOR SHIFT restored | ceiling=%.5f | waiting swing low near RevL",g_fibLockedCeiling));
   // H&S pattern state (STATE_VER 35)
   g_invHSDetected=(FileReadInteger(h)==1); g_invHSNeckline=FileReadDouble(h);
   g_invHSBar=FileReadInteger(h);           g_invHSArmed=(FileReadInteger(h)==1);
   g_hsDetected=(FileReadInteger(h)==1);    g_hsNeckline=FileReadDouble(h);
   g_hsBar=FileReadInteger(h);              g_hsArmed=(FileReadInteger(h)==1);
   // Watch cooldown (STATE_VER 35)
   g_watchLastBuyBar=FileReadInteger(h);    g_watchLastSellBar=FileReadInteger(h);
   // Watch score + priority (STATE_VER 35)
   g_fibWatch.score=FileReadInteger(h);     g_fibWatch.priority=FileReadInteger(h);
   if(g_invHSDetected)
      Log(StringFormat("💾 INV H&S restored|neckline=%.5f",g_invHSNeckline));
   if(g_hsDetected)
      Log(StringFormat("💾 H&S restored|neckline=%.5f",g_hsNeckline));
   // Flipped SD levels
   int fc=FileReadInteger(h); g_fibFlippedCount=0;
   for(int i=0;i<fc&&i<32;i++)
   { g_fibFlippedLevels[i]=FileReadDouble(h); g_fibFlippedDir[i]=FileReadInteger(h); g_fibFlippedCount++; }
   if(g_fibFlippedCount>0)
      Log(StringFormat("💾 Flipped levels restored: %d levels",g_fibFlippedCount));
   // Consolidation state (STATE_VER 38)
   g_inConsolidation=(FileReadInteger(h)==1);
   g_consolHigh=FileReadDouble(h); g_consolLow=FileReadDouble(h); g_adrValue=FileReadDouble(h);
   if(g_inConsolidation)
      Log(StringFormat("💾 Consolidation restored | high=%.5f low=%.5f ADR=%.5f",g_consolHigh,g_consolLow,g_adrValue));
   FileClose(h);
   Log("💾 Loaded V8.0 | trades="+IntegerToString(g_openTradeCount)+" SR="+IntegerToString(g_srChannelCount)+" fib="+EnumToString(g_fib.state)+" watch="+(g_fibWatch.active?"ARMED":"IDLE")+" consol="+(g_inConsolidation?"YES":"NO"));
}

//| INIT                                                            |
int OnInit()
{
   MathSrand(GetTickCount());
   Print("════ LinerX Snflow EA V8.0 ════");

   // Auto-scale buffers for high-value instruments
   if(true) // auto-scale for high-value instruments (always on)
   { double price=SymbolInfoDouble(_Symbol,SYMBOL_BID);
     double pip=SymbolInfoDouble(_Symbol,SYMBOL_POINT);
     if(price>0 && pip>0)
     { double ratio=price/pip;
       double reference=450000.0; // XAUUSD baseline (~4500 / 0.01)
       g_priceScalar=MathMax(1.0,MathMin(100.0,ratio/reference)); }
     Print(StringFormat("📐 Price scalar: %.2f | %s (price=%.2f point=%.5f)",
           g_priceScalar,_Symbol,SymbolInfoDouble(_Symbol,SYMBOL_BID),GetPointsize())); }

   // B3 FIX: warn loudly if no SL is configured — trades will open unprotected
   if(!UseATRBasedSL && SL_Points <= 0)
   { Print("ℹ️ INFO: UseATRBasedSL=false AND SL_Points=0 — SL assigned from fib structure (fib0/fib1) and VirtualSL for cascade trades.");
     Print("ℹ️ All entries use VirtualSL_Points=",VirtualSL_Points," as SL — tight stop enables fast BE, worst case = break even not full loss."); }

   g_stATRHandle=iATR(_Symbol,PERIOD_CURRENT,ST_ATR_Periods);
   if(g_stATRHandle==INVALID_HANDLE&&ST_UseWilderATR){Print("ERROR: ST ATR failed");return INIT_FAILED;}

   trade.SetExpertMagicNumber(MagicNumber);
   trade.SetDeviationInPoints(Slippage);
   trade.SetAsyncMode(false);

   // Reset all globals
   g_st_up=0;g_st_dn=0;g_st_up_prev=0;g_st_dn_prev=0;g_st_trend=0;
   g_barCount=iBars(_Symbol,PERIOD_CURRENT); // set real count so backfill barAge is never negative
   ZeroMemory(g_openTrades);g_openTradeCount=0;
   g_pendingCount=0;g_lastOpenMs=0;g_nextDelayMs=0;
   g_srChannelCount=0;g_srPivotCount=0;ZeroMemory(g_srChannels);
   ArrayInitialize(g_srPivotVals,0);ArrayInitialize(g_srPivotBars,0);
   g_srM30ChannelCount=0;g_srM30PivotCount=0;ZeroMemory(g_srM30Channels);
   ArrayInitialize(g_srM30PivotVals,0);ArrayInitialize(g_srM30PivotBars,0);
   Fib_ResetAll();

   LoadStateFile();

   // Stale SR check
   if(UseSRChannels&&g_srPivotCount>0)
   { double curPrice=iClose(_Symbol,PERIOD_CURRENT,1),priceRange=curPrice*0.05;bool staleZones=false;
     for(int i=0;i<g_srPivotCount;i++) if(MathAbs(g_srPivotVals[i]-curPrice)>priceRange){staleZones=true;break;}
     if(staleZones){Print("⚠️ SR: stale pivots — clearing and backfilling");
       g_srPivotCount=0;g_srChannelCount=0;ArrayInitialize(g_srPivotVals,0);ArrayInitialize(g_srPivotBars,0);ZeroMemory(g_srChannels);
       SR_BackfillPivots();}}

   // Stale fib check
   if(g_fib.valid&&Fib_WatchEnabled)
   { double curPrice=iClose(_Symbol,PERIOD_CURRENT,1);
     bool priceOutside=(curPrice<g_fib.fibLow||curPrice>g_fib.fibHigh);
     // Price outside range is EXPECTED during one-side reanchor — never reset mid-break
     bool waitingReanchor=(g_fibWaitingNewFloor||g_fibWaitingNewCeiling);
     if(priceOutside && waitingReanchor)
     { Print(StringFormat("💾 Fib outside range but reanchor in progress (%s) — preserving state",
             g_fibWaitingNewCeiling?"CEILING↑":"FLOOR↓")); }
     else if(priceOutside)
     { if(g_openTradeCount > 0)
          Print("⚠️ Stale fib — price outside range but ",g_openTradeCount," open trade(s) — preserving to protect management");
       else
       { Print("⚠️ Stale fib — resetting (price outside range, no reanchor, no open trades)");
         Fib_ResetAll(); }}}

   if(UseSRChannels&&g_srPivotCount==0) SR_BackfillPivots();
   else if(UseSRChannels&&g_srPivotCount>0&&g_srChannelCount==0){Print("💾 SR pivots loaded — rebuilding...");SR_BuildChannels();}
   if(Fib_WatchEnabled&&!g_fib.valid) Fib_BackfillAnchor();
   else if(Fib_WatchEnabled&&g_fib.valid)
   { Fib_CalcLevels();
     Log("💾 Fib restored | 0="+DoubleToString(g_fibLevel0,_Digits)+" 1="+DoubleToString(g_fibLevel1,_Digits)+" | "+EnumToString(g_fib.state)+(g_fibWatch.active?" WATCH-ARMED":""));}
   SR_M30_BackfillPivots();

   UnifiedTradeManagerInit();


   Print("════ V8.0 INIT COMPLETE ════════════════════════════════");
   Print("Mode     : ",EAMode==EA_MODE_TRADE?"TRADE":"SIGNAL");
   Print("Engines  : SuperTrend(x",ST_Multiplier,", ATR",ST_ATR_Periods,") + Score gate");
   Print("M12 Fib  : ",Fib_WatchEnabled?EnumToString(Fib_HTF)+(g_fib.valid?" ARMED ["+DoubleToString(g_fibLevel0,_Digits)+"-"+DoubleToString(g_fibLevel1,_Digits)+"] "+EnumToString(g_fib.state)+(g_fibWaitingNewCeiling?" [CEILING UP]":g_fibWaitingNewFloor?" [FLOOR DOWN]":""):" NOT ANCHORED"):"OFF");
   Print("SR (M5)  : ",UseSRChannels?"ON zones="+IntegerToString(g_srChannelCount):"OFF");
   Print("SR (M30) : zones=",g_srM30ChannelCount);
   Print("ATR SL   : ",UseATRBasedSL?"ON x"+DoubleToString(ATR_SL_Multiplier,1):"OFF");
   Print("State    : Save=",SaveState," Load=",LoadState," [STATE_VER=38]");
   Print("ScoreMins: Entry=",Fib_EntryMinScore," Cascade=",Fib_CascadeMinScore);
   Print("===================================================================");
   return INIT_SUCCEEDED;
}

//| DEINIT                                                           |
void OnDeinit(const int reason)
{
   SaveStateFile();
   if(g_stATRHandle!=INVALID_HANDLE) IndicatorRelease(g_stATRHandle);
   UnifiedTradeManagerCleanup();
   Print("LinerX V8.0 removed. Reason: ",reason);
}

//| TICK                                                             |
void OnTick()
{
   ProcessPendingQueue();
   ManageTrade();
   datetime cBar=iTime(_Symbol,PERIOD_CURRENT,0);
   if(EnableTradeManager) UnifiedScanAndEnroll();

   // Per M5 bar logic
   static datetime lastBar=0;
   if(cBar==lastBar) return;
   lastBar=cBar; g_barCount++;

   if(EnableTradeManager) UnifiedManagePositions();

   // Consolidation detection — ADR contraction + equal H/L
   ADR_Consolidation();

   // Range zone touches — only when consolidating
   if(g_inConsolidation && g_fib.valid) Range_CheckZoneTouches();

   // SR M5
   if(UseSRChannels){bool np=SR_DetectPivot();if(np)SR_BuildChannels();}

   // M12 Fib HTF pivot — one-side reanchor
   datetime cFib=iTime(_Symbol,Fib_HTF,0);
   if(Fib_WatchEnabled&&cFib!=g_lastFibHTFBar)
   { g_lastFibHTFBar=cFib;
     if(g_fibWaitingNewCeiling||g_fibWaitingNewFloor)
     { if(Fib_DetectHTFPivot()) Fib_CalcLevels(); }
   }

   // M12 Fib state + watch
   if(Fib_WatchEnabled&&g_fib.valid){Fib_UpdateState();Fib_CheckWatch();}

   // M30 SR — gated on new M30 bar
   datetime cM30=iTime(_Symbol,Fib_HTF2,0);
   static datetime lastM30Bar=0;
   if(cM30!=lastM30Bar)
   { lastM30Bar=cM30;
     HS_DetectPatterns();
     if(SR_M30_DetectPivot()) SR_M30_BuildChannels();}

   // ── SUPERTREND — sole entry trigger ──────────────────────────────
   // ST flip → score check → execute (score>=min) or arm watch (score<min)
   // No GMMA waiting period — patterns + zone confluence score gates quality
   int stFlip=UpdateSuperTrend();
   if(stFlip!=0)
   {
      double epCheck=(stFlip==1)?SymbolInfoDouble(_Symbol,SYMBOL_ASK):SymbolInfoDouble(_Symbol,SYMBOL_BID);
      int quickScore = g_fib.valid ? Fib_ScoreZoneEntry(stFlip, epCheck, 1) : 0;
      string qGrade = (quickScore>=9)?"GOLDMINE":(quickScore>=6)?"STRONG":(quickScore>=4)?"MODERATE":"WEAK";

      // SR tag: M5 first, fall back to M30 for historical structural zones
      string srLT="";
      if(UseSRChannels)
      { string sc=SR_GetConfluenceTag(stFlip,epCheck);
        if(sc==""&&Use_HTF2_SRGate) sc=SR_M30_GetConfluenceTag(stFlip,epCheck);
        srLT=(sc!="")?" "+sc:" [no SR]"; }

      // Zone-block tag — mirror ExecuteSignal hard block so phone notification
      // immediately shows ⚠️PREMIUM-BLOCKED / DISCOUNT-BLOCKED before EA logs it.
      // GOLDMINE (score≥9) overrides zone just like ExecuteSignal does.
      string zoneTag="";
      if(g_fib.valid && g_fibLevel05>0 && quickScore<9)
      { bool premBuy  = (stFlip== 1 && epCheck>g_fibLevel05 && !g_fibWaitingNewCeiling);
        bool discSell = (stFlip==-1 && epCheck<g_fibLevel05 && !g_fibWaitingNewFloor);
        if(premBuy)  zoneTag="|📕PREMIUM-BLOCKED";
        if(discSell) zoneTag="|📗DISCOUNT-BLOCKED"; }

      Log(StringFormat("📡 ST FLIP %s | bar=%d | score=%d %s%s%s",
          stFlip==1?"BUY":"SELL", g_barCount, quickScore, qGrade, srLT, zoneTag));
      Notify(StringFormat("📡 ST %s FLIP|%s|score=%d %s%s%s",
             stFlip==1?"BUY":"SELL", _Symbol, quickScore, qGrade, srLT, zoneTag));
      double signalClose=iClose(_Symbol,PERIOD_CURRENT,1);
      ExecuteSignal(stFlip, signalClose);
   }
}
