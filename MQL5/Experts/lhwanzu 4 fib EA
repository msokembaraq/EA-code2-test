#define STATE_VER 1

string StateFile()
{
   string tf=EnumToString(PERIOD_CURRENT); StringReplace(tf,":","_");
   return "LinerX_v9_"+_Symbol+"_"+tf+"_"+IntegerToString(MagicNumber)+".state";
}

void SaveStateFile()
{
   int h=FileOpen(StateFile(),FILE_WRITE|FILE_BIN|FILE_COMMON);
   if(h==INVALID_HANDLE) return;
   FileWriteInteger(h, STATE_VER);
   FileWriteLong(h, (long)TimeCurrent());
   // SuperTrend state
   FileWriteDouble(h, g_st_up);  FileWriteDouble(h, g_st_dn);
   FileWriteDouble(h, g_st_up_prev); FileWriteDouble(h, g_st_dn_prev);
   FileWriteInteger(h, g_st_trend);
   FileWriteInteger(h, g_barCount);
   // Fib anchor
   FileWriteInteger(h, g_fibValid?1:0);
   FileWriteDouble(h, g_f0); FileWriteDouble(h, g_f1);
   // Cascade state
   FileWriteInteger(h, g_waitFloor?1:0);
   FileWriteInteger(h, g_waitCeil?1:0);
   FileWriteDouble(h, g_lockedFloor);
   FileWriteDouble(h, g_lockedCeil);
   // Role-flip array
   FileWriteInteger(h, g_flippedCount);
   for(int i=0; i<g_flippedCount; i++)
   { FileWriteDouble(h, g_flippedLevels[i]); FileWriteInteger(h, g_flippedDir[i]); }
   // PO3 state
   FileWriteInteger(h, g_po3BuyArmed?1:0);
   FileWriteInteger(h, g_po3BuyArmedBar);
   FileWriteInteger(h, g_po3SellArmed?1:0);
   FileWriteInteger(h, g_po3SellArmedBar);
   // Consolidation
   FileWriteInteger(h, g_inConsol?1:0);
   FileWriteDouble(h, g_adrValue);
   // Open trades
   FileWriteInteger(h, g_openTradeCount);
   for(int i=0; i<g_openTradeCount; i++)
   { FileWriteLong(h,(long)g_openTrades[i].ticket);
     FileWriteDouble(h,g_openTrades[i].openPrice);
     FileWriteDouble(h,g_openTrades[i].originalLots);
     FileWriteInteger(h,g_openTrades[i].direction);
     FileWriteDouble(h,g_openTrades[i].slPrice);
     FileWriteDouble(h,g_openTrades[i].assignedTP);
     FileWriteInteger(h,g_openTrades[i].tpBucket); }
   FileClose(h);
   Log("💾 State saved | ST="+IntegerToString(g_st_trend)+
       " fib="+(g_fibValid?"VALID":"NONE")+
       " waitFloor="+(g_waitFloor?"YES":"NO")+
       " waitCeil="+(g_waitCeil?"YES":"NO")+
       " flips="+IntegerToString(g_flippedCount)+
       " consol="+(g_inConsol?"YES":"NO"));
}

void LoadStateFile()
{
   string fn=StateFile();
   if(!FileIsExist(fn, FILE_COMMON)) return;
   int h=FileOpen(fn, FILE_READ|FILE_BIN|FILE_COMMON);
   if(h==INVALID_HANDLE) return;
   int fmt=FileReadInteger(h);
   if(fmt!=STATE_VER)
   { FileClose(h); FileDelete(fn,FILE_COMMON);
     Print("⚠️ State version mismatch (got ",fmt,") expected ",STATE_VER," — fresh start");
     return; }
   datetime ts=(datetime)FileReadLong(h);
   // ST state
   g_st_up      = FileReadDouble(h);  g_st_dn      = FileReadDouble(h);
   g_st_up_prev = FileReadDouble(h);  g_st_dn_prev = FileReadDouble(h);
   g_st_trend   = FileReadInteger(h);
   g_barCount   = FileReadInteger(h);
   int cb=iBars(_Symbol,PERIOD_CURRENT);
   if(g_barCount>0 && MathAbs(g_barCount-cb)>5000) g_barCount=cb;
   // Fib anchor
   bool fv=(FileReadInteger(h)==1);
   double fL=FileReadDouble(h), fH=FileReadDouble(h);
   if(fv && fH>fL) Fib_SetAnchor(fL, fH);
   // Cascade state
   g_waitFloor   = (FileReadInteger(h)==1);
   g_waitCeil    = (FileReadInteger(h)==1);
   g_lockedFloor = FileReadDouble(h);
   g_lockedCeil  = FileReadDouble(h);
   // Role-flip array
   int fc=FileReadInteger(h); g_flippedCount=0;
   for(int i=0; i<fc&&i<32; i++)
   { g_flippedLevels[i]=FileReadDouble(h); g_flippedDir[i]=FileReadInteger(h); g_flippedCount++; }
   // PO3 state
   g_po3BuyArmed    = (FileReadInteger(h)==1);
   g_po3BuyArmedBar =  FileReadInteger(h);
   g_po3SellArmed   = (FileReadInteger(h)==1);
   g_po3SellArmedBar=  FileReadInteger(h);
   // Consolidation
   g_inConsol = (FileReadInteger(h)==1);
   g_adrValue = FileReadDouble(h);
   // Open trades
   int sC=FileReadInteger(h); g_openTradeCount=0;
   for(int i=0; i<sC&&i<200; i++)
   { ulong tk=(ulong)FileReadLong(h);
     double op=FileReadDouble(h); double ol=FileReadDouble(h);
     int d=FileReadInteger(h);   double sp=FileReadDouble(h);
     double aT=FileReadDouble(h); int tB=FileReadInteger(h);
     if(PositionSelectByTicket(tk))
     { int idx=g_openTradeCount++;
       g_openTrades[idx].ticket=tk;      g_openTrades[idx].openPrice=op;
       g_openTrades[idx].originalLots=ol; g_openTrades[idx].direction=d;
       g_openTrades[idx].slPrice=sp;     g_openTrades[idx].assignedTP=aT;
       g_openTrades[idx].tpBucket=tB; }}
   FileClose(h);
   if(g_waitCeil)
      Log(StringFormat("💾 State: CEILING SHIFT restored | lockedFloor=%.5f | RevH=%.5f", g_lockedFloor, g_fRevH));
   if(g_waitFloor)
      Log(StringFormat("💾 State: FLOOR SHIFT restored | lockedCeil=%.5f | RevL=%.5f", g_lockedCeil, g_fRevL));
   if(g_flippedCount>0)
      Log(StringFormat("💾 State: %d flipped levels restored", g_flippedCount));
   Log("💾 State loaded | trades="+IntegerToString(g_openTradeCount)+
       " ST="+IntegerToString(g_st_trend)+" fib="+(g_fibValid?"VALID":"NONE")+
       " consol="+(g_inConsol?"YES":"NO"));
}

//+------------------------------------------------------------------+
//| ONINIT                                                           |
//+------------------------------------------------------------------+
int OnInit()
{
   MathSrand(GetTickCount());
   Print("════ LinerX v9.1 FibST EA ════");

   // Price scalar — maps broker "point" to a trader "pip" of meaningful size.
   // XAUUSD uses 2 decimal places (point=0.01); 1 pip = $1 = 100 points → scalar=100.
   // 3-digit pairs: scalar=10.  Standard 4/5-digit forex: scalar=1.
   {
      int dg2 = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
      if     (dg2 <= 2) g_priceScalar = 100.0;
      else if(dg2 == 3) g_priceScalar = 10.0;
      else              g_priceScalar = 1.0;
      Print(StringFormat("📐 Price scalar: %.0f | %s (%d digits, point=%.5f) — 1 pip = %.4f",
            g_priceScalar, _Symbol, dg2, GetPointsize(), GetPointsize()*g_priceScalar));
   }

   // ATR handle
   g_stATRHandle = iATR(_Symbol, PERIOD_CURRENT, ST_ATR_Periods);
   if(g_stATRHandle==INVALID_HANDLE && ST_UseWilderATR)
   { Print("ERROR: ST ATR handle failed"); return INIT_FAILED; }

   trade.SetExpertMagicNumber(MagicNumber);
   trade.SetDeviationInPoints(Slippage);
   trade.SetAsyncMode(false);

   // Reset globals
   g_st_up=0; g_st_dn=0; g_st_up_prev=0; g_st_dn_prev=0; g_st_trend=0;
   g_barCount = iBars(_Symbol, PERIOD_CURRENT);
   ZeroMemory(g_openTrades); g_openTradeCount=0;
   g_pendingCount=0; g_lastOpenMs=0; g_nextDelayMs=0;
   g_fibValid=false; g_fibRange=0;
   g_f0=0; g_f1=0; g_f025=0; g_f0382=0; g_f05=0; g_f0618=0; g_f075=0;
   g_fRevL=0; g_fRevH=0; g_fFlip1L=0; g_fFlip1H=0;
   g_waitCeil=false; g_waitFloor=false; g_lockedFloor=0; g_lockedCeil=0;
   g_flippedCount=0;
   ArrayInitialize(g_flippedLevels,0); ArrayInitialize(g_flippedDir,0);
   g_po3BuyArmed=false; g_po3SellArmed=false;
   g_inConsol=false; g_adrValue=0;
   g_srCount=0;
   ArrayResize(g_unifiedPositions,0); g_unifiedPosCount=0;

   // Load state (must come before backfill to avoid redundant backfill)
   LoadStateFile();

   // Backfill fib if not valid
   if(!g_fibValid) Fib_Backfill();
   else
   {
      Log("💾 Fib restored from state | 0="+DoubleToString(g_f0,_Digits)+
          " 1="+DoubleToString(g_f1,_Digits)+
          " RevL="+DoubleToString(g_fRevL,_Digits)+
          " RevH="+DoubleToString(g_fRevH,_Digits));
   }

   // Backfill SR pivot levels from historical bars
   SR_Backfill();

   Print("════ V9.0 INIT COMPLETE ════");
   Print("Mode      : ", EAMode==EA_MODE_TRADE?"TRADE":"SIGNAL");
   Print("SuperTrend: mult=",ST_Multiplier," ATR=",ST_ATR_Periods);
   Print("Fib HTF   : ",EnumToString(Fib_HTF));
   Print("Fib Valid : ", g_fibValid?"YES — 0="+DoubleToString(g_f0,_Digits)+" 1="+DoubleToString(g_f1,_Digits):"NO");
   Print("RequireSR : ", InpRequireSR?"YES":"NO");
   Print("Consol    : ", UseConsolidation?"YES":"NO");
   Print("ATR SL    : ", UseATRBasedSL?"YES x"+DoubleToString(SL_ATR_Mult,1):"NO");
   Print("==========================================================");
   return INIT_SUCCEEDED;
}

//+------------------------------------------------------------------+
//| ONDEINIT                                                         |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
   SaveStateFile();
   if(g_stATRHandle!=INVALID_HANDLE) IndicatorRelease(g_stATRHandle);
   ArrayFree(g_unifiedPositions);
   // Remove chart objects
   ObjectsDeleteAll(0, "LX_FIB_");
   Print("LinerX v9.0 removed. Reason: ", reason);
}

//+------------------------------------------------------------------+
//| ONTICK                                                           |
//+------------------------------------------------------------------+
void OnTick()
{
   ProcessQueue();
   ManageTrade();

   datetime cBar=iTime(_Symbol, PERIOD_CURRENT, 0);
   if(EnableTradeManager) UnifiedScanAndEnroll();

   // ── New bar ───────────────────────────────────────────────────
   static datetime lastBar=0;
   if(cBar==lastBar) return;
   lastBar=cBar;
   g_barCount++;

   if(EnableTradeManager) UnifiedManagePositions();

   // Consolidation ADR check
   ADR_Check();

   // SR pivot update
   SR_Update();

   // Fib: check for M12 HTF pivot re-anchor + state update + PO3
   datetime cFib = iTime(_Symbol, Fib_HTF, 0);
   static datetime lastFibHTFBar = 0;
   if(g_fibValid && cFib!=lastFibHTFBar)
   {
      lastFibHTFBar = cFib;
      Fib_UpdateState();  // includes pivot detection inside waitCeil/waitFloor
   }
   else if(g_fibValid)
   {
      // Still run PO3 + break detection on every M5 bar
      Fib_UpdateState();
   }

   // Consolidation direct entry check (no ST flip needed)
   if(g_inConsol && g_fibValid) Consol_Check();

   // Draw fib levels on chart
   // ── SUPERTREND — sole entry trigger ───────────────────────────
   int stFlip = UpdateSuperTrend();
   if(stFlip != 0)
   {
      double epCheck = (stFlip==1) ? SymbolInfoDouble(_Symbol,SYMBOL_ASK)
                                   : SymbolInfoDouble(_Symbol,SYMBOL_BID);
      // Quick zone pre-check for notification
      string zoneTag="";
      if(g_fibValid)
      {
         double buf=Fib_PDBuffer*ScaledPip();
         bool inDisc=(epCheck>=g_f0-buf&&epCheck<=g_f0382+buf);
         bool inPrem=(epCheck>=g_f0618-buf&&epCheck<=g_f1+buf);
         bool nearRevL=(g_fRevL>0&&MathAbs(epCheck-g_fRevL)<=buf*3);
         bool nearRevH=(g_fRevH>0&&MathAbs(epCheck-g_fRevH)<=buf*3);
         bool at382=(g_f0382>0&&MathAbs(epCheck-g_f0382)<=buf*3);
         bool at618=(g_f0618>0&&MathAbs(epCheck-g_f0618)<=buf*3);
         if(stFlip==1)
            zoneTag=inDisc?"📗DISCOUNT":nearRevL?"📍RevL":at618?"📍F0618-SUPP":(g_po3BuyArmed?"🎯PO3":"📕OUT-OF-ZONE");
         else
            zoneTag=inPrem?"📕PREMIUM":nearRevH?"📍RevH":at382?"📍F0382-REJ":(g_po3SellArmed?"🎯PO3":"📗OUT-OF-ZONE");
      }
      Log(StringFormat("📡 ST FLIP %s | bar=%d | @%.5f | %s",
          stFlip==1?"BUY":"SELL", g_barCount, epCheck, zoneTag));
      Notify(StringFormat("📡 ST %s FLIP|%s|@%.5f|%s",
             stFlip==1?"BUY":"SELL", _Symbol, epCheck, zoneTag));
      ExecuteSignal(stFlip);
   }
}
