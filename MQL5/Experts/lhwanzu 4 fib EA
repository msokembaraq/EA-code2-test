int GetTrackedTpBucket(ulong ticket)
{ for(int i=0;i<g_openTradeCount;i++) if(g_openTrades[i].ticket==ticket) return g_openTrades[i].tpBucket; return -1;}

void OpenPositions(int direction, double signalClose, double sl, double tp1, double tp2, double tp3)
{
   int dg=(int)SymbolInfoInteger(_Symbol,SYMBOL_DIGITS);
   double ml=SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_MIN),mx=SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_MAX);
   double ls=SymbolInfoDouble(_Symbol,SYMBOL_VOLUME_STEP);
   double lot=NormalizeDouble(MathMax(ml,MathMin(mx,MathFloor(LotSize/ls)*ls)),2);
   int sameDirCount=0;
   for(int i=0;i<PositionsTotal();i++)
   { ulong t=PositionGetTicket(i);if(!t||!PositionSelectByTicket(t))continue;
     if(PositionGetString(POSITION_SYMBOL)!=_Symbol)continue;
     if((ulong)PositionGetInteger(POSITION_MAGIC)!=(ulong)MagicNumber)continue;
     int pt2=(int)PositionGetInteger(POSITION_TYPE);
     if((direction==1&&pt2==POSITION_TYPE_BUY)||(direction==-1&&pt2==POSITION_TYPE_SELL))sameDirCount++;}
   if(sameDirCount>0){Log(StringFormat("⏭️ %s skipped — %d open",direction==1?"BUY":"SELL",sameDirCount));return;}
   if(CloseOnOpposite&&g_pendingCount>0&&g_pendingQueue[0].direction!=direction){Log("🗑️ Cleared opposite queue");g_pendingCount=0;}

   // CASCADE GUARD: during active breakdown/breakout, do NOT close opposite positions
   // BUY positions are short-term RBS bounces — let BE/trail manage their exits
   // Only close opposite in normal FIB_RANGE or FIB_TREND mode
   bool cascadeActive = (g_fibWaitingNewFloor && direction==-1) ||
                        (g_fibWaitingNewCeiling && direction==1);
   if(CloseOnOpposite && !cascadeActive)
   { // Normal mode: close all opposite positions
     for(int i=PositionsTotal()-1;i>=0;i--)
     { ulong t=PositionGetTicket(i);if(!t||!PositionSelectByTicket(t))continue;
       if(PositionGetString(POSITION_SYMBOL)!=_Symbol)continue;
       if((ulong)PositionGetInteger(POSITION_MAGIC)!=(ulong)MagicNumber)continue;
       int pt2=(int)PositionGetInteger(POSITION_TYPE);
       bool isOpp=(direction==1&&pt2==POSITION_TYPE_SELL)||(direction==-1&&pt2==POSITION_TYPE_BUY);
       if(!isOpp)continue;
       if(GetTrackedTpBucket(t)==0){Log("🏃 Runner #"+IntegerToString((int)t)+" exempt");continue;}
       trade.PositionClose(t);Log("Closed opposite #"+IntegerToString((int)t));}}
   else if(cascadeActive && CloseOnOpposite)
   { // CASCADE mode: close ALL opposite positions before opening new cascade direction
     // Accumulating two opposing losing positions creates unlimited drawdown risk
     int nClosed=0;
     for(int i=PositionsTotal()-1;i>=0;i--)
     { ulong t=PositionGetTicket(i);if(!t||!PositionSelectByTicket(t))continue;
       if(PositionGetString(POSITION_SYMBOL)!=_Symbol)continue;
       if((ulong)PositionGetInteger(POSITION_MAGIC)!=(ulong)MagicNumber)continue;
       int pt2=(int)PositionGetInteger(POSITION_TYPE);
       bool isOpp=(direction==1&&pt2==POSITION_TYPE_SELL)||(direction==-1&&pt2==POSITION_TYPE_BUY);
       if(!isOpp)continue;
       if(GetTrackedTpBucket(t)==0){Log("🏃 Runner #"+IntegerToString((int)t)+" exempt");continue;}
       double profit=PositionGetDouble(POSITION_PROFIT)+PositionGetDouble(POSITION_SWAP);
       trade.PositionClose(t);
       Log(StringFormat("%s CASCADE CLOSE | #%d | profit=%.2f",profit>=0?"💰":"🛑",(int)t,profit));
       nClosed++; }
     if(nClosed>0) Log(StringFormat("⚠️ CASCADE: closed %d opposite(s) before new entry",nClosed)); }
   int ex=0;
   for(int i=0;i<PositionsTotal();i++){ulong t=PositionGetTicket(i);if(t>0&&PositionSelectByTicket(t)&&PositionGetString(POSITION_SYMBOL)==_Symbol&&(ulong)PositionGetInteger(POSITION_MAGIC)==(ulong)MagicNumber)ex++;}
   int slots=MathMin(NumberOfPositions,MathMax(0,MaxPositions-ex));
   if(slots<=0){Log("⛔ MaxPositions");return;}


   int c1=0,c2=0,c3=0;

   // Dynamic TP distribution — always keep 1 runner, distribute rest across TP levels
   // Examples: 5 pos → 1+1+1+2runners | 3 pos → 1+1+runner | 2 pos → 1+runner | 1 pos → runner
   int toClose   = MathMax(0, slots - 1); // always keep minimum 1 runner
   int tp1Count  = 0, tp2Count = 0, tp3Count = 0;
   if(toClose >= 1) tp1Count = 1;
   if(toClose >= 2) tp2Count = 1;
   if(toClose >= 3) tp3Count = 1;
   // any remaining beyond 3 closes = extra runners (toClose > 3 means slots > 4)
   for(int pos=0;pos<slots&&g_pendingCount<200;pos++)
   { double aT=0;int tB=0;string bk="RUNNER";
     if(ScaleOutMultiTP)
     { if(c1<tp1Count){aT=tp1;tB=1;bk="TP1";c1++;}
       else if(c2<tp2Count){aT=tp2;tB=2;bk="TP2";c2++;}
       else if(c3<tp3Count){aT=tp3;tB=3;bk="TP3";c3++;}
       else{aT=0;tB=0;bk="RUNNER";}}
     else{aT=tp3;tB=3;bk="TP3";}
     int idx=g_pendingCount++;
     g_pendingQueue[idx].direction=direction;g_pendingQueue[idx].sl=sl;
     g_pendingQueue[idx].assignedTP=aT;g_pendingQueue[idx].tpBucket=tB;
     g_pendingQueue[idx].bucket=bk;g_pendingQueue[idx].lot=lot;
     g_pendingQueue[idx].engTag=" [ST]";g_pendingQueue[idx].createdBar=g_barCount;}
   Log("📋 Queued "+IntegerToString(slots)+" positions [ST]");
   g_lastOpenMs=GetTickCount()-HumanDelay_MaxMs;
   g_nextDelayMs=HumanDelay_MinMs+MathRand()%(MathMax(1,HumanDelay_MaxMs-HumanDelay_MinMs)+1);
}

void OpenOneFromQueue()
{
   if(g_pendingCount<=0)return;
   int ex=0;
   for(int i=0;i<PositionsTotal();i++){ulong t=PositionGetTicket(i);if(t>0&&PositionSelectByTicket(t)&&PositionGetString(POSITION_SYMBOL)==_Symbol&&(ulong)PositionGetInteger(POSITION_MAGIC)==(ulong)MagicNumber)ex++;}
   if(ex>=MaxPositions){Log("⛔ MaxPos queue clear");g_pendingCount=0;return;}
   PendingPosition p=g_pendingQueue[0];
   for(int i=0;i<g_pendingCount-1;i++)g_pendingQueue[i]=g_pendingQueue[i+1];g_pendingCount--;
   int dg=(int)SymbolInfoInteger(_Symbol,SYMBOL_DIGITS);
   double pip=ScaledPip(),mn=GetMinStop();
   double bp=(p.direction==1)?SymbolInfoDouble(_Symbol,SYMBOL_ASK):SymbolInfoDouble(_Symbol,SYMBOL_BID);

   // TP from queue — already calculated correctly at signal time (fib-based or fixed)
   double nTP = p.assignedTP;

   // SL: recalculate fresh from current fill price for ALL positions
   double nSL=0, sdFresh=0;
   if(UseATRBasedSL){double a=GetATRSlDist();sdFresh=(a>0)?a:MathMax(SL_Points*pip,mn);}
   else sdFresh=(SL_Points>0)?MathMax(SL_Points*pip,mn):0;
   if(sdFresh>0)
      nSL=(p.direction==1)?NormalizeDouble(bp-sdFresh,dg):NormalizeDouble(bp+sdFresh,dg);
   else
   { // ALL positions — VirtualSL recalc at fill price, no signal SL fallback
     double vsl=(VirtualSL_Points>0)?VirtualSL_Points*GetPointsize():MathMax(mn+ScaledPip(),mn);
     vsl=MathMax(vsl,mn+ScaledPip());
     nSL=(p.direction==1)?NormalizeDouble(bp-vsl,dg):NormalizeDouble(bp+vsl,dg);
     Log(StringFormat("📌 %s SL recalc at fill: %.5f [VirtualSL=%.1fpts]",
         p.tpBucket==0?"RUNNER":"TP",nSL,vsl/GetPointsize())); }

   // Validate SL on correct side and not inverted
   if(nSL>0)
   { if(p.direction==1  && nSL >= bp)    { Log("⛔ BUY SL above entry — aborting");  return; }
     if(p.direction==-1 && nSL <= bp)    { Log("⛔ SELL SL below entry — aborting"); return; }
     if(p.direction==1  && nSL>=bp-mn)   { Log("⛔ BUY SL too close");  return; }
     if(p.direction==-1 && nSL<=bp+mn)   { Log("⛔ SELL SL too close"); return; } }

   // Validate TP on correct side — switch to RUNNER if inverted
   if(nTP>0)
   { if(p.direction==1&&nTP<=bp+mn){Log("⛔ BUY TP below entry — using RUNNER");nTP=0;}
     if(p.direction==-1&&nTP>=bp-mn){Log("⛔ SELL TP above entry — using RUNNER");nTP=0;} }

   double pt=SymbolInfoDouble(_Symbol,SYMBOL_POINT);
   int jit=MathRand()%3;
   double jp=NormalizeDouble(bp+(p.direction==1?jit*pt:-jit*pt),dg);
   trade.SetExpertMagicNumber(MagicNumber);trade.SetDeviationInPoints(Slippage);trade.SetTypeFilling(GetFill());
   string cmt="LinerX V8.0 "+p.bucket;
   bool ok=(p.direction==1)?trade.PositionOpen(_Symbol,ORDER_TYPE_BUY, p.lot,jp,nSL,nTP,cmt)
                           :trade.PositionOpen(_Symbol,ORDER_TYPE_SELL,p.lot,jp,nSL,nTP,cmt);
   if(ok){ulong tk=trade.ResultOrder();
     if(tk>0&&PositionSelectByTicket(tk)&&g_openTradeCount<200)
     { int idx=g_openTradeCount++;double op=PositionGetDouble(POSITION_PRICE_OPEN);
       g_openTrades[idx].ticket=tk;g_openTrades[idx].openPrice=op;g_openTrades[idx].originalLots=p.lot;
       g_openTrades[idx].direction=p.direction;g_openTrades[idx].slPrice=nSL;
       g_openTrades[idx].assignedTP=nTP;g_openTrades[idx].tpBucket=p.tpBucket;
       Log("✅ "+cmt+" #"+IntegerToString((int)tk)+" @"+DoubleToString(op,dg)+
           (nSL>0?" SL="+DoubleToString(nSL,dg)+(UseATRBasedSL?" [ATR]":" [Fx]"):" SL=NONE")+
           (nTP>0?" TP="+DoubleToString(nTP,dg):" RUNNER"));}}
   else Log("❌ Open FAILED err="+IntegerToString(GetLastError()));
}

void ProcessPendingQueue()
{ if(g_pendingCount<=0)return;
  if(!UseHumanDelay){while(g_pendingCount>0)OpenOneFromQueue();return;}
  uint now=GetTickCount();if(now-g_lastOpenMs<g_nextDelayMs)return;
  int burstMax=2;
  for(int b=0;b<burstMax&&g_pendingCount>0;b++)
  { OpenOneFromQueue(); g_lastOpenMs=now; }
  g_nextDelayMs=HumanDelay_MinMs+MathRand()%(MathMax(1,HumanDelay_MaxMs-HumanDelay_MinMs)+1);}

void ManageTrade()
{ for(int i=g_openTradeCount-1;i>=0;i--)
  { if(!PositionSelectByTicket(g_openTrades[i].ticket)){for(int j=i;j<g_openTradeCount-1;j++)g_openTrades[j]=g_openTrades[j+1];g_openTradeCount--;continue;}
    if(g_openTrades[i].tpBucket==0||g_openTrades[i].assignedTP<=0)continue;
    if(!PositionSelectByTicket(g_openTrades[i].ticket))continue;   // re-select before GetDouble
    double brokerTP=PositionGetDouble(POSITION_TP);
    // If user manually changed TP in MT5 UI, broker handles the close — skip EA management
    if(brokerTP>0 && MathAbs(brokerTP-g_openTrades[i].assignedTP)>ScaledPip()) continue;
    double cp=PositionGetDouble(POSITION_PRICE_CURRENT);int dir=g_openTrades[i].direction;
    bool hit=(dir==1)?(cp>=g_openTrades[i].assignedTP):(cp<=g_openTrades[i].assignedTP);
    if(hit){trade.SetTypeFilling(GetFill());
      if(trade.PositionClose(g_openTrades[i].ticket)){Log("🎯 TP"+IntegerToString(g_openTrades[i].tpBucket)+" hit");
        for(int j=i;j<g_openTradeCount-1;j++)g_openTrades[j]=g_openTrades[j+1];g_openTradeCount--;}}}}

//| UNIFIED TRADE MANAGER                                           |
double GetUnifiedR(ulong t,double op,double rd,int d){if(!PositionSelectByTicket(t)||rd<=0)return 0;double cp=PositionGetDouble(POSITION_PRICE_CURRENT);return((d==POSITION_TYPE_BUY)?(cp-op):(op-cp))/rd;}
double GetRiskDistance(ulong t,double op,int d)
{
   if(!PositionSelectByTicket(t))return 0;
   double sl=PositionGetDouble(POSITION_SL);
   if(sl>0) return MathAbs(op-sl);
   // No hard SL — use VirtualSL_Points for BE calculation
   if(VirtualSL_Points>0) return VirtualSL_Points*GetPointsize();
   if(SL_Points>0) return SL_Points*GetPointsize();
   return 0;
}

void UnifiedScanAndEnroll()
{
   int dg=(int)SymbolInfoInteger(_Symbol,SYMBOL_DIGITS);
   for(int i=0;i<PositionsTotal();i++)
   { ulong tk=PositionGetTicket(i);if(!PositionSelectByTicket(tk))continue;
     if(PositionGetString(POSITION_SYMBOL)!=_Symbol)continue;
     ulong mg=(ulong)PositionGetInteger(POSITION_MAGIC);bool isEA=(mg==MagicNumber),isMn=(mg==0&&ManageManualTrades);if(!isEA&&!isMn)continue;
     bool found=false;
     for(int j=0;j<g_unifiedPosCount;j++){if(g_unifiedPositions[j].ticket==tk){found=true;double cp=PositionGetDouble(POSITION_PRICE_CURRENT);
       if(g_unifiedPositions[j].direction==POSITION_TYPE_BUY){if(cp>g_unifiedPositions[j].highWaterMark)g_unifiedPositions[j].highWaterMark=cp;}
       else{if(cp<g_unifiedPositions[j].highWaterMark)g_unifiedPositions[j].highWaterMark=cp;}break;}}
     if(found)continue;
     int d2=(int)PositionGetInteger(POSITION_TYPE);if(d2!=POSITION_TYPE_BUY&&d2!=POSITION_TYPE_SELL)continue;
     double op=PositionGetDouble(POSITION_PRICE_OPEN),rd=GetRiskDistance(tk,op,d2),cp=PositionGetDouble(POSITION_PRICE_CURRENT);
     ArrayResize(g_unifiedPositions,g_unifiedPosCount+1);
     g_unifiedPositions[g_unifiedPosCount].ticket=tk;g_unifiedPositions[g_unifiedPosCount].direction=d2;
     g_unifiedPositions[g_unifiedPosCount].openPrice=op;g_unifiedPositions[g_unifiedPosCount].riskDistance=rd;
     g_unifiedPositions[g_unifiedPosCount].highWaterMark=cp;g_unifiedPositions[g_unifiedPosCount].beDone=false;
     g_unifiedPositions[g_unifiedPosCount].isEATrade=isEA;g_unifiedPosCount++;
     // Late enrollment check — if trade already past BE threshold, skip BE and go to trail
     if(rd>0)
     { double r=GetUnifiedR(tk,op,rd,d2);
       if(r>=TriggerBE_R)
         g_unifiedPositions[g_unifiedPosCount-1].beDone=true; }
     if(UseATRBasedSL&&PositionGetDouble(POSITION_SL)==0)
     { double a=GetATRSlDist();if(a>0){double as=(d2==POSITION_TYPE_BUY)?NormalizeDouble(op-a,dg):NormalizeDouble(op+a,dg);
       if(trade.PositionModify(tk,as,PositionGetDouble(POSITION_TP)))g_unifiedPositions[g_unifiedPosCount-1].riskDistance=a;}}
   }
   // Single summary log — only once per session, not every tick
   static bool lateEnrollLogged = false;
   if(!lateEnrollLogged)
   { int lateCount=0; double lateMinR=DBL_MAX; double lateMaxR=0;
     for(int i=0;i<g_unifiedPosCount;i++)
     { if(!g_unifiedPositions[i].beDone) continue;
       if(g_unifiedPositions[i].riskDistance<=0) continue;
       double r=GetUnifiedR(g_unifiedPositions[i].ticket,g_unifiedPositions[i].openPrice,
                            g_unifiedPositions[i].riskDistance,g_unifiedPositions[i].direction);
       if(r>=TriggerBE_R){lateCount++;if(r<lateMinR)lateMinR=r;if(r>lateMaxR)lateMaxR=r;}}
     if(lateCount>0)
     { Log(StringFormat("🛡️ ENROLL LATE | %d trades already past BE (R=%.2f–%.2f) | trail active immediately",
           lateCount,lateMinR,lateMaxR));
       lateEnrollLogged=true; }}
   for(int i=g_unifiedPosCount-1;i>=0;i--){if(!PositionSelectByTicket(g_unifiedPositions[i].ticket)){for(int j=i;j<g_unifiedPosCount-1;j++)g_unifiedPositions[j]=g_unifiedPositions[j+1];g_unifiedPosCount--;ArrayResize(g_unifiedPositions,g_unifiedPosCount);}}
}

