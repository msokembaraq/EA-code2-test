   if(g_rsiHandle != INVALID_HANDLE) IndicatorRelease(g_rsiHandle);
  }

//+------------------------------------------------------------------+
int OnCalculate(
   const int rates_total,
   const int prev_calculated,
   const datetime &time[],
   const double   &open[],
   const double   &high[],
   const double   &low[],
   const double   &close[],
   const long     &tick_volume[],
   const long     &volume[],
   const int      &spread[])
  {
   if(rates_total < RSI_Length + 10) return 0;

   if(g_rsiHandle == INVALID_HANDLE)
     { g_rsiHandle = iRSI(_Symbol, PERIOD_CURRENT, RSI_Length, PRICE_CLOSE);
       if(g_rsiHandle == INVALID_HANDLE) return 0; }

   double rsiTemp[];
   ArraySetAsSeries(rsiTemp, true);
   if(CopyBuffer(g_rsiHandle, 0, 0, rates_total, rsiTemp) <= 0) return 0;

   double atrRaw[];
   ArraySetAsSeries(atrRaw, true);
   bool atrReady = (CopyBuffer(g_atrHandle, 0, 0, rates_total, atrRaw) == rates_total);

   if(prev_calculated == 0)
     {
      ArrayResize(g_lv, 0); g_nLv = 0;
      g_lastFlipBar        = -1;
      g_isRanging          = false; g_rangePH = 0.0; g_rangePL = 0.0;
      g_lastRSIRevDir      = 0;     g_lastRSIRevTime  = 0;
      g_lastRSINowDir      = 0;     g_lastRSINowTime  = 0;
      g_lastRBSSBRDir      = 0;
      g_lastRBSTime        = 0;
      g_lastSBRTime        = 0;
      g_lastRSRevDir       = 0;     g_lastRSRevTime   = 0;
      g_lastAlertTime      = 0;
      g_lastRSIRevFireTime = 0;
      g_msDir              = 0;
      g_pathA_dir          = 0; g_pathA_armTime = 0; g_pathA_armed = false;
      g_pathB_dir          = 0; g_pathB_armTime = 0; g_pathB_armed = false;
      g_confluenceTime     = 0; g_confluenceDir = 0;
      g_pathBLastFiredDir  = 0;
      g_lastSweepHTFBar    = 0;
      g_rangeBreakUp       = false;
      g_rangeBreakDown     = false;
      InitPendingSignals();
      g_fibValid = false; g_fibLow = 0; g_fibHigh = 0;
      g_fibSD1H = 0; g_fibSD2H = 0; g_fibSD1L = 0; g_fibSD2L = 0;
      g_intFibValid = false; g_intFibLow = 0; g_intFibHigh = 0;
      g_intFibSD1H = 0; g_intFibSD2H = 0; g_intFibSD1L = 0; g_intFibSD2L = 0;
      g_intRangeBreakUp = false; g_intRangeBreakDown = false;
      g_intPrevHigh = 0; g_intPrevLow = 0;
     }

   if(atrReady)
      CalcRS(rates_total, prev_calculated, close, atrRaw, time);

   static double maxMin       = 0;
   static double acceleration = SAR_Start;
   static bool   isBelow      = false;

   if(prev_calculated == 0)
     { maxMin = 0; acceleration = SAR_Start; isBelow = false; }

   int start = (prev_calculated == 0) ? RSI_Length : MathMax(prev_calculated - 1, RSI_Length);

   //── ENGINE 1: RSI PSAR ─────────────────────────────────────────
   for(int i = start; i < rates_total; i++)
     {
      RSI_Buffer[i]  = rsiTemp[rates_total - 1 - i];
      double prev_rsi     = RSI_Buffer[i-1];
      double prev_rsi2    = (i >= 2) ? RSI_Buffer[i-2] : RSI_Buffer[i-1];
      double sar_result   = (i > 0) ? SAR_Internal[i-1] : RSI_Buffer[i];
      bool   prev_isBelow = isBelow;

      CalculateSAR(i, RSI_Buffer[i], prev_rsi, prev_rsi2,
                   sar_result, isBelow, maxMin, acceleration);

      SAR_Internal[i]   = sar_result;
      IsBelow_Buffer[i] = isBelow ? 1 : 0;

      if(DisplaySAR)
         SAR_Buffer[i] = (i > 0 && IsBelow_Buffer[i] != IsBelow_Buffer[i-1])
                         ? EMPTY_VALUE : sar_result;
      else
         SAR_Buffer[i] = EMPTY_VALUE;

      bool sig_up   = (isBelow != prev_isBelow) && isBelow;
      bool sig_dn   = (isBelow != prev_isBelow) && !isBelow;
      bool s_sig_up = sig_up && (sar_result <= Lower_Threshold);
      bool s_sig_dn = sig_dn && (sar_result >= Upper_Threshold);

      double rsTrend    = (atrReady && i < rates_total) ? g_rsTrendArr[i] : 0.0;
      bool   rsGateBull = (rsTrend > 0.0);
      bool   rsGateBear = (rsTrend < 0.0);

      bool gated_sig_up = sig_up && (sar_result >= Lower_Threshold) && (g_lastRBSSBRDir != -1);
      bool gated_sig_dn = sig_dn && (sar_result <= Upper_Threshold) && (g_lastRBSSBRDir !=  1);

      SigUp_Buffer[i]    = gated_sig_up ? sar_result : EMPTY_VALUE;
      SigDn_Buffer[i]    = gated_sig_dn ? sar_result : EMPTY_VALUE;
      StrongUp_Buffer[i] = s_sig_up     ? sar_result : EMPTY_VALUE;
      StrongDn_Buffer[i] = s_sig_dn     ? sar_result : EMPTY_VALUE;

      //── Range detection on confirmed closed bar ──────────────────
      if(i == rates_total - 2)
        {
         double   recentPH = 0.0, recentPL = DBL_MAX;
         datetime recentPHTime = 0, recentPLTime = 0;

         for(int k = 0; k < g_nLv; k++)
           {
            if(g_lv[k].broken) continue;
            if( g_lv[k].isHigh && g_lv[k].t1 > recentPHTime)
              { recentPH = g_lv[k].price; recentPHTime = g_lv[k].t1; }
            if(!g_lv[k].isHigh && g_lv[k].t1 > recentPLTime)
              { recentPL = g_lv[k].price; recentPLTime = g_lv[k].t1; }
           }

         bool hasBothPivots = (recentPHTime > 0 && recentPLTime > 0);
         bool wasRanging    = g_isRanging;

         if(hasBothPivots)
           {
            g_rangePH          = recentPH;
            g_rangePL          = recentPL;
            double c           = close[i];
            double rangeWidth  = g_rangePH - g_rangePL;
            double curAtrRange = atrReady ? atrRaw[rates_total - 1 - i] : 0;
            bool   inBox       = (c < g_rangePH && c > g_rangePL);
            bool   tightEnough = (curAtrRange > 0 && rangeWidth < InpRangeMinATR * curAtrRange);
            g_isRanging        = inBox && tightEnough;

            if(g_isRanging && !wasRanging)
               FireAlert("⏸ RANGING — SIGNALS PAUSED | " + _Symbol + " " +
                         EnumToString((ENUM_TIMEFRAMES)_Period) +
                         " | Box:" + DoubleToString(g_rangePL, _Digits) +
                         "-"       + DoubleToString(g_rangePH, _Digits) +
                         " | Width:$" + DoubleToString(rangeWidth, 2) +
                         " | ATR×" + DoubleToString(InpRangeMinATR, 1) +
                         "=$"      + DoubleToString(InpRangeMinATR * curAtrRange, 2), true);

            if(!g_isRanging && wasRanging)
               FireAlert("▶ RANGE BROKEN — SIGNALS LIVE | " + _Symbol + " " +
                         EnumToString((ENUM_TIMEFRAMES)_Period) +
                         " | Breakout:" + DoubleToString(c, _Digits), true);
           }
         else
            g_isRanging = false;

         // ── Check pending signals on every confirmed bar ──────────
         // Note: runs even when ranging (hold through range by design)
         if(prev_calculated > 0)
            CheckPendingSignals(close, high, low, i, time[i]);
        }

      //── RSI alerts on confirmed closed bar ───────────────────────
      if(i == rates_total - 2 && !g_isRanging && prev_calculated > 0)
        {
         double curAtr = atrReady ? atrRaw[rates_total - 1 - i] : 0;

         if(s_sig_up && !(g_lastRSIRevDir == 1 &&
            (time[i] - g_lastRSIRevFireTime) < (datetime)(InpSeqLookback * PeriodSeconds())))
           { g_lastRSIRevDir = 1; g_lastRSIRevTime = time[i]; g_lastRSIRevFireTime = time[i];
             int riBuyRevBias=0; GetFibZone(close[i], riBuyRevBias);
             FireAlert("RSI BUY REVERSAL ◈ " + (rsGateBull ? "✅ SAFE" : "⚠️ RISK") +
                       " | " + _Symbol + " " + EnumToString((ENUM_TIMEFRAMES)_Period) +
                       FibTag(close[i], 1) + IntFibTag(close[i], 1),
                       false, riBuyRevBias == 1);
             g_lastAlertTime = time[i];
             CheckSequence(SEQ_RSI_REV, 1, time[i], close[i], curAtr); }
         else if(s_sig_dn && !(g_lastRSIRevDir == -1 &&
            (time[i] - g_lastRSIRevFireTime) < (datetime)(InpSeqLookback * PeriodSeconds())))
           { g_lastRSIRevDir = -1; g_lastRSIRevTime = time[i]; g_lastRSIRevFireTime = time[i];
             int riSellRevBias=0; GetFibZone(close[i], riSellRevBias);
             FireAlert("RSI SELL REVERSAL ◈ " + (rsGateBear ? "✅ SAFE" : "⚠️ RISK") +
                       " | " + _Symbol + " " + EnumToString((ENUM_TIMEFRAMES)_Period) +
                       FibTag(close[i], -1) + IntFibTag(close[i], -1),
                       false, riSellRevBias == -1);
             g_lastAlertTime = time[i];
             CheckSequence(SEQ_RSI_REV, -1, time[i], close[i], curAtr); }
         else if(gated_sig_up && g_lastRSINowDir != 1 && time[i] != g_lastAlertTime)
           { g_lastRSINowDir = 1; g_lastRSINowTime = time[i];
             int riBuyNowBias=0; GetFibZone(close[i], riBuyNowBias);
             FireAlert("RSI BUY NOW ◇ | " + _Symbol + " " +
                       EnumToString((ENUM_TIMEFRAMES)_Period) +
                       FibTag(close[i], 1) + IntFibTag(close[i], 1),
                       false, riBuyNowBias == 1);
             g_lastAlertTime = time[i];
             CheckSequence(SEQ_RSI_NOW, 1, time[i], close[i], curAtr); }
         else if(gated_sig_dn && g_lastRSINowDir != -1 && time[i] != g_lastAlertTime)
           { g_lastRSINowDir = -1; g_lastRSINowTime = time[i];
             int riSellNowBias=0; GetFibZone(close[i], riSellNowBias);
             FireAlert("RSI SELL NOW ◇ | " + _Symbol + " " +
                       EnumToString((ENUM_TIMEFRAMES)_Period) +
                       FibTag(close[i], -1) + IntFibTag(close[i], -1),
                       false, riSellNowBias == -1);
             g_lastAlertTime = time[i];
             CheckSequence(SEQ_RSI_NOW, -1, time[i], close[i], curAtr); }
        }
     }

   //── ENGINE 2: PIVOT DETECTION ──────────────────────────────────
   int pivStart = (prev_calculated == 0)
                  ? InpSwingLeft
                  : MathMax(InpSwingLeft, prev_calculated - InpSwingRight - 1);

   for(int i = pivStart; i < rates_total; i++)
     {
      int pBar = i - InpSwingRight;
      if(pBar < InpSwingLeft) continue;

      if(IsPivotHigh(high, pBar, InpSwingLeft, InpSwingRight, rates_total))
        {
         bool exists = false;
         for(int k = 0; k < g_nLv; k++)
            if(g_lv[k].isHigh && g_lv[k].t1 == time[pBar]) { exists = true; break; }
         if(!exists)
            AddLevel(high[pBar], high[pBar], low[pBar], time[pBar], true);
        }

      if(IsPivotLow(low, pBar, InpSwingLeft, InpSwingRight, rates_total))
        {
         bool exists = false;
         for(int k = 0; k < g_nLv; k++)
            if(!g_lv[k].isHigh && g_lv[k].t1 == time[pBar]) { exists = true; break; }
         if(!exists)
            AddLevel(low[pBar], high[pBar], low[pBar], time[pBar], false);
        }

      for(int j = 0; j < g_nLv; j++)
        {
         if(g_lv[j].broken) continue;
         if(g_lv[j].isHigh ? (close[i] > g_lv[j].top) : (close[i] < g_lv[j].bot))
            g_lv[j].broken = true;
        }
     }

   UpdateMarketStructure();

   // ── Fib context — re-anchor from updated swing data ────────────
   // Runs every bar: only actually re-anchors when a new HH or LL is detected
   if(rates_total >= 2)
     {
      RecalcFibLevels(close[rates_total - 2]);
      RecalcIntFibLevels(close[rates_total - 2]);
     }

   //── ENGINE 3b: LIQUIDITY SWEEP DETECTION — HTF candles ────────
   // Runs only when a new HTF bar closes (InpSweepHTF default M30)
   // Checks g_lv[] pivot levels against HTF wick/engulfing patterns
   // Prevents false sweeps from noisy LTF candles
   {
    datetime htfBarTime = iTime(_Symbol, InpSweepHTF, 1);  // last closed HTF bar
    if(prev_calculated > 0 && htfBarTime != g_lastSweepHTFBar && htfBarTime > 0)
      {
       g_lastSweepHTFBar = htfBarTime;

       // HTF candle data — last two closed bars
       double htfH1 = iHigh (_Symbol, InpSweepHTF, 1);
       double htfL1 = iLow  (_Symbol, InpSweepHTF, 1);
       double htfO1 = iOpen (_Symbol, InpSweepHTF, 1);
       double htfC1 = iClose(_Symbol, InpSweepHTF, 1);
       double htfH2 = iHigh (_Symbol, InpSweepHTF, 2);
       double htfO2 = iOpen (_Symbol, InpSweepHTF, 2);
       double htfC2 = iClose(_Symbol, InpSweepHTF, 2);

       double curAtrLq = atrReady ? atrRaw[1] : 0;

       for(int j = 0; j < g_nLv; j++)
         {
          if(g_lv[j].broken) continue;
          if(g_lv[j].swept)  continue;

          //── BUY-SIDE LIQUIDITY SWEEP ──────────────────────────
          // Sell stops above swing HIGH taken — expect SELL after
          if(g_lv[j].isHigh)
            {
             bool wickSweep = (htfH1  >= g_lv[j].price &&
                               htfC1  <  g_lv[j].price &&
                               htfO1  <  g_lv[j].price &&
                               UpperWickRatio(htfO1, htfH1, htfL1, htfC1) >= InpWickRatioMin);

             bool dualSweep = (htfC2  >  g_lv[j].price &&
                               htfC1  <  g_lv[j].price &&
                               IsBearishEngulfing(htfO1, htfC1, htfO2, htfC2));

             if(wickSweep || dualSweep)
               {
                g_lv[j].swept      = true;
                string sweepType   = wickSweep ? "WICK" : "DUAL";
                int    lqBias      = 0;
                GetFibZone(htfC1, lqBias);

                // TP levels — fib-based when valid, fallback to swing pivots
                string tpStr = "";
                if(g_fibValid)
                  {
                   double r    = g_fibHigh - g_fibLow;
                   double tp1  = NormalizeDouble(g_fibLow + 0.5   * r, _Digits);  // 0.5 EQ
                   double tp2  = NormalizeDouble(g_fibLow + 0.236 * r, _Digits);  // 0.236 discount
                   double tp3  = NormalizeDouble(g_fibLow,             _Digits);  // 0.0 anchor
                   tpStr = " | TP1:" + DoubleToString(tp1, _Digits) +
                           " TP2:"  + DoubleToString(tp2, _Digits) +
                           " TP3:"  + DoubleToString(tp3, _Digits);
                  }
                else
                  {
                   // Fallback — nearest unbroken swing lows below current price
                   double tp[]; GetNextPivots(false, htfC1, tp, 3);
                   for(int t = 0; t < 3; t++)
                      tpStr += " TP" + IntegerToString(t+1) + ":" +
                               (tp[t] > 0 ? DoubleToString(tp[t], _Digits) : "N/A");
                  }

                string lqMsg = "💧 BUY-SIDE LQ SWEPT [" + sweepType + "] " +
                               EnumToString(InpSweepHTF) + " | " +
                               _Symbol + " " + EnumToString((ENUM_TIMEFRAMES)_Period) +
                               " | Level:" + DoubleToString(g_lv[j].price, _Digits) +
                               tpStr +
                               FibTag(htfC1, -1);
                FireAlert(lqMsg, false, lqBias == -1);
                Print("[LQ SWEEP] Buy-side swept at ",
                      DoubleToString(g_lv[j].price, _Digits),
                      " [", sweepType, "] HTF:", EnumToString(InpSweepHTF),
                      " | expect SELL | ", _Symbol);
                CheckSequence(SEQ_LIQSWEEP, -1, htfBarTime, htfC1, curAtrLq);
               }
            }

          //── SELL-SIDE LIQUIDITY SWEEP ─────────────────────────
          // Buy stops below swing LOW taken — expect BUY after
          if(!g_lv[j].isHigh)
            {
             bool wickSweep = (htfL1  <= g_lv[j].price &&
                               htfC1  >  g_lv[j].price &&
                               htfO1  >  g_lv[j].price &&
                               LowerWickRatio(htfO1, htfH1, htfL1, htfC1) >= InpWickRatioMin);

             bool dualSweep = (htfC2  <  g_lv[j].price &&
                               htfC1  >  g_lv[j].price &&
                               IsBullishEngulfing(htfO1, htfC1, htfO2, htfC2));

             if(wickSweep || dualSweep)
               {
                g_lv[j].swept      = true;
                string sweepType   = wickSweep ? "WICK" : "DUAL";
                int    lqBias      = 0;
                GetFibZone(htfC1, lqBias);

                // TP levels — fib-based when valid, fallback to swing pivots
                string tpStr = "";
                if(g_fibValid)
                  {
                   double r    = g_fibHigh - g_fibLow;
                   double tp1  = NormalizeDouble(g_fibLow + 0.5   * r, _Digits);  // 0.5 EQ
                   double tp2  = NormalizeDouble(g_fibLow + 0.786 * r, _Digits);  // 0.786 premium
                   double tp3  = NormalizeDouble(g_fibHigh,            _Digits);  // 1.0 anchor
                   tpStr = " | TP1:" + DoubleToString(tp1, _Digits) +
                           " TP2:"  + DoubleToString(tp2, _Digits) +
                           " TP3:"  + DoubleToString(tp3, _Digits);
                  }
                else
                  {
                   // Fallback — nearest unbroken swing highs above current price
                   double tp[]; GetNextPivots(true, htfC1, tp, 3);
                   for(int t = 0; t < 3; t++)
                      tpStr += " TP" + IntegerToString(t+1) + ":" +
                               (tp[t] > 0 ? DoubleToString(tp[t], _Digits) : "N/A");
                  }

                string lqMsg = "💧 SELL-SIDE LQ SWEPT [" + sweepType + "] " +
                               EnumToString(InpSweepHTF) + " | " +
                               _Symbol + " " + EnumToString((ENUM_TIMEFRAMES)_Period) +
                               " | Level:" + DoubleToString(g_lv[j].price, _Digits) +
                               tpStr +
                               FibTag(htfC1, 1);
                FireAlert(lqMsg, false, lqBias == 1);
                Print("[LQ SWEEP] Sell-side swept at ",
                      DoubleToString(g_lv[j].price, _Digits),
                      " [", sweepType, "] HTF:", EnumToString(InpSweepHTF),
                      " | expect BUY | ", _Symbol);
                CheckSequence(SEQ_LIQSWEEP, 1, htfBarTime, htfC1, curAtrLq);
               }
            }
         }
      }
   }

   //── ENGINE 3: RBS/SBR ──────────────────────────────────────────
   int lastBar = rates_total - 1;
   bool rbs_suppressed_logged = false;  // log suppression once per bar max
   bool sbr_suppressed_logged = false;
   if(prev_calculated > 0 && lastBar != g_lastFlipBar && !g_isRanging)
     {
      g_lastFlipBar = lastBar;
      int prevBar   = lastBar - 1;

      for(int j = 0; j < g_nLv; j++)
        {
         if(!g_lv[j].broken)     continue;
         if(g_lv[j].flipAlerted) continue;

         //── RBS BUY ──────────────────────────────────────────────
         if(g_lv[j].isHigh &&
            close[prevBar] <= g_lv[j].top &&
            close[lastBar]  > g_lv[j].top &&
            (time[lastBar] - g_lastRBSTime) > (datetime)(PeriodSeconds() * InpSameDirCooldownBars))
           {
            if(InpHTFGateEnable && GlobalVariableCheck(InpSRZonesDirVar))
              {
               double srDir = GlobalVariableGet(InpSRZonesDirVar);
               // Fib zone override — allow trade if price is in confirmed buy/sell zone
               // regardless of HTF direction (range trade overrides trend gate)
               int fibBiasRBS = 0;
               GetFibZone(close[lastBar], fibBiasRBS);
               bool fibOverride = (fibBiasRBS == 1);  // price in discount zone = allow BUY
               if(!fibOverride && srDir != 1.0)
                 {
                  if(!rbs_suppressed_logged)
                    { Print("[HTF GATE] RBS BUY suppressed — SR Zones dir=", srDir);
                      rbs_suppressed_logged = true; }
                  continue;
                 }
               if(fibOverride && srDir != 1.0)
                  Print("[HTF GATE] RBS BUY allowed — FIB DISCOUNT zone override | SR dir=", srDir);
               // Time staleness check removed for RBS/SBR — direction is sufficient gate
              }

            g_lv[j].flipAlerted = true;
            g_lastRBSSBRDir     = 1;
            g_lastRBSTime       = time[lastBar];
            double tp[];
            GetNextPivots(true, g_lv[j].top, tp, 3);
            string tpStr = "";
            for(int t = 0; t < 3; t++)
               tpStr += " TP" + IntegerToString(t+1) + ":" +
                        (tp[t] > 0 ? DoubleToString(tp[t], _Digits) : "N/A") +
                        (t < 2 ? " |" : "");
            FireAlert("RBS BUY NOW | " + _Symbol + " " +
                      EnumToString((ENUM_TIMEFRAMES)_Period) +
                      " | ENTRY:" + DoubleToString(g_lv[j].bot, _Digits) +
                      "-"         + DoubleToString(g_lv[j].top, _Digits) +
                      " | SL:"    + DoubleToString(g_lv[j].bot, _Digits) +
                      " |"        + tpStr +
                      FibTag(close[lastBar], 1) + IntFibTag(close[lastBar], 1));
            // SBR/RBS exempt from swing gate: pass atr=0
            CheckSequence(SEQ_RBSSBR, 1, time[lastBar], close[lastBar], 0);
           }

         //── SBR SELL ─────────────────────────────────────────────
         if(!g_lv[j].isHigh &&
            close[prevBar] >= g_lv[j].bot &&
            close[lastBar]  < g_lv[j].bot &&
            (time[lastBar] - g_lastSBRTime) > (datetime)(PeriodSeconds() * InpSameDirCooldownBars))
           {
            if(InpHTFGateEnable && GlobalVariableCheck(InpSRZonesDirVar))
              {
               double srDir = GlobalVariableGet(InpSRZonesDirVar);
               // Fib zone override — allow SELL if price in confirmed premium zone
               int fibBiasSBR = 0;
               GetFibZone(close[lastBar], fibBiasSBR);
               bool fibOverride = (fibBiasSBR == -1);  // price in premium zone = allow SELL
               if(!fibOverride && srDir != -1.0)
                 {
                  if(!sbr_suppressed_logged)
                    { Print("[HTF GATE] SBR SELL suppressed — SR Zones dir=", srDir);
                      sbr_suppressed_logged = true; }
                  continue;
                 }
               if(fibOverride && srDir != -1.0)
                  Print("[HTF GATE] SBR SELL allowed — FIB PREMIUM zone override | SR dir=", srDir);
              }

            g_lv[j].flipAlerted = true;
            g_lastRBSSBRDir     = -1;
            g_lastSBRTime       = time[lastBar];
            double tp[];
            GetNextPivots(false, g_lv[j].bot, tp, 3);
            string tpStr = "";
            for(int t = 0; t < 3; t++)
               tpStr += " TP" + IntegerToString(t+1) + ":" +
                        (tp[t] > 0 ? DoubleToString(tp[t], _Digits) : "N/A") +
                        (t < 2 ? " |" : "");
            FireAlert("SBR SELL NOW | " + _Symbol + " " +
                      EnumToString((ENUM_TIMEFRAMES)_Period) +
                      " | ENTRY:" + DoubleToString(g_lv[j].top, _Digits) +
                      "-"         + DoubleToString(g_lv[j].bot, _Digits) +
                      " | SL:"    + DoubleToString(g_lv[j].top, _Digits) +
                      " |"        + tpStr +
                      FibTag(close[lastBar], -1) + IntFibTag(close[lastBar], -1));
            // SBR/RBS exempt from swing gate: pass atr=0
            CheckSequence(SEQ_RBSSBR, -1, time[lastBar], close[lastBar], 0);
           }
        }
     }

   return rates_total;
  }
//+------------------------------------------------------------------+
