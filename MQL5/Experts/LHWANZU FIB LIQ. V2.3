//════════════════════════════════════════════════════════════════════
//  INTERNAL FIB — inducement / fake range detection
//  Anchors to nearest unbroken swings INSIDE external EQ zone (0.236-0.786)
//  Same locking rules: ceiling only up, floor only up
//  Only valid when external fib is valid and range is meaningful
//════════════════════════════════════════════════════════════════════
bool   g_intFibValid       = false;
double g_intFibLow         = 0.0;   // internal 0 — fake range floor
double g_intFibHigh        = 0.0;   // internal 1 — fake range ceiling
double g_intFibSD1H        = 0.0;   // internal SD+1
double g_intFibSD2H        = 0.0;   // internal SD+2
double g_intFibSD1L        = 0.0;   // internal SD-1
double g_intFibSD2L        = 0.0;   // internal SD-2
bool   g_intRangeBreakUp   = false;
bool   g_intRangeBreakDown = false;
double g_intPrevHigh       = 0.0;
double g_intPrevLow        = 0.0;

//════════════════════════════════════════════════════════════════════
//  FIB CONTEXT — auto-anchored from nearest unbroken swings
//  Static anchor: updates only when new HH or LL confirmed by close
//  All SD levels derive from single range = fibHigh - fibLow
//════════════════════════════════════════════════════════════════════
bool   g_fibValid = false;
double g_fibLow   = 0.0;   // 0.000 anchor — nearest swing low below price
double g_fibHigh  = 0.0;   // 1.000 anchor — nearest swing high above price
double g_fibSD1H  = 0.0;   // +0.5 range above high  (SD+1)
double g_fibSD2H  = 0.0;   // +1.0 range above high  (SD+2)
double g_fibSD1L  = 0.0;   // -0.5 range below low   (SD-1)
double g_fibSD2L  = 0.0;   // -1.0 range below low   (SD-2)

void CalcFibLevels()
  {
   if(g_fibHigh <= g_fibLow) { g_fibValid = false; return; }
   double r   = g_fibHigh - g_fibLow;
   g_fibSD1H  = g_fibHigh + 0.5 * r;
   g_fibSD2H  = g_fibHigh + 1.0 * r;
   g_fibSD1L  = g_fibLow  - 0.5 * r;
   g_fibSD2L  = g_fibLow  - 1.0 * r;
   g_fibValid = true;
  }

// Auto-anchor: find nearest unbroken swing H above and swing L below current price
// Called on startup and on every confirmed bar (re-anchors on new HH or LL)
void RecalcFibLevels(double curPrice)
  {
   double nearH = 0, nearL = 0;
   double nearHDist = DBL_MAX, nearLDist = DBL_MAX;

   for(int k = 0; k < g_nLv; k++)
     {
      if(g_lv[k].broken) continue;
      if(g_lv[k].isHigh && g_lv[k].price > curPrice)
        {
         double d = g_lv[k].price - curPrice;
         if(d < nearHDist) { nearHDist = d; nearH = g_lv[k].price; }
        }
      if(!g_lv[k].isHigh && g_lv[k].price < curPrice)
        {
         double d = curPrice - g_lv[k].price;
         if(d < nearLDist) { nearLDist = d; nearL = g_lv[k].price; }
        }
     }

   if(nearH <= 0 || nearL <= 0 || nearH <= nearL) return;

   bool wasValid  = g_fibValid;
   bool highSame  = (MathAbs(nearH - g_fibHigh) <= _Point);
   bool lowSame   = (MathAbs(nearL  - g_fibLow)  <= _Point);
   if(wasValid && highSame && lowSame) return;

   // FIX #1: declare prevHigh/prevLow BEFORE overwriting anchors
   double prevHigh = g_fibHigh;
   double prevLow  = g_fibLow;

   // FIX #2: msDir-aware directional lock — ties anchor to market structure
   // Bullish: ceiling only up, floor only up (compression)
   // Bearish: ceiling only down, floor only down (expansion)
   // Flat/unknown: allow both directions
   if(wasValid)
     {
      if(g_msDir == 1)
        {
         if(nearH < g_fibHigh - _Point) return;  // ceiling only up in bull
         if(nearL  < g_fibLow  - _Point) return;  // floor only up in bull
        }
      else if(g_msDir == -1)
        {
         if(nearH > g_fibHigh + _Point) return;  // ceiling only down in bear
         if(nearL  > g_fibLow  + _Point) return;  // floor only down in bear
        }
      // g_msDir == 0 (flat) — allow any direction
     }

   g_fibHigh = nearH;
   g_fibLow  = nearL;
   CalcFibLevels();

   // FIX #3/4: range break flags — now work correctly because lock is directional
   if(wasValid)
     {
      if(nearH > prevHigh + _Point) { g_rangeBreakUp   = true;  g_rangeBreakDown = false; }
      if(nearL  < prevLow  - _Point) { g_rangeBreakDown = true;  g_rangeBreakUp   = false; }
     }
   else
     { g_rangeBreakUp = false; g_rangeBreakDown = false; }
   string fibMsg = StringFormat("[FIB] %s | Low=%s High=%s | SD+1=%s SD-1=%s | Range=$%s",
                   wasValid ? "Re-anchored" : "Anchored",
                   DoubleToString(g_fibLow, _Digits),
                   DoubleToString(g_fibHigh, _Digits),
                   DoubleToString(g_fibSD1H, _Digits),
                   DoubleToString(g_fibSD1L, _Digits),
                   DoubleToString(g_fibHigh - g_fibLow, 2));
   Print(fibMsg);
  }

// Returns fib zone label and sets bias: 1=buy zone -1=sell zone 0=neutral
string GetFibZone(double price, int &bias)
  {
   bias = 0;
   if(!g_fibValid) return "";
   double r = g_fibHigh - g_fibLow;
   if(r <= 0) return "";
   double p = (price - g_fibLow) / r;   // normalized position 0=low 1=high

   // SD levels (outside range)
   if(p <= -0.75) { bias =  1; return "SD-2 EXTREME DISCOUNT"; }
   if(p <= -0.25) { bias =  1; return "SD-1 DISCOUNT EXT"; }

   // Active range zones
   // BUY zone: 0.0 - 0.236 only
   if(p <=  0.10)  { bias =  1; return "FIB 0 ANCHOR LOW"; }
   if(p <=  0.236) { bias =  1; return "FIB 0.236 DISCOUNT"; }

   // Equilibrium zone: 0.236 - 0.786 — NO buy/sell bias normally
   // EXCEPTION: after range break UP   → 0.618 = RBS retracement BUY zone
   // EXCEPTION: after range break DOWN → 0.382 = SBR retracement SELL zone
   if(p <=  0.40)
     { bias = g_rangeBreakDown ? -1 : 0;
       return g_rangeBreakDown ? "FIB 0.382 SBR RETRACEMENT" : "FIB 0.382 EQ"; }
   if(p <=  0.60)  { bias =  0; return "FIB 0.5 EQ"; }
   if(p <=  0.70)
     { bias = g_rangeBreakUp ? 1 : 0;
       return g_rangeBreakUp ? "FIB 0.618 RBS RETRACEMENT" : "FIB 0.618 EQ"; }
   if(p <=  0.786) { bias =  0; return "FIB 0.75 NEUTRAL"; }

   // SELL zone: 0.786 - 1.0 only
   if(p <=  1.05)  { bias = -1; return "FIB 1.0 ANCHOR HIGH"; }

   // SD levels (outside range)
   if(p <=  1.35) { bias = -1; return "SD+1 PREMIUM EXT"; }
   if(p <=  1.75) { bias = -1; return "SD+2 EXTREME PREMIUM"; }
   if(p >   1.75) { bias = -1; return "SD+2+ ULTRA PREMIUM"; }

   bias = 0; return "OUTSIDE FIB";
  }

// Appends fib zone context to any signal message
// signalDir: 1=buy signal -1=sell signal 0=neutral/info
string FibTag(double price, int signalDir)
  {
   if(!g_fibValid) return "";
   int    bias = 0;
   string zone = GetFibZone(price, bias);
   if(zone == "") return "";

   string tag = " | 📐 " + zone;

   if(signalDir != 0)
     {
      if(bias == signalDir)       tag += " ✅";
      else if(bias == -signalDir) tag += " ⚠️";
     }

   // Append anchor prices for push context — always visible
   tag += " [0=" + DoubleToString(g_fibLow,  _Digits) +
          " | 1=" + DoubleToString(g_fibHigh, _Digits) + "]";

   return tag;
  }

//════════════════════════════════════════════════════════════════════
//  INTERNAL FIB — RecalcIntFibLevels / GetIntFibZone / IntFibTag
//════════════════════════════════════════════════════════════════════

void RecalcIntFibLevels(double curPrice)
  {
   if(!InpIntFibEnable || !g_fibValid) { g_intFibValid = false; return; }

   double extRange = g_fibHigh - g_fibLow;
   if(extRange <= 0) return;

   // Internal pivots must sit inside external EQ zone
   double eqLow  = g_fibLow + 0.236 * extRange;
   double eqHigh = g_fibLow + 0.786 * extRange;

   double nearH = 0, nearL = 0;
   double nearHDist = DBL_MAX, nearLDist = DBL_MAX;

   for(int k = 0; k < g_nLv; k++)
     {
      if(g_lv[k].broken) continue;
      if(g_lv[k].price < eqLow || g_lv[k].price > eqHigh) continue;

      if(g_lv[k].isHigh && g_lv[k].price > curPrice)
        {
         double d = g_lv[k].price - curPrice;
         if(d < nearHDist) { nearHDist = d; nearH = g_lv[k].price; }
        }
      if(!g_lv[k].isHigh && g_lv[k].price < curPrice)
        {
         double d = curPrice - g_lv[k].price;
         if(d < nearLDist) { nearLDist = d; nearL = g_lv[k].price; }
        }
     }

   if(nearH <= 0 || nearL <= 0 || nearH <= nearL)
     { g_intFibValid = false; return; }

   // Minimum size check
   double intRange = nearH - nearL;
   if(intRange < extRange * InpIntFibMinRatio)
     { g_intFibValid = false; return; }

   // Directional lock — msDir-aware, same as external fib
   bool wasValid = g_intFibValid;
   bool highSame = (MathAbs(nearH - g_intFibHigh) <= _Point);
   bool lowSame  = (MathAbs(nearL  - g_intFibLow)  <= _Point);
   if(wasValid && highSame && lowSame) return;

   // FIX: declare prevH/prevL BEFORE overwriting
   double prevH = g_intFibHigh;
   double prevL = g_intFibLow;

   if(wasValid)
     {
      if(g_msDir == 1)
        {
         if(nearH < g_intFibHigh - _Point) return;
         if(nearL  < g_intFibLow  - _Point) return;
        }
      else if(g_msDir == -1)
        {
         if(nearH > g_intFibHigh + _Point) return;
         if(nearL  > g_intFibLow  + _Point) return;
        }
     }
   g_intFibHigh     = nearH;
   g_intFibLow      = nearL;
   double r         = g_intFibHigh - g_intFibLow;
   g_intFibSD1H     = g_intFibHigh + 0.5 * r;
   g_intFibSD2H     = g_intFibHigh + 1.0 * r;
   g_intFibSD1L     = g_intFibLow  - 0.5 * r;
   g_intFibSD2L     = g_intFibLow  - 1.0 * r;
   g_intFibValid    = true;

   if(wasValid)
     {
      if(nearH > prevH + _Point) { g_intRangeBreakUp   = true;  g_intRangeBreakDown = false; }
      if(nearL  < prevL - _Point) { g_intRangeBreakDown = true;  g_intRangeBreakUp   = false; }
     }
   else { g_intRangeBreakUp = false; g_intRangeBreakDown = false; }

   Print("[INT-FIB] ", wasValid ? "Re-anchored" : "Anchored",
         " | Low=",  DoubleToString(g_intFibLow,  _Digits),
         " High=", DoubleToString(g_intFibHigh, _Digits),
         " | SD+1=", DoubleToString(g_intFibSD1H, _Digits),
         " | Range=$", DoubleToString(r, 2));
  }

string GetIntFibZone(double price, int &bias)
  {
   bias = 0;
   if(!g_intFibValid) return "";
   double r = g_intFibHigh - g_intFibLow;
   if(r <= 0) return "";
   double p = (price - g_intFibLow) / r;

   if(p <= -0.75) { bias =  1; return "INT SD-2 DISCOUNT"; }
   if(p <= -0.25) { bias =  1; return "INT SD-1 DISCOUNT"; }
   if(p <=  0.10) { bias =  1; return "INT FIB 0 LOW"; }
   if(p <=  0.236){ bias =  1; return "INT FIB 0.236 DISCOUNT"; }
   if(p <=  0.40)
     { bias = g_intRangeBreakDown ? -1 : 0;
       return g_intRangeBreakDown ? "INT 0.382 SBR RETRACEMENT" : "INT FIB 0.382 EQ"; }
   if(p <=  0.60) { bias =  0; return "INT FIB 0.5 EQ"; }
   if(p <=  0.70)
     { bias = g_intRangeBreakUp ? 1 : 0;
       return g_intRangeBreakUp ? "INT 0.618 RBS RETRACEMENT" : "INT FIB 0.618 EQ"; }
   if(p <=  0.786){ bias =  0; return "INT FIB 0.75 NEUTRAL"; }
   if(p <=  1.05) { bias = -1; return "INT FIB 1.0 HIGH"; }
   if(p <=  1.35) { bias = -1; return "INT SD+1 PREMIUM"; }
                    bias = -1; return "INT SD+2 PREMIUM";
  }

string IntFibTag(double price, int signalDir)
  {
   if(!g_intFibValid) return "";
   int    bias = 0;
   string zone = GetIntFibZone(price, bias);
   if(zone == "") return "";

   string tag = " | 🔷 " + zone;
   if(signalDir != 0)
     {
      if(bias == signalDir)       tag += " ✅";
      else if(bias == -signalDir) tag += " ⚠️";
     }
   tag += " [INT: 0=" + DoubleToString(g_intFibLow,  _Digits) +
          " | 1="     + DoubleToString(g_intFibHigh, _Digits) + "]";
   return tag;
  }
