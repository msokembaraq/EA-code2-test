//+------------------------------------------------------------------+
//  SEQUENCE ENGINE
//+------------------------------------------------------------------+
void CheckSequence(int sigType, int dir, datetime sigTime,
                   double refPrice, double atr)
  {
   if(!InpSeqEnable) return;

   long lookbackSecs = (long)InpSeqLookback * (long)PeriodSeconds();

   //── LIQUIDITY SWEEP — arms PATH A in OPPOSITE direction ──────────
   // Sweep dir passed is already the EXPECTED MOVE direction (opposite to sweep)
   // Buy-side swept → dir passed = -1 (SELL expected)
   // Sell-side swept → dir passed = +1 (BUY expected)
   if(sigType == SEQ_LIQSWEEP)
     {
      if(g_pathA_armed && g_pathA_dir != dir)
        { g_pathA_armed = false; g_pathA_dir = 0; g_pathA_armTime = 0; }
      if(g_pathB_armed && g_pathB_dir != dir)
        { g_pathB_armed = false; g_pathBLastFiredDir = 0; }

      g_pathA_dir     = dir;
      g_pathA_armTime = sigTime;
      g_pathA_armed   = true;

      // Check RS already confirmed within lookback
      if(g_lastRSRevDir == dir && g_lastRSRevTime > 0)
        {
         long diff = (long)(sigTime - g_lastRSRevTime);
         if(diff >= 0 && diff <= lookbackSecs)
           { FireConfluenceA(dir, sigTime, refPrice, atr); g_pathA_armed = false; return; }
        }
      // Check RSI already confirmed within lookback
      if(g_lastRSIRevDir == dir && g_lastRSIRevTime > 0)
        {
         long diff = (long)(sigTime - g_lastRSIRevTime);
         if(diff >= 0 && diff <= lookbackSecs)
           { FireConfluenceA(dir, sigTime, refPrice, atr); g_pathA_armed = false; return; }
        }
      if(g_lastRSINowDir == dir && g_lastRSINowTime > 0)
        {
         long diff = (long)(sigTime - g_lastRSINowTime);
         if(diff >= 0 && diff <= lookbackSecs)
           { FireConfluenceA(dir, sigTime, refPrice, atr); g_pathA_armed = false; return; }
        }
      return;
     }

   if(sigType == SEQ_RBSSBR)
     {
      if(g_pathA_armed && g_pathA_dir != dir)
        {
         FireAlert("🚫 SEQ CANCELLED | " + _Symbol + " " +
                   EnumToString((ENUM_TIMEFRAMES)_Period) +
                   " | Was:" + (g_pathA_dir == 1 ? "BUY" : "SELL") +
                   " → Now:" + (dir == 1 ? "BUY" : "SELL"));
        }
      g_pathA_dir     = dir;
      g_pathA_armTime = sigTime;
      g_pathA_armed   = true;
      if(g_pathB_armed && g_pathB_dir != dir)
        { g_pathB_armed = false; g_pathB_dir = 0; g_pathB_armTime = 0; }

      if(g_lastRSRevDir == dir && g_lastRSRevTime > 0)
        {
         long diff = (long)(sigTime - g_lastRSRevTime);
         if(diff >= 0 && diff <= lookbackSecs)
           // SBR/RBS exempt: atr=0 bypasses swing gate
           { FireConfluenceA(dir, sigTime, refPrice, 0); g_pathA_armed = false; return; }
        }
      if(g_lastRSIRevDir == dir && g_lastRSIRevTime > 0)
        {
         long diff = (long)(sigTime - g_lastRSIRevTime);
         if(diff >= 0 && diff <= lookbackSecs)
           { FireConfluenceA(dir, sigTime, refPrice, 0); g_pathA_armed = false; return; }
        }
      if(g_lastRSINowDir == dir && g_lastRSINowTime > 0)
        {
         long diff = (long)(sigTime - g_lastRSINowTime);
         if(diff >= 0 && diff <= lookbackSecs)
           { FireConfluenceA(dir, sigTime, refPrice, 0); g_pathA_armed = false; return; }
        }
      return;
     }

   if(sigType == SEQ_RS)
     {
      if(g_pathA_armed && g_pathA_dir != dir)
        { g_pathA_armed = false; g_pathA_dir = 0; g_pathA_armTime = 0; }
      if(g_pathA_armed && g_pathA_dir == dir && sigTime >= g_pathA_armTime)
        { FireConfluenceA(dir, sigTime, refPrice, atr); g_pathA_armed = false; return; }
      if(g_pathB_armed && g_pathB_dir == dir && sigTime >= g_pathB_armTime)
        { FireConfluenceB(dir, sigTime, refPrice, atr); g_pathB_armed = false; return; }
      return;
     }

   if(sigType == SEQ_RSI_REV || sigType == SEQ_RSI_NOW)
     {
      if(g_pathA_armed && g_pathA_dir != dir)
        { g_pathA_armed = false; g_pathA_dir = 0; g_pathA_armTime = 0; }
      if(g_pathB_armed && g_pathB_dir != dir)
        { g_pathB_armed = false; g_pathBLastFiredDir = 0; }

      if(g_pathBLastFiredDir == dir) return;

      if(g_pathA_armed && g_pathA_dir == dir && sigTime >= g_pathA_armTime)
        { FireConfluenceA(dir, sigTime, refPrice, atr); g_pathA_armed = false; }

      g_pathB_dir     = dir;
      g_pathB_armTime = sigTime;
      g_pathB_armed   = true;

      if(g_lastRSRevDir == dir && g_lastRSRevTime > 0)
        {
         long diff = (long)(sigTime - g_lastRSRevTime);
         if(diff >= 0 && diff <= lookbackSecs)
           { FireConfluenceB(dir, sigTime, refPrice, atr); g_pathB_armed = false; }
        }
      return;
     }
  }

//+------------------------------------------------------------------+
//  SAR CALCULATION
//+------------------------------------------------------------------+
void CalculateSAR(
   int i,
   double src,
   double prev_src,
   double prev_src2,
   double &result,
   bool &isBelow,
   double &maxMin,
   double &acceleration)
  {
   double src_high      = src + 1.0;
   double src_low       = src - 1.0;
   bool   isFirstTrendBar = false;

   if(i <= RSI_Length + 2)
     {
      if(src > prev_src)
        { isBelow = true;  maxMin = src_high; result = prev_src - 1.0; }
      else
        { isBelow = false; maxMin = src_low;  result = prev_src + 1.0; }
      isFirstTrendBar = true;
      acceleration    = SAR_Start;
     }

   result = result + acceleration * (maxMin - result);

   if(isBelow)
     {
      if(result > src_low)
        { isFirstTrendBar = true; isBelow = false;
          result = MathMax(src_high, maxMin); maxMin = src_low; acceleration = SAR_Start; }
     }
   else
     {
      if(result < src_high)
        { isFirstTrendBar = true; isBelow = true;
          result = MathMin(src_low, maxMin); maxMin = src_high; acceleration = SAR_Start; }
     }

   if(!isFirstTrendBar)
     {
      if(isBelow)
        { if(src_high > maxMin) { maxMin = src_high; acceleration = MathMin(acceleration + SAR_Inc, SAR_Max); } }
      else
        { if(src_low  < maxMin) { maxMin = src_low;  acceleration = MathMin(acceleration + SAR_Inc, SAR_Max); } }
     }

   if(isBelow)
     {
      result = MathMin(result, prev_src  - 1.0);
      if(i > 1) result = MathMin(result, prev_src2 - 1.0);
     }
   else
     {
      result = MathMax(result, prev_src  + 1.0);
      if(i > 1) result = MathMax(result, prev_src2 + 1.0);
     }
  }

//+------------------------------------------------------------------+
//  ROLLING SEGMENT
//+------------------------------------------------------------------+
void CalcRS(const int rates_total, const int prev_calculated,
            const double &close[], const double &atrRaw[],
            const datetime &time[])
  {
   ArrayResize(g_rsTrendArr, rates_total);
   ArrayResize(g_rollSegArr, rates_total);
   ArrayInitialize(g_rsTrendArr, 0.0);
   ArrayInitialize(g_rollSegArr, 0.0);

   if(rates_total < InpATRLen + 2) return;

   double rollSeg    = close[InpATRLen];
   double rsTrend    = 1.0;
   double actSlope   = 0.0;
   bool   isFastMode = false;

   g_rsTrendArr[InpATRLen] = rsTrend;
   g_rollSegArr[InpATRLen] = rollSeg;

   for(int i = InpATRLen + 1; i < rates_total; i++)
     {
      double atr = atrRaw[rates_total - 1 - i];
      if(atr <= 0.0 || atr >= EMPTY_VALUE || !MathIsValidNumber(atr))
        {
         g_rsTrendArr[i] = rsTrend;
         g_rollSegArr[i] = close[i];
         continue;
        }

      double dist    = close[i] - rollSeg;
      bool   bullRev = (rsTrend < 0) && ( dist >  InpRSRevThresh * atr);
      bool   bearRev = (rsTrend > 0) && (-dist >  InpRSRevThresh * atr);

      if(bullRev)      rsTrend =  1.0;
      else if(bearRev) rsTrend = -1.0;

      bool newFast = (MathAbs(dist) > InpRSFastThresh * atr);
      if(bullRev || bearRev || (newFast != isFastMode) || actSlope == 0.0)
        { isFastMode = newFast;
          actSlope   = isFastMode ? atr / InpRSFastLen : atr / InpRSSlowLen; }

      rollSeg += rsTrend * actSlope;

      g_rsTrendArr[i] = rsTrend;
      g_rollSegArr[i] = rollSeg;

      if(i == rates_total - 2 && !g_isRanging && prev_calculated > 0)
        {
         double curAtr = atrRaw[rates_total - 1 - i];
         if(bullRev && g_lastRSRevDir != 1)
           {
            g_lastRSRevDir  = 1;
            g_lastRSRevTime = time[i];
            string rsBuyMsg = "📈 RS BUY EMA CROSS| " + _Symbol + " " +
                      EnumToString((ENUM_TIMEFRAMES)_Period) +
                      " | Price:" + DoubleToString(close[i], _Digits) +
                      FibTag(close[i], 1) + IntFibTag(close[i], 1);
            int rsBuyBias = 0; GetFibZone(close[i], rsBuyBias);
            FireAlert(rsBuyMsg, false, rsBuyBias == 1);
            CheckSequence(SEQ_RS, 1, time[i], close[i], curAtr);
           }
         else if(bearRev && g_lastRSRevDir != -1)
           {
            g_lastRSRevDir  = -1;
            g_lastRSRevTime = time[i];
            string rsSellMsg = "📉 RS SELL EMA CROSS | " + _Symbol + " " +
                      EnumToString((ENUM_TIMEFRAMES)_Period) +
                      " | Price:" + DoubleToString(close[i], _Digits) +
                      FibTag(close[i], -1) + IntFibTag(close[i], -1);
            int rsSellBias = 0; GetFibZone(close[i], rsSellBias);
            FireAlert(rsSellMsg, false, rsSellBias == -1);
            CheckSequence(SEQ_RS, -1, time[i], close[i], curAtr);
           }
        }
     }
  }

//+------------------------------------------------------------------+
//  PIVOT HELPERS
//+------------------------------------------------------------------+
bool IsPivotHigh(const double &h[], int pos, int L, int R, int total)
  {
   if(pos - L < 0 || pos + R >= total) return false;
   double v = h[pos];
   for(int k = 1; k <= L; k++) if(h[pos-k] >= v) return false;
   for(int k = 1; k <= R; k++) if(h[pos+k] >= v) return false;
   return true;
  }

bool IsPivotLow(const double &l[], int pos, int L, int R, int total)
  {
   if(pos - L < 0 || pos + R >= total) return false;
   double v = l[pos];
   for(int k = 1; k <= L; k++) if(l[pos-k] <= v) return false;
   for(int k = 1; k <= R; k++) if(l[pos+k] <= v) return false;
   return true;
  }

void AddLevel(double price, double top, double bot, datetime t1, bool isHigh)
  {
   if(g_nLv >= 2000)
     { for(int i = 0; i < g_nLv - 1; i++) g_lv[i] = g_lv[i+1]; g_nLv--; }
   // FIX #8: chunk allocation — avoids expensive resize on every new pivot
   if(g_nLv >= ArraySize(g_lv))
      ArrayResize(g_lv, ArraySize(g_lv) + 256);
   g_lv[g_nLv].price       = price;
   g_lv[g_nLv].top         = top;
   g_lv[g_nLv].bot         = bot;
   g_lv[g_nLv].t1          = t1;
   g_lv[g_nLv].isHigh      = isHigh;
   g_lv[g_nLv].broken      = false;
   g_lv[g_nLv].flipAlerted = false;
   g_lv[g_nLv].swept       = false;
   g_nLv++;
  }

//+------------------------------------------------------------------+
//  MARKET STRUCTURE
//+------------------------------------------------------------------+
void UpdateMarketStructure()
  {
   double   sh1 = 0,  sh2 = 0;
   datetime sht1 = 0, sht2 = 0;
   double   sl1 = 0,  sl2 = 0;
   datetime slt1 = 0, slt2 = 0;

   for(int k = 0; k < g_nLv; k++)
     {
      if(g_lv[k].broken) continue;
      if(g_lv[k].isHigh)
        {
         if(g_lv[k].t1 > sht1)
           { sht2 = sht1; sh2 = sh1; sht1 = g_lv[k].t1; sh1 = g_lv[k].price; }
         else if(g_lv[k].t1 > sht2)
           { sht2 = g_lv[k].t1; sh2 = g_lv[k].price; }
        }
      else
        {
         if(g_lv[k].t1 > slt1)
           { slt2 = slt1; sl2 = sl1; slt1 = g_lv[k].t1; sl1 = g_lv[k].price; }
         else if(g_lv[k].t1 > slt2)
           { slt2 = g_lv[k].t1; sl2 = g_lv[k].price; }
        }
     }

   bool lowerHigh  = (sh1 > 0 && sh2 > 0 && sh1 < sh2);
   bool lowerLow   = (sl1 > 0 && sl2 > 0 && sl1 < sl2);
   bool higherHigh = (sh1 > 0 && sh2 > 0 && sh1 > sh2);
   bool higherLow  = (sl1 > 0 && sl2 > 0 && sl1 > sl2);

   if(lowerHigh  && lowerLow)       g_msDir = -1;
   else if(higherHigh && higherLow) g_msDir =  1;
  }

//+------------------------------------------------------------------+
//  GET NEXT N PIVOT TARGETS
//+------------------------------------------------------------------+
void GetNextPivots(bool isBuy, double refPrice, double &tp[], int n)
  {
   ArrayResize(tp, n);
   ArrayInitialize(tp, 0.0);
   double found[];
   int    fCount = 0;

   for(int k = 0; k < g_nLv; k++)
     {
      if(g_lv[k].broken) continue;
      if( isBuy && !g_lv[k].isHigh) continue;
      if(!isBuy &&  g_lv[k].isHigh) continue;
      if( isBuy && g_lv[k].price <= refPrice) continue;
      if(!isBuy && g_lv[k].price >= refPrice) continue;
      ArrayResize(found, fCount + 1);
      found[fCount++] = g_lv[k].price;
     }

   for(int a = 0; a < fCount - 1; a++)
      for(int b = a + 1; b < fCount; b++)
        {
         bool sw = isBuy ? (found[b] < found[a]) : (found[b] > found[a]);
         if(sw) { double tmp = found[a]; found[a] = found[b]; found[b] = tmp; }
        }

   for(int i = 0; i < n && i < fCount; i++)
      tp[i] = found[i];
  }

